---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import FAQSection from '../components/FAQSection.astro'
import { site, waUrl } from '../config/site'

const planSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `תכנון טיול ל${site.destinationName} - מסלולים מומלצים לישראלים`,
  description: `מדריך תכנון מלא ל${site.destinationName} עם מסלולים מומלצים לפי מספר ימים וסגנון טיול`,
  author: { '@type': 'Organization', name: site.brand },
  publisher: { '@type': 'Organization', name: site.brand, url: `https://${site.domain}` },
  datePublished: '2025-01-01',
  dateModified: '2026-04-06',
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: `תכנון טיול ל${site.destinationName}` },
]

const faqItems = [
  { q: `כמה ימים מומלץ לטיול ב${site.destinationName}?`, a: 'המינימום המומלץ הוא 3-4 ימים כדי לראות את עיקרי האטרקציות. 5-7 ימים מאפשרים לכם להכיר את העיר לעומק - לצאת מעבר למנהטן, לחוות ברוקלין, לאכול בשכונות השונות ולהנות בלי ללחוץ.' },
  { q: `מה העונה הכי טובה לטיול ב${site.destinationName}?`, a: 'כל עונה טובה! אביב (אפריל-מאי) וסתיו (ספטמבר-נובמבר) הם האידיאליים. קיץ חם ולח אבל יש אירועים. חורף קר אבל קסום - שלג בסנטרל פארק והנחות בחנויות.' },
  { q: `כמה כסף צריך ליום ב${site.destinationName}?`, a: 'בתקציב חסכוני: $100-150 ליום. בתקציב בינוני: $200-300 ליום. בתקציב גבוה: $400+ ליום. אוכל הוא ההוצאה הגדולה - אפשר לחסוך הרבה עם אוכל רחוב מעולה.' },
  { q: `האם כדאי לקנות New York Pass?`, a: 'אם אתם מתכננים 4+ אטרקציות בתשלום - CityPASS יחסוך לכם כ-40%. אם אתם יותר אוכל ושכונות - לא בטוח שמשתלם. חשבו מראש מה אתם רוצים לעשות.' },
  { q: `מה ההבדל בין סיור מודרך לטיול עצמאי ב${site.destinationName}?`, a: 'סיור מודרך נותן לכם סיפורים, פינות נסתרות, והמלצות שלא תמצאו באינטרנט. השילוב הכי טוב: סיור מודרך ביום הראשון כדי להכיר את העיר, ואחרי - לטייל לבד.' },
  { q: `איך הכי טוב להגיע ממנהטן ל-JFK?`, a: 'AirTrain + מטרו = הכי זול ($10.75). מונית/Uber = הכי נוח ($55-75). מ-JFK למנהטן חשבו שעה-שעה וחצי.' },
  { q: `מה כדאי לארוז לטיול ל${site.destinationName}?`, a: 'נעליים נוחות (15-20 אלף צעדים ביום!), שכבות ביגוד, מטריה קטנה, מתאם חשמל, כרטיס אשראי בינלאומי. בחורף: מעיל חם, כפפות וכובע צמר.' },
  { q: `כמה עולה מטרו ב${site.destinationName}?`, a: 'נסיעה בודדת $2.90. כרטיס שבועי $34 - שווה מאוד אם אתם 3+ ימים. אפשר לשלם עם Apple Pay / contactless.' },
]
---
<Layout
  title={`תכנון טיול ל${site.destinationName} - מסלולים, תקציב ועצות | ${site.brand}`}
  description={`תכננו את הטיול המושלם ל${site.destinationName}: מסלולים מומלצים ל-3, 5 ו-7 ימים, אומדן תקציב, עצות ממדריכים מקומיים ומידע מלא.`}
>
  <SchemaOrg schema={planSchema} />
<main dir="rtl" class="max-w-5xl mx-auto px-4 py-12">

  <Breadcrumb items={breadcrumbItems} />

  <div class="text-center mb-16">
    <div class="text-6xl mb-4">🗽</div>
    <h1 class="text-5xl font-bold text-white mb-4">תכנון טיול ל{site.destinationName}</h1>
    <p class="text-white/70 text-xl max-w-2xl mx-auto">כמה ימים יש לכם? בוחרים סגנון, ומקבלים מסלול מושלם ל{site.destinationName} עם כל מה שצריך - יום אחרי יום</p>
  </div>

  <!-- Duration picker -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">כמה זמן אתם ב{site.destinationName}?</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {[
        { days: '3 ימים', desc: 'סוף שבוע ארוך', id: '3' },
        { days: '5 ימים', desc: 'שבוע קלאסי', id: '5' },
        { days: '7+ ימים', desc: 'להכיר לעומק', id: '7' },
      ].map(t => (
        <button
          data-days={t.id}
          class="duration-btn bg-[#1A1208] rounded-xl p-6 text-center cursor-pointer hover:border-amber-500 border border-amber-500/10 hover:bg-amber-500/5 transition-all text-white"
        >
          <div class="font-bold text-lg">{t.days}</div>
          <div class="text-white/60 text-sm mt-1">{t.desc}</div>
        </button>
      ))}
    </div>
  </section>

  <!-- Style picker -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">מה סגנון הטיול שלכם ב{site.destinationName}?</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {[
        { type: 'קלאסי', desc: 'אטרקציות מרכזיות, צילומים', id: 'classic' },
        { type: 'אוכל', desc: 'מסעדות, שווקים, סיור אוכל', id: 'food' },
        { type: 'תרבות', desc: 'מוזיאונים, ברודווי, גלריות', id: 'culture' },
        { type: 'שופינג', desc: 'חנויות, אאוטלטים, וינטג\'', id: 'shopping' },
        { type: 'משפחות', desc: 'ילדים, פארקים, חוויות', id: 'family' },
        { type: 'היפסטרי', desc: 'ברוקלין, גלריות, קפה', id: 'hipster' },
      ].map(t => (
        <button
          data-style={t.id}
          class="style-btn bg-[#1A1208] rounded-xl p-5 cursor-pointer hover:bg-amber-500/5 border border-amber-500/10 hover:border-amber-500 transition-all text-white text-right"
        >
          <div class="text-xl mb-2 font-bold">{t.type}</div>
          <div class="text-white/60 text-sm">{t.desc}</div>
        </button>
      ))}
    </div>
  </section>

  <!-- Pre-built itineraries -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-8 text-center">מסלולים מומלצים לטיול ב{site.destinationName}</h2>

    <!-- 3-day itinerary -->
    <div data-itinerary="3" class="itinerary-card bg-[#1A1208] rounded-2xl p-8 mb-6 border border-amber-500/10 hover:border-amber-500/30 transition-all">
      <div class="flex items-center gap-3 mb-6">
        <div>
          <h3 class="text-xl font-bold text-white">מסלול 3 ימים ב{site.destinationName} - סוף שבוע ארוך</h3>
          <p class="text-white/60 text-sm">מסלול אינטנסיבי שמכסה את עיקרי {site.destinationName}</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          { day: 'יום 1', place: 'מנהטן - המרכז', note: 'טיימס סקוור, Top of the Rock, סנטרל פארק, 5th Avenue. ארוחת ערב באיסט וילג\'. סיור מנהטן מומלץ!' },
          { day: 'יום 2', place: 'דאונטאון + ברוקלין', note: 'פסל החירות, וול סטריט, גשר ברוקלין, DUMBO. ארוחת צהריים ב-Time Out Market. ברודווי בערב.' },
          { day: 'יום 3', place: 'Upper West + שופינג', note: 'מוזיאון הטבע / MET, סנטרל פארק, קניות ב-SoHo. ארוחת אוכל אחרונה ב-Chelsea Market.' },
        ].map(d => (
          <div class="flex gap-4 items-start">
            <div class="flex-1 border-r-2 border-amber-500 pr-4">
              <div class="font-bold text-white text-sm">{d.day} - {d.place}</div>
              <div class="text-white/70 text-sm mt-1">{d.note}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 5-day itinerary -->
    <div data-itinerary="5" class="itinerary-card bg-[#1A1208] rounded-2xl p-8 mb-6 border border-amber-500/10 hover:border-amber-500/30 transition-all">
      <div class="flex items-center gap-3 mb-6">
        <div>
          <h3 class="text-xl font-bold text-white">מסלול 5 ימים ב{site.destinationName} - שבוע קלאסי</h3>
          <p class="text-white/60 text-sm">5 ימים - המסלול הקלאסי והכי מומלץ לישראלים ב{site.destinationName}</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          { day: 'יום 1', place: 'מנהטן - עם מדריך', note: 'סיור מנהטן בעברית בבוקר. אחה"צ: Top of the Rock, Rockefeller Center. ערב: טיימס סקוור.' },
          { day: 'יום 2', place: 'דאונטאון + SoHo', note: 'פסל החירות, 9/11 Memorial, וול סטריט, Brooklyn Bridge. ארוחת צהריים ב-Little Italy / Chinatown. שופינג ב-SoHo.' },
          { day: 'יום 3', place: 'ברוקלין', note: 'סיור ברוקלין בעברית: Williamsburg, גרפיטי, Dumbo, Brooklyn Bridge Park. ארוחת ערב ב-Williamsburg.' },
          { day: 'יום 4', place: 'Upper Manhattan + מוזיאונים', note: 'MET / MoMA / מוזיאון הטבע. צהריים בסנטרל פארק. ברודווי בערב.' },
          { day: 'יום 5', place: 'סיור אוכל + שופינג', note: 'סיור אוכל: Lower East Side, Katz\'s, Russ & Daughters. אחה"צ: Chelsea Market, High Line. שופינג אחרון.' },
        ].map(d => (
          <div class="flex gap-4 items-start">
            <div class="flex-1 border-r-2 border-amber-500 pr-4">
              <div class="font-bold text-white text-sm">{d.day} - {d.place}</div>
              <div class="text-white/70 text-sm mt-1">{d.note}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 7-day itinerary -->
    <div data-itinerary="7" class="itinerary-card bg-[#1A1208] rounded-2xl p-8 mb-6 border border-amber-500/10 hover:border-amber-500/30 transition-all">
      <div class="flex items-center gap-3 mb-6">
        <div>
          <h3 class="text-xl font-bold text-white">מסלול 7 ימים ב{site.destinationName} - להכיר לעומק</h3>
          <p class="text-white/60 text-sm">שבוע מלא - לחוות את כל הפנים של {site.destinationName}</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          { day: 'יום 1', place: 'מנהטן הקלאסית', note: 'סיור מנהטן בעברית. Top of the Rock. ארוחת ערב בHell\'s Kitchen.' },
          { day: 'יום 2', place: 'דאונטאון + Tribeca', note: 'פסל החירות, 9/11, וול סטריט, Chinatown, Little Italy. ערב: East Village.' },
          { day: 'יום 3', place: 'ברוקלין', note: 'סיור ברוקלין: Williamsburg, Bushwick, DUMBO. גרפיטי וסמולנבורג.' },
          { day: 'יום 4', place: 'מוזיאונים + Central Park', note: 'MET / MoMA בבוקר. סנטרל פארק אחה"צ. ברודווי בערב.' },
          { day: 'יום 5', place: 'סיור אוכל + Chelsea', note: 'סיור אוכל: LES, Katz\'s, דמפלינגס. אחה"צ: Chelsea Market, High Line, Hudson Yards.' },
          { day: 'יום 6', place: 'Harlem + Upper Manhattan', note: 'Harlem בבוקר, מוזיאון ה-Met Cloisters. Washington Heights. ערב חופשי.' },
          { day: 'יום 7', place: 'שופינג + סגירה', note: 'SoHo, 5th Avenue, Woodbury Common (אופציה). ארוחה אחרונה במקום מיוחד.' },
        ].map(d => (
          <div class="flex gap-4 items-start">
            <div class="flex-1 border-r-2 border-amber-500 pr-4">
              <div class="font-bold text-white text-sm">{d.day} - {d.place}</div>
              <div class="text-white/70 text-sm mt-1">{d.note}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WhatsApp CTA -->
  <section class="mb-16">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/20 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">רוצים מסלול מותאם אישית ל{site.destinationName}?</h2>
      <p class="text-white/60 mb-6">ספרו לנו כמה ימים, מה הסגנון שלכם, ונבנה לכם מסלול מושלם</p>
      <a href={waUrl(`היי, אנחנו מתכננים טיול ל${site.destinationName} ורוצים עזרה עם מסלול`)} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-bold px-8 py-4 rounded-xl text-lg transition-all">
        בנו לנו מסלול בווטסאפ
      </a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-8 text-center">שאלות נפוצות - תכנון טיול ל{site.destinationName}</h2>
    <FAQSection items={faqItems} />
  </section>

</main>
</Layout>
