---
import Layout from '../components/Layout.astro'
---
<Layout title="תכנן את החופשה המושלמת בבאלי | יאללה באלי" description="תכנן את הטיול לבאלי: מסלולים מומלצים, לו״ז לפי ימים, עצות מקצועיות לישראלים">
<main dir="rtl" class="max-w-5xl mx-auto px-4 py-12">

  <!-- Hero -->
  <div class="text-center mb-16">
    <div class="text-6xl mb-4">🌴</div>
    <h1 class="text-5xl font-bold text-white mb-4">תכנן את באלי שלך</h1>
    <p class="text-gray-400 text-xl">כמה ימים יש לכם? נבנה לכם את המסלול המושלם</p>
  </div>

  <!-- Duration picker — visual cards -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">כמה זמן אתם בבאלי?</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        {days:'5 ימים', emoji:'⚡', desc:'נקודות השיא'},
        {days:'7 ימים', emoji:'🌊', desc:'שבוע מושלם'},
        {days:'10 ימים', emoji:'🏄', desc:'להכיר לעומק'},
        {days:'14+ ימים', emoji:'🧘', desc:'חיים בבאלי'},
      ].map(t => (
        <div class="bg-gray-900 rounded-xl p-6 text-center cursor-pointer hover:border-teal-500 border border-gray-800 hover:bg-gray-800 transition-all">
          <div class="text-4xl mb-3">{t.emoji}</div>
          <div class="text-white font-bold text-lg">{t.days}</div>
          <div class="text-gray-400 text-sm mt-1">{t.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Traveler type -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">מה הסגנון שלכם?</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {[
        {type:'🏄 גולשים', desc:'גלים, חוף, קאנגו', color:'blue'},
        {type:'🧘 ריטריט', desc:'יוגה, מדיטציה, אובוד', color:'purple'},
        {type:'🎉 מסיבות', desc:'קוטה, חיי לילה, ברים', color:'pink'},
        {type:'🏛️ תרבות', desc:'מקדשים, אמנות, היסטוריה', color:'amber'},
        {type:'🤿 הרפתקה', desc:'צלילה, מפלות, וולקאנו', color:'teal'},
        {type:'👨‍👩‍👧 משפחה', desc:'בטוח, נוח, מושלם', color:'green'},
      ].map(t => (
        <div class="bg-gray-900 rounded-xl p-5 cursor-pointer hover:bg-gray-800 border border-gray-800 hover:border-teal-500 transition-all">
          <div class="text-2xl mb-2">{t.type}</div>
          <div class="text-gray-400 text-sm">{t.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 3 pre-built itineraries as timeline cards -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-8 text-center">מסלולים מוכנים</h2>

    <!-- 7-day itinerary -->
    <div class="bg-gray-900 rounded-2xl p-8 mb-6 border border-gray-800">
      <div class="flex items-center gap-3 mb-6">
        <div class="text-3xl">🗓️</div>
        <div>
          <h3 class="text-xl font-bold text-white">שבוע קלאסי בבאלי</h3>
          <p class="text-gray-400 text-sm">7 ימים — הכי פופולרי אצל ישראלים</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          {day:'יום 1', place:'נחיתה + קאנגו', emoji:'✈️', note:'הגעה, check-in, ערב ראשון בבאלי'},
          {day:'יום 2-3', place:'קאנגו + גלישה', emoji:'🏄', note:'שיעור גלישה, בייק, קפה, sunset'},
          {day:'יום 4', place:'אובוד', emoji:'🌾', note:'שדות אורז, מקדש, שוק, יוגה'},
          {day:'יום 5', place:'נוסה פניידה', emoji:'🏝️', note:'day trip — Kelingking, Broken Beach'},
          {day:'יום 6', place:'אולוואטו', emoji:'🌅', note:'גלישה, Kecak בשקיעה, ארוחת ים'},
          {day:'יום 7', place:'טיסה חזרה', emoji:'✈️', note:'בוקר חופשי, checkout, נמל תעופה'},
        ].map(d => (
          <div class="flex gap-4 items-start">
            <div class="text-2xl w-8 flex-shrink-0">{d.emoji}</div>
            <div class="flex-1 border-r-2 border-teal-500 pr-4">
              <div class="font-bold text-white text-sm">{d.day} — {d.place}</div>
              <div class="text-gray-400 text-sm mt-1">{d.note}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 10-day itinerary -->
    <div class="bg-gray-900 rounded-2xl p-8 border border-gray-800">
      <div class="flex items-center gap-3 mb-6">
        <div class="text-3xl">🗓️</div>
        <div>
          <h3 class="text-xl font-bold text-white">10 ימים — לטייל לעומק</h3>
          <p class="text-gray-400 text-sm">למי שרוצה יותר מהרגיל</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          {day:'יום 1', place:'נחיתה + כוטה/לגיאן', emoji:'✈️', note:'הגעה, מנוחה, קניות'},
          {day:'יום 2-4', place:'קאנגו', emoji:'🏄', note:'גלישה, nomad life, nightlife'},
          {day:'יום 5', place:'הר בטור — Sunrise Trek', emoji:'🌋', note:'יציאה ב-02:00, שקיעת שמש מהפסגה'},
          {day:'יום 6-7', place:'אובוד', emoji:'🌾', note:'ריטריט יוגה, מקדשים, בישול בלינזי'},
          {day:'יום 8', place:'נוסה פניידה', emoji:'🏝️', note:'Kelingking + Angel Billabong'},
          {day:'יום 9', place:'אמד', emoji:'🤿', note:'צלילה על אוניית USAT Liberty'},
          {day:'יום 10', place:'אולוואטו + הטיסה', emoji:'🌅', note:'Kecak ואז נמל תעופה'},
        ].map(d => (
          <div class="flex gap-4 items-start">
            <div class="text-2xl w-8 flex-shrink-0">{d.emoji}</div>
            <div class="flex-1 border-r-2 border-teal-500 pr-4">
              <div class="font-bold text-white text-sm">{d.day} — {d.place}</div>
              <div class="text-gray-400 text-sm mt-1">{d.note}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Budget estimator -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">💰 אומדן תקציב לזוג</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        {type:'תרמיל', budget:'$80-120/יום', weekly:'~2,200 ₪', emoji:'🎒', items:['הוסטל/חדר פשוט','warung + שוק','Grab + קטנוע','פעילויות בחינם']},
        {type:'מאוזן', budget:'$150-250/יום', weekly:'~4,000 ₪', emoji:'🌿', items:['וילה/בוטיק','מסעדות טובות','Grab comf.','טיולים מאורגנים']},
        {type:'יוקרה', budget:'$300+/יום', weekly:'~7,500 ₪', emoji:'✨', items:['ריזורט/וילה פרטית','מסעדות פרמיום','נהג פרטי','ספא + ריטריטים']},
      ].map(b => (
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
          <div class="text-3xl mb-3">{b.emoji}</div>
          <div class="text-white font-bold text-lg mb-1">{b.type}</div>
          <div class="text-teal-400 font-bold text-xl mb-1">{b.budget}</div>
          <div class="text-gray-500 text-sm mb-4">לזוג: {b.weekly}</div>
          <ul class="space-y-2">
            {b.items.map(i => <li class="text-gray-400 text-sm">• {i}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Visa CTA -->
  <section class="bg-teal-900/30 border border-teal-500/40 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-4">🛂</div>
    <h2 class="text-2xl font-bold text-white mb-3">אל תשכחו ויזה לפני הטיסה!</h2>
    <p class="text-gray-400 mb-6">ישראלים חייבים ויזה לבאלי. אנחנו מגישים עבורכם — 185 ₪ בלבד.</p>
    <a href="/visa" class="inline-block bg-teal-500 hover:bg-teal-400 text-white font-bold py-3 px-8 rounded-xl transition-colors">
      לפרטים ולהרשמה ←
    </a>
  </section>

</main>
</Layout>
