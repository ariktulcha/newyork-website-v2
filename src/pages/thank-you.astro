---
import Layout from '../components/Layout.astro'
import { site, waUrl } from '../config/site'

const title = `תודה על ההזמנה | ${site.brand}`
const description = 'ההזמנה שלכם התקבלה בהצלחה. ניצור אתכם קשר בהקדם.'
---

<Layout title={title} description={description}>
  <section class="min-h-[60vh] flex items-center justify-center px-4 py-20">
    <div class="max-w-lg w-full text-center">
      <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-teal-500/10 border border-teal-500/20">
        <svg class="h-10 w-10 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-3xl md:text-4xl font-black text-white mb-4">ההזמנה התקבלה בהצלחה!</h1>
      <p class="text-lg text-white/70 leading-relaxed mb-8">
        תודה שבחרתם ב-{site.brand}. קיבלנו את הפרטים שלכם וניצור אתכם קשר בהקדם לאישור ההזמנה.
      </p>

      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <p class="text-white/60 text-sm mb-4">רוצים לקבל אישור מיידי? שלחו לנו הודעה בוואטסאפ:</p>
        <a
          href={waUrl(`היי, שלחתי הזמנה דרך האתר ואשמח לאישור`)}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white px-6 py-3 rounded-xl font-bold transition-all hover:scale-105"
        >
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span>שלחו הודעה בוואטסאפ</span>
        </a>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-6 py-3 rounded-xl border border-teal-500/20 text-white/70 hover:text-teal-400 hover:border-teal-500/40 transition-all text-sm font-medium">
          חזרה לדף הבית
        </a>
        <a href="/tours" class="px-6 py-3 rounded-xl bg-teal-500/10 text-teal-400 hover:bg-teal-500/20 transition-all text-sm font-medium">
          לכל הסיורים
        </a>
      </div>
    </div>
  </section>
</Layout>
