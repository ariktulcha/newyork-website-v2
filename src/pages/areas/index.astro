---
import Layout from '../../components/Layout.astro'
import AreaCard from '../../components/Cards/AreaCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'

const { data: items } = await supabaseAdmin
  .from('areas')
  .select('name_he, name_en, slug, image, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('name_he')

const areas = items || []

const title = 'שכונות בניו יורק — המדריך המלא | Yalla NY'
const description = 'מדריך שכונות בניו יורק: מנהטן, ברוקלין, קווינס, האדסון יארדס ועוד. מה יש בכל שכונה, איפה כדאי לישון, ומה מתאים לסגנון שלכם.'

const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'שכונות בניו יורק',
  description,
  numberOfItems: areas.length,
  itemListElement: areas.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: a.name_he,
    url: new URL(`/areas/${a.slug}`, Astro.site).toString(),
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'דף הבית', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'שכונות' },
  ],
}
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="relative py-20 px-4 bg-gradient-to-b from-teal-500/10 to-transparent">
    <div class="max-w-6xl mx-auto text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-teal-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">אזורים</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black mb-4">שכונות בניו יורק — איפה לישון ומה לעשות</h1>
      <p class="text-lg text-white/60 max-w-3xl mx-auto leading-relaxed">
        בניו יורק יש שכונות שונות לכל סוג של טיול. בחרו לפי סגנון החיים שלכם: אם אתם מחפשים חיי לילה, מנהטן תחתון;
        אם אתם מחפשים תרבות, ברוקלין; אם תיירות יוקרתית, אפר איסט סייד או סוהו. כל שכונה בעלת אופי משלה — טיפים, אטרקציות, מסעדות, ומחירים.
      </p>
      <p class="mt-6 text-teal-400 font-medium text-lg">{areas.length} שכונות בניו יורק</p>
    </div>
  </section>

  <!-- Area selection guide -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white mb-8">בחרו שכונה לפי סגנון הטיול שלכם</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6">
        <h3 class="text-white font-bold mb-4">🗽 לתיירות ואטרקציות</h3>
        <p class="text-white/70 text-sm mb-4">מידטאון מנהטן — טיימס סקוור, ברודווי, סנטרל פארק, אמפייר סטייט. מרכז העניינים התיירותי.</p>
        <a href="/areas/midtown" class="text-teal-400 text-sm hover:underline">חקרו את מידטאון ↙</a>
      </div>
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6">
        <h3 class="text-white font-bold mb-4">🎨 לתרבות ואמנות</h3>
        <p class="text-white/70 text-sm mb-4">ברוקלין — וויליאמסבורג, דאמבו, בושוויק. גלריות, שווקים, אוכל רחוב, חיי לילה אלטרנטיביים.</p>
        <a href="/areas/brooklyn" class="text-teal-400 text-sm hover:underline">חקרו את ברוקלין ↙</a>
      </div>
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6">
        <h3 class="text-white font-bold mb-4">✨ ליוקרה ושופינג</h3>
        <p class="text-white/70 text-sm mb-4">אפר איסט סייד וסוהו — חנויות מעצבים, מסעדות יוקרה, גלריות, אווירה מתוחכמת.</p>
        <a href="/areas/soho" class="text-teal-400 text-sm hover:underline">חקרו את סוהו ↙</a>
      </div>
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6">
        <h3 class="text-white font-bold mb-4">👨‍👩‍👧 למשפחות</h3>
        <p class="text-white/70 text-sm mb-4">אפר ווסט סייד — מוזיאון הטבע, סנטרל פארק, פארקים ומגרשי משחקים. שכונה שקטה ומשפחתית.</p>
        <a href="/areas/upper-west-side" class="text-teal-400 text-sm hover:underline">חקרו את אפר ווסט סייד ↙</a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 pb-20">
    {areas.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((area) => (
          <AreaCard {...area} />
        ))}
      </div>
    ) : (
      <p class="text-center text-white/40 py-12">לא נמצאו אזורים כרגע.</p>
    )}
  </section>
</Layout>
