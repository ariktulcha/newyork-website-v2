---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import AttractionCard from '../../../components/Cards/AttractionCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'
import { site, waUrl } from '../../../config/site'

const { data } = await supabaseAdmin
  .from('attractions')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(a => a.is_free === true || a.price_range === 'חינם' || a.price_range === 'free')

const pageTitle = `אטרקציות חינם ב${site.destinationName} | ${site.brand}`
const pageDescription = `אטרקציות חינם בניו יורק — סנטרל פארק, גשר בורוקלין, שווקים, מהלכים על גדות ירידות וקוים גבוהות ללא תשלום. חוויות מעולות בחינם בניו יורק.`

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `אטרקציות חינם ב${site.destinationName}`,
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/attractions/${item.slug}`, `https://${site.domain}`).toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'אטרקציות', href: '/attractions' },
  { label: 'חינם' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/attractions/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-amber-500 text-black whitespace-nowrap">חינם</span>
      <a href="/attractions/kids/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">לילדים</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">אטרקציות חינם ב{site.destinationName}</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        {site.destinationName} לא חייבת להיות יקרה. יש המון אטרקציות חינמיות מדהימות —
        מסנטרל פארק ועד גשר ברוקלין, נמל חופשי בסטטן איילנד פרי ועוד.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <AttractionCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            price={item.price}
            rating={item.rating}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו אטרקציות חינם כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-amber-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-amber-400 mb-6">שאלות נפוצות — אטרקציות חינם ב{site.destinationName}</h2>
      <div class="space-y-4">
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה אפשר לעשות ב{site.destinationName} בחינם?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">{site.destinationName} מציעה הרבה חוויות חינם: סנטרל פארק, גשר ברוקלין, High Line, טיימס סקוור, סטטן איילנד פרי, שווקי רחוב, גלריות חינמיות בצ'לסי, וטיולים ברחבי מנהטן.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">האם המוזיאונים ב{site.destinationName} בחינם?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">חלק מהמוזיאונים ב{site.destinationName} מציעים כניסה חופשית או "שלמו כרצונכם" — כולל המוזיאון לאמנות מודרנית (MoMA) בימי שישי בערב, המוזיאון האמריקני להיסטוריה טבעית, ומוזיאון ברוקלין.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה הפארקים החינמיים הטובים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">הפארקים החינמיים הטובים ב{site.destinationName} כוללים: סנטרל פארק, High Line, ברייאנט פארק, בטרי פארק, Washington Square Park, ופרוספקט פארק בברוקלין. כולם פתוחים לציבור ללא תשלום.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">האם סטטן איילנד פרי ב{site.destinationName} בחינם?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, סטטן איילנד פרי ב{site.destinationName} הוא לגמרי בחינם. ההפלגה מציעה נוף מרהיב של פסל החירות, קו הרקיע של מנהטן וגשר ורזאנו — אחת האטרקציות החינמיות הטובות ב{site.destinationName}.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה טיולים רגליים חינם ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם ב{site.destinationName} כוללות טיולים רגליים: הליכה על גשר ברוקלין, טיול ב-High Line, סיור בסוהו וצ'איינטאון, טיול לאורך הריברסייד פארק ברחבי מנהטן. טיולים חינמיים ב{site.destinationName} מגלים את הנשמה האמיתית של העיר.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה גלריות חינמיות ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם ב{site.destinationName} כוללות מאות גלריות אמנות בחינם בצ'לסי, Lower East Side ו-Williamsburg. גם National Museum of the American Indian ו-The Bronx Museum of the Arts הם בכניסה חופשית.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה אירועים חינם ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם ב{site.destinationName} כוללות אירועים לאורך השנה: הופעות חינם בסנטרל פארק (SummerStage), סרטים בפארקים בקיץ, פסטיבלי רחוב, ופעילויות עונתיות בברייאנט פארק וטיימס סקוור.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה הזמן הטוב ביותר לבקר באטרקציות חינם ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם ב{site.destinationName} מושלמות בסתיו (ספטמבר-נובמבר) עם מזג אוויר נעים ועלי שלכת. האביב (אפריל-יוני) גם נהדר. בקיץ יש הכי הרבה אירועים חינם אך חם ולח.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">איך להגיע לאטרקציות חינם ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם ב{site.destinationName} נגישות בתחבורה ציבורית מצוינת — הסאבוויי פועל 24/7 ומגיע לכל מקום. כרטיס OMNY או MetroCard מאפשרים נסיעות ללא הגבלה. רוב האטרקציות החינמיות נמצאות במרחק הליכה מתחנת רכבת תחתית.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים לדעת עוד על אטרקציות חינם ב{site.destinationName}?</p>
      <a
        href={waUrl(`היי, אנחנו מחפשים אטרקציות חינם ב${site.destinationName}`)}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
