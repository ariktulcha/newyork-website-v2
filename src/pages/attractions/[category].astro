---
import Layout from '../../components/Layout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import AttractionCard from '../../components/Cards/AttractionCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import { site, waUrl } from '../../config/site'
import { marked } from 'marked'

type CategoryPage = {
  slug: string
  title: string
  subtitle: string | null
  description: string | null
  hero_image_url: string | null
  source_category_field: string
  source_category_value: string
  intro_content: string | null
  faq: { q: string; a: string }[] | null
  meta_title: string
  meta_description: string
}

export async function getStaticPaths() {
  const { data: pages } = await supabaseAdmin
    .from('category_pages')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('source_table', 'attractions')
    .eq('published', true)
    .order('sort_order', { ascending: true })

  const allPages = pages ?? []
  return allPages.map((page: CategoryPage) => ({
    params: { category: page.slug },
    props: { page, allPages },
  }))
}

const { page, allPages } = Astro.props as { page: CategoryPage; allPages: CategoryPage[] }

const baseQuery = supabaseAdmin
  .from('attractions')
  .select('name_he, name_en, slug, image, area, price_range, is_free, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const field = page.source_category_field
const value = page.source_category_value
const values = value.split('|').map(v => v.trim()).filter(Boolean)

let items: any[] = []
if (field === 'area') {
  const orClause = values.map(v => `area.ilike.%${v}%`).join(',')
  const { data } = await baseQuery.or(orClause).order('name_he')
  items = data ?? []
} else if (field === 'is_free' || field === 'family_friendly') {
  const boolVal = value === 'true'
  const { data } = await baseQuery.eq(field, boolVal).order('name_he')
  items = data ?? []
} else {
  const { data } = await baseQuery.eq(field, value).order('name_he')
  items = data ?? []
}

const introHtml = page.intro_content ? await marked(page.intro_content) : ''
const faqItems = Array.isArray(page.faq) ? page.faq : []

const pageUrl = new URL(`/attractions/${page.slug}`, Astro.site).toString()

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: page.title,
  description: page.meta_description,
  numberOfItems: items.length,
  itemListElement: items.map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: r.name_he,
    url: new URL(`/attractions/${r.slug}`, Astro.site).toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'אטרקציות', href: '/attractions' },
  { label: page.title },
]

const whatsappMsg = `היי, אנחנו מחפשים ${page.title.toLowerCase()} ב${site.destinationName}`
---

<Layout
  title={page.meta_title}
  description={page.meta_description}
  canonical={pageUrl}
  ogImage={page.hero_image_url || undefined}
  schema={itemListSchema}
>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <header class="relative mb-10 overflow-hidden rounded-2xl border border-emerald-500/10 bg-gradient-to-b from-emerald-500/10 to-transparent">
      {page.hero_image_url && (
        <div class="absolute inset-0 opacity-30">
          <img src={page.hero_image_url} alt={page.title} class="h-full w-full object-cover" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-b from-[#1A0A1F]/40 to-[#1A0A1F]"></div>
        </div>
      )}
      <div class="relative p-8 md:p-12 text-center">
        <h1 class="text-3xl md:text-5xl font-black text-white mb-3">{page.title}</h1>
        {page.subtitle && <p class="text-lg md:text-xl text-emerald-400 font-medium mb-4">{page.subtitle}</p>}
        {page.description && <p class="max-w-2xl mx-auto text-white/70 leading-relaxed">{page.description}</p>}
        <p class="mt-4 text-sm text-emerald-400/80 font-medium">{items.length} אטרקציות ב{site.destinationName}</p>
      </div>
    </header>

    <nav class="mb-10 overflow-x-auto scrollbar-hide" aria-label="קטגוריות אטרקציות">
      <div class="flex gap-2 min-w-max pb-2" dir="rtl">
        <a href="/attractions/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
        {allPages.map(p => (
          p.slug === page.slug ? (
            <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-emerald-500 text-black whitespace-nowrap">{p.title}</span>
          ) : (
            <a href={`/attractions/${p.slug}/`} class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">{p.title}</a>
          )
        ))}
      </div>
    </nav>

    {introHtml && (
      <section class="prose prose-invert max-w-none mb-12 [&_h2]:text-emerald-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:border-r-4 [&_h2]:border-emerald-500 [&_h2]:pr-3 [&_h3]:text-emerald-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-emerald-400 [&_strong]:text-white [&_ul]:list-disc [&_ul]:pr-5 [&_li]:my-1 [&_p]:leading-relaxed [&_p]:text-white/80" set:html={introHtml} />
    )}

    <section class="mb-16">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-6 border-r-4 border-emerald-500 pr-4">
        {page.title} — כל ההמלצות
      </h2>
      {items.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {items.map(item => (
            <AttractionCard
              name_he={item.name_he}
              name_en={item.name_en}
              slug={item.slug}
              image={item.image}
              area={item.area}
              price_range={item.price_range}
              is_free={item.is_free}
              rating={item.rating}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-[#2D1B3D] rounded-2xl border border-emerald-500/10">
          <p class="text-white/40 text-lg">לא נמצאו אטרקציות בקטגוריה זו כרגע.</p>
        </div>
      )}
    </section>

    {faqItems.length > 0 && (
      <section class="mb-16">
        <FAQSection items={faqItems} />
      </section>
    )}

    <div class="bg-gradient-to-br from-emerald-900/20 to-emerald-800/10 border border-emerald-500/30 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-black text-emerald-400 mb-3">מחפשים את {page.title} המתאימים לכם?</h2>
      <p class="text-white/70 mb-6 max-w-2xl mx-auto">
        אנחנו מכירים את האטרקציות של {site.destinationName} מבפנים — נעזור לכם לבחור את האטרקציה הנכון לפי התקציב, האזור והסגנון שלכם.
      </p>
      <a
        href={waUrl(whatsappMsg)}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>דברו איתנו בוואטסאפ</span>
      </a>
    </div>
  </main>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
