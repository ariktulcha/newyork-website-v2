---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import AttractionCard from '../../../components/Cards/AttractionCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'
import { site, waUrl } from '../../../config/site'

const { data } = await supabaseAdmin
  .from('attractions')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const KIDS_KEYWORDS = ['ילד', 'ילדים', 'משפחה', 'פארק', 'אקווריום', 'zoo', 'גן חיות', 'כיף', 'playground', 'museum of natural history', 'liberty science']
const items = (data || []).filter(a =>
  a.family_friendly === true ||
  (a.category || '').includes('kids') || (a.category || '').includes('family') ||
  KIDS_KEYWORDS.some(kw =>
    (a.name_he || '').toLowerCase().includes(kw.toLowerCase()) ||
    (a.name_en || '').toLowerCase().includes(kw.toLowerCase()) ||
    (a.excerpt || '').toLowerCase().includes(kw.toLowerCase())
  )
)

const pageTitle = `אטרקציות לילדים ב${site.destinationName} | ${site.brand}`
const pageDescription = `אטרקציות לילדים ולמשפחות ב${site.destinationName}. מוזיאונים, פארקים, גן חיות ועוד — כל מה שצריך לטיול משפחתי מוצלח.`

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `אטרקציות לילדים ב${site.destinationName}`,
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/attractions/${item.slug}`, `https://${site.domain}`).toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'אטרקציות', href: '/attractions' },
  { label: 'לילדים' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/attractions/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/attractions/free/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">חינם</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-amber-500 text-black whitespace-nowrap">לילדים</span>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">אטרקציות לילדים ב{site.destinationName}</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        {site.destinationName} היא גן עדן לילדים — המוזיאון האמריקני להיסטוריה טבעית, גן החיות של ברונקס,
        סנטרל פארק, Top of the Rock ועוד אינספור פעילויות שיהפכו את הטיול המשפחתי לבלתי נשכח.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <AttractionCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            price={item.price}
            rating={item.rating}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו אטרקציות לילדים כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-amber-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-amber-400 mb-6">שאלות נפוצות — אטרקציות לילדים ב{site.destinationName}</h2>
      <div class="space-y-4">
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה האטרקציות הכי טובות לילדים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">האטרקציות המובילות לילדים ב{site.destinationName} כוללות: המוזיאון האמריקני להיסטוריה טבעית, גן החיות של ברונקס, סנטרל פארק (כולל קרוסלה ומגרשי משחקים), Top of the Rock, ו-Intrepid Sea, Air & Space Museum.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מאיזה גיל מתאימות האטרקציות לילדים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">יש אטרקציות לילדים ב{site.destinationName} לכל גיל — מגיל שנה ועד נוער. מוזיאון הילדים מתאים מגיל 2, סנטרל פארק לכל גיל, מוזיאונים גדולים מגיל 5, ואטרקציות כמו Top of the Rock מגיל 4 ומעלה.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">האם יש אטרקציות מקורות לילדים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, אטרקציות לילדים ב{site.destinationName} מקורות כוללות: מוזיאון הילדים של מנהטן, המוזיאון להיסטוריה טבעית, New York Hall of Science, ו-Liberty Science Center. מושלם לימים גשומים או קרים.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה פעילויות חוצות ב{site.destinationName} לילדים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים ב{site.destinationName} כוללות פעילויות חוצות: רכיבה על אופניים בסנטרל פארק, שיט בסירות בלייק בפארק, מגרשי משחקים ייחודיים, גן החיות של סנטרל פארק, וטיול על ה-High Line. ב{site.destinationName} יש גם החלקה על קרח בחורף ב-Rockefeller Center.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה גני חיות ב{site.destinationName} לילדים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים ב{site.destinationName} כוללות גני חיות: גן החיות של ברונקס (הגדול בארה"ב), גן החיות של סנטרל פארק, פרוספקט פארק Zoo, ו-Queens Zoo. גני החיות ב{site.destinationName} מציעים חוויה חינוכית לילדים.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה מוזיאונים לילדים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים ב{site.destinationName} כוללות מוזיאונים: מוזיאון הילדים של מנהטן, Brooklyn Children's Museum, המוזיאון האמריקני להיסטוריה טבעית עם דינוזאורים, ו-Intrepid Museum עם מטוסים וצוללת. מוזיאונים אלה מותאמים לילדים בכל הגילאים.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה הגיל הטוב ביותר לאטרקציות לילדים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים ב{site.destinationName} מתאימות לכל גיל: עד גיל 3 — סנטרל פארק ומגרשי משחקים, גיל 3-7 — מוזיאון ילדים וגני חיות, גיל 7-12 — מוזיאון טבע ו-Top of the Rock, גיל 12 ומעלה — הופעות ברודווי ו-One World Observatory.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">כמה עולות אטרקציות לילדים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים ב{site.destinationName}: מוזיאון ילדים מ-$15, גן חיות סנטרל פארק מ-$14, גן חיות ברונקס מ-$30, Top of the Rock מ-$40. מומלץ לרכוש CityPASS שחוסך עד 40% על הכניסות הגדולות.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה טיפים לביקור באטרקציות לילדים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים ב{site.destinationName} — טיפים: הגיעו מוקדם בבוקר כדי להימנע מתורים, הביאו נעליים נוחות (הרבה הליכה), קנו כרטיסים מראש אונליין. האביב והסתיו הם העונות הטובות ביותר — מזג אוויר נעים ופחות עומסים מהקיץ.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">מתכננים טיול עם ילדים ל{site.destinationName}?</p>
      <a
        href={waUrl(`היי, אנחנו מתכננים טיול עם ילדים ל${site.destinationName}`)}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
