---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import { site, waUrl } from '../config/site'

const services = [
  { icon: '🎒', title: 'סיורים בעברית', description: `סיורים מודרכים ב${site.destinationName} עם מדריכים ישראלים שגרים בעיר. מנהטן, ברוקלין, סיור אוכל - חוויות אותנטיות שלא תשכחו.` },
  { icon: '📖', title: 'מדריכים מפורטים', description: `מאות עמודים של תוכן מקורי בעברית: אטרקציות, מסעדות, מלונות, שכונות, ברודווי ועוד. כל מדריך נכתב מניסיון אישי ומתעדכן באופן שוטף.` },
  { icon: '📍', title: 'תכנון טיול', description: `כלי תכנון טיול חכם שבונה לכם מסלול מותאם אישית ל${site.destinationName} לפי מספר ימים, סגנון טיול ותחומי עניין.` },
  { icon: '📱', title: 'שירות אישי בווטסאפ', description: `שאלה? בעיה? צריכים המלצה? שלחו לנו הודעה בווטסאפ ונחזור אליכם תוך דקות. אנחנו זמינים לכל שאלה - לפני, במהלך ואחרי הטיול.` },
]

const values = [
  { icon: '🗽', title: `תשוקה ל${site.destinationName}`, description: `אנחנו מכירים כל פינה ב${site.destinationName} ואוהבים לשתף את הידע. כל המלצה מבוססת על ביקור אישי.` },
  { icon: '🛡️', title: 'אמינות ושקיפות', description: 'מחירים שקופים, ביקורות כנות, ואין תוכן ממומן סמוי. מה שאנחנו ממליצים - אנחנו באמת אוהבים.' },
  { icon: '👥', title: 'קהילה ישראלית', description: 'הכל בעברית, מותאם לתייר הישראלי. כשרות, שבת, מחירים - אנחנו מבינים את הצרכים שלכם.' },
  { icon: '⭐', title: 'מצוינות', description: `אנחנו שואפים להיות המדריך הכי טוב ומקיף ל${site.destinationName} בעברית. תוכן מעודכן, מדויק ושימושי.` },
]

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `אודות ${site.brandHe}`,
  description: `${site.brandHe} - ${site.taglineHe}.`,
  author: { '@type': 'Organization', name: site.brand },
  publisher: { '@type': 'Organization', name: site.brand, url: `https://${site.domain}` },
  mainEntityOfPage: `https://${site.domain}/about`,
  inLanguage: 'he',
  datePublished: '2025-01-01',
  dateModified: '2026-04-06',
}
---

<Layout
  title={`אודות ${site.brandHe}`}
  description={`${site.brandHe} - ${site.taglineHe}. מי אנחנו, מה המשימה שלנו, ואיך אנחנו עוזרים לתיירים ישראלים לגלות את ${site.destinationName}.`}
  canonical={`https://${site.domain}/about`}
>
  <SchemaOrg schema={articleSchema} />

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-amber-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">אודות <span class="text-amber-400">{site.brandHe}</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">{site.taglineHe}. סיורים בעברית, מדריכים מפורטים ושירות אישי לכל מטייל.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/20 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl md:text-3xl font-bold text-amber-400 mb-6">הסיפור שלנו</h2>
      <div class="space-y-4 text-white/70 leading-relaxed">
        <p>
          {site.brandHe} נולד מתוך אהבה עמוקה ל{site.destinationName} וההבנה שחסר משהו מהותי: מדריך איכותי, מקיף ומעודכן בעברית לישראלים שמגיעים לעיר הגדולה.
          בשנים האחרונות, עשרות אלפי ישראלים מבקרים ב{site.destinationName} כל שנה - אחד היעדים הפופולריים ביותר מישראל. אבל המידע בעברית היה פזור, לא מעודכן, ולא התאים לצרכים הייחודיים של המטייל הישראלי.
        </p>
        <p>
          החלטנו לשנות את זה. הקמנו את <strong class="text-white">המדריך הכי מקיף ל{site.destinationName} בעברית</strong> - עם אטרקציות מפורטות, מסעדות, מלונות, שכונות, ברודווי ועוד. בנוסף, אנחנו מפעילים <strong class="text-white">סיורים מודרכים בעברית</strong> עם ישראלים שגרים ב{site.destinationName} ומכירים כל פינה בעיר.
        </p>
        <p>
          המטרה שלנו <strong class="text-white">פשוטה וברורה</strong>: שכל ישראלי שמגיע ל{site.destinationName} ייהנה מטיול מושלם - עם כל המידע שצריך, בשפה שלו, עם תמיכה אישית בכל שלב.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">מה אנחנו <span class="text-amber-400">מציעים</span></h2>
    <p class="text-white/60 text-center mb-10 max-w-2xl mx-auto">כל מה שצריך לטיול מושלם ב{site.destinationName} - במקום אחד, בעברית</p>
    <div class="grid md:grid-cols-2 gap-6">
      {services.map((s) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 rounded-2xl p-6 hover:border-amber-500/30 transition-all">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-amber-500/10 border border-amber-500/20 rounded-xl flex items-center justify-center text-2xl">{s.icon}</div>
            <h3 class="text-xl font-bold text-white">{s.title}</h3>
          </div>
          <p class="text-white/60 leading-relaxed">{s.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">הערכים <span class="text-amber-400">שלנו</span></h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4">
      {values.map((v) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 rounded-2xl p-5 text-center hover:border-amber-500/30 transition-all">
          <span class="text-3xl block mb-3">{v.icon}</span>
          <h3 class="text-white font-bold mb-2">{v.title}</h3>
          <p class="text-white/50 text-sm leading-relaxed">{v.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-gradient-to-b from-[#0D0D0D] to-[#1A1208] py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-6">מוכנים <span class="text-amber-400">להתחיל?</span></h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto">גלו את כל מה ש{site.destinationName} יכולה להציע - סיורים, אטרקציות ומדריכים מפורטים</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/tours" class="bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-black px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-amber-500/25">בחרו סיור</a>
        <a href="/attractions" class="bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all border border-white/20">גלו אטרקציות</a>
      </div>
    </div>
  </section>
</Layout>
