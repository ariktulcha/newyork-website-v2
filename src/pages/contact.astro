---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import { site, waUrl } from '../config/site'

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `צור קשר - ${site.brandHe}`,
  description: `צרו קשר עם ${site.brandHe} בווטסאפ או באימייל.`,
  url: `https://${site.domain}/contact`,
  mainEntity: {
    '@type': 'Organization',
    name: site.brand,
    url: `https://${site.domain}`,
    email: `info@${site.domain}`,
    contactPoint: { '@type': 'ContactPoint', contactType: 'customer service', availableLanguage: ['Hebrew', 'English'] },
  },
}

const commonTopics = [
  { title: 'הזמנת סיור', desc: `סיורים בעברית ב${site.destinationName} - הזמנה מהירה עם אישור מיידי` },
  { title: 'תכנון טיול', desc: `עזרה בבניית מסלול, בחירת מלון, המלצות מותאמות ל${site.destinationName}` },
  { title: `שאלות על ${site.destinationName}`, desc: 'ויזה, מטרו, בטיחות, תחבורה - כל שאלה' },
  { title: 'המלצות למסעדות', desc: 'כשר, לא כשר, יוקרתי, תקציבי - נמצא לכם' },
  { title: 'כרטיסים לברודווי', desc: 'עזרה בהזמנת כרטיסים להצגות ברודווי' },
  { title: 'שיתופי פעולה', desc: 'עסקים, בלוגרים, אתרי תיירות - בואו נדבר' },
]
---

<Layout
  title={`צור קשר - ${site.brandHe}`}
  description={`צרו קשר עם ${site.brandHe} בווטסאפ או באימייל. נשמח לעזור לכם לתכנן את הטיול המושלם ל${site.destinationName}.`}
  canonical={`https://${site.domain}/contact`}
>
  <SchemaOrg schema={contactSchema} />

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">צרו <span class="text-amber-400">קשר</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">נשמח לעזור לכם לתכנן את הטיול המושלם ל{site.destinationName}. שלחו הודעה בווטסאפ ונחזור אליכם תוך דקות.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 -mt-8 relative z-20 mb-12">
    <a href={waUrl()} target="_blank" rel="noopener noreferrer" class="block bg-gradient-to-r from-green-600 to-green-500 hover:from-green-500 hover:to-green-400 rounded-2xl p-8 md:p-10 text-center transition-all shadow-lg shadow-green-600/20 group">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-3">שלחו הודעה בווטסאפ</h2>
      <p class="text-white/90 text-lg mb-4 max-w-md mx-auto">הדרך הכי מהירה לתשובות. שלחו הודעה ונחזור אליכם תוך דקות.</p>
      <div class="flex flex-wrap justify-center gap-4 text-white/80 text-sm">
        <span>זמינים כל יום</span>
        <span>מענה מהיר</span>
        <span>עברית ואנגלית</span>
      </div>
    </a>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="grid md:grid-cols-2 gap-6">
      <a href={`mailto:info@${site.domain}`} class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/20 hover:border-amber-500/40 rounded-2xl p-6 text-center transition-all group">
        <h3 class="text-xl font-bold text-white mb-2">אימייל</h3>
        <p class="text-white/60 text-sm mb-3">לשאלות מפורטות, שיתופי פעולה ופניות עסקיות</p>
        <span class="text-amber-400 font-bold" dir="ltr">info@{site.domain}</span>
      </a>
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 rounded-2xl p-6 text-center">
        <h3 class="text-xl font-bold text-white mb-2">זמני מענה</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between text-white/60"><span>וואטסאפ:</span><span class="text-green-400 font-bold">תוך דקות</span></div>
          <div class="flex justify-between text-white/60"><span>אימייל:</span><span class="text-amber-400 font-bold">עד 24 שעות</span></div>
          <div class="flex justify-between text-white/60"><span>שעות פעילות:</span><span class="text-white font-bold">כל יום, 08:00-23:00</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">פונים אלינו <span class="text-amber-400">בנושאים:</span></h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {commonTopics.map((t) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 rounded-xl p-4">
          <h3 class="text-white font-bold mb-1">{t.title}</h3>
          <p class="text-white/50 text-sm">{t.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/20 rounded-2xl p-6 md:p-8 text-center">
      <h3 class="text-xl font-bold text-white mb-3">אולי התשובה כבר נמצאת אצלנו?</h3>
      <p class="text-white/60 mb-4">בדקו את דף השאלות הנפוצות - שם תמצאו תשובות מפורטות לשאלות נפוצות על טיול ל{site.destinationName}</p>
      <a href="/faq" class="inline-flex items-center gap-2 bg-[#0D0D0D] border border-amber-500/30 hover:border-amber-500/50 text-amber-400 px-6 py-3 rounded-xl font-bold transition-all">שאלות ותשובות</a>
    </div>
  </section>
</Layout>
