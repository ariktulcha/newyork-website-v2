---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'

const kosherRestaurants = [
  { name: 'Armani/Kaf', area: 'דאונטאון דובאי', type: 'בשרי', cuisine: 'ים תיכוני', description: 'מסעדה כשרה במלון ארמאני בבורג\' חליפה. תפריט ים תיכוני עשיר עם בשרים, דגים ומנות טבעוניות. השגחה של רב מקומי.', priceRange: '₪₪₪₪', highlight: 'מיקום בתוך בורג\' חליפה' },
  { name: 'Eli\'s Kosher Kitchen', area: 'JBR - ג\'ומיירה ביץ\' רזידנס', type: 'בשרי', cuisine: 'מזרחי/ישראלי', description: 'מסעדה עם אווירה ביתית, תפריט ישראלי מוכר עם שווארמה, קבב, סלטים והומוס. פופולרית מאוד בקרב תיירים ישראלים.', priceRange: '₪₪₪', highlight: 'אווירה ישראלית' },
  { name: 'The Kosher Grill', area: 'דובאי מרינה', type: 'בשרי', cuisine: 'גריל/סטייקים', description: 'בית סטייק כשר עם בשרים איכותיים על הגריל. מנות דגל כוללות ריביי, אנטריקוט ומנות צד עשירות. מיקום מצוין על המרינה.', priceRange: '₪₪₪₪', highlight: 'נוף למרינה' },
  { name: 'Dairy by the Sea', area: 'פאלם ג\'ומיירה', type: 'חלבי', cuisine: 'איטלקי/חלבי', description: 'מסעדה חלבית עם פסטות, פיצות, סלטים ומנות דגים. מיקום מרהיב על הפאלם עם נוף לים. מושלמת לארוחת ערב רומנטית.', priceRange: '₪₪₪', highlight: 'נוף לים' },
]

const supermarkets = [
  { name: 'Spinneys', description: 'רשת סופרמרקטים גדולה עם מדור מוצרים כשרים. תמצאו חלות, יין לקידוש, מוצרים עם הכשרים מוכרים (OU, OK) ומוצרים ישראליים.', locations: 'סניפים בכל העיר — המרינה, JBR, דאונטאון' },
  { name: 'Carrefour', description: 'רשת הסופרמרקטים הגדולה ביותר. יש מדור בינלאומי עם מוצרים כשרים מיובאים מאירופה וארה"ב. גם בשר חלאל שמתאים למי שמקפיד פחות.', locations: 'דובאי מול, מול אוף דה אמירייטס, ועוד' },
  { name: 'West Zone Supermarket', description: 'סופרמרקט עם מבחר מוצרים בינלאומיים. כולל מוצרים עם הכשרים, קטניות, שימורים ומוצרים יבשים כשרים.', locations: 'סניפים ב-JBR, דובאי מרינה, ג\'ומיירה' },
]

const shabbatInfo = [
  { title: 'תפילות שבת', description: 'בית הכנסת הרשמי בדובאי פתוח לתפילות שבת. יש גם מניינים פרטיים במלונות שונים בעונת התיירות. מומלץ לבדוק מראש.' },
  { title: 'סעודות שבת', description: 'הקהילה היהודית בדובאי מארגנת סעודות שבת ציבוריות, בעיקר בעונת השיא. כמה מלונות מציעים ארוחות שבת כשרות עם הזמנה מראש.' },
  { title: 'עירוב', description: 'אין עירוב רשמי בדובאי. מי שמקפיד על הלכות שבת צריך להתכונן בהתאם. רוב האזורים התיירותיים הם בהליכה מהמלונות.' },
  { title: 'מוצאי שבת', description: 'זמני הצאת שבת בדובאי — חורף: סביב 17:30-18:00, קיץ: סביב 19:00-19:30. מומלץ לבדוק זמנים מדויקים באפליקציות כמו Hebcal.' },
]

const kosherTips = [
  { title: 'הביאו מוצרים מהבית', desc: 'אם אתם מקפידים על כשרות מלאה, מומלץ להביא מוצרים בסיסיים: חטיפים, שוקולדים, עוגיות, ושימורים. המזוודה מישראל לדובאי נותנת 30 ק"ג בדרך כלל.' },
  { title: 'בדקו הכשרים על מוצרים', desc: 'הרבה מוצרים בסופרמרקטים נושאים הכשר OU, OK, או הכשר אירופאי. בדקו על האריזה — תופתעו לגלות כמה מוצרים כשרים יש.' },
  { title: 'מלונות עם מטבחון', desc: 'שקלו להזמין דירת מלון (serviced apartment) עם מטבחון. כך תוכלו להכין ארוחות בעצמכם ממוצרים כשרים שקניתם.' },
  { title: 'דגים ופירות ים', desc: 'דגים הם אופציה מצוינת בדובאי. מסעדות דגים רבות (גם לא כשרות) מגישות דגים שמותרים על פי ההלכה — סלמון, לברק, דניס ועוד.' },
  { title: 'צרו קשר עם הקהילה', desc: 'הקהילה היהודית בדובאי שמחה לעזור. דרך בית הכנסת או קבוצות וואטסאפ אפשר לקבל מידע עדכני על אפשרויות כשרות, סעודות שבת ואירועים.' },
  { title: 'אוכל צמחוני/טבעוני', desc: 'מסעדות צמחוניות וטבעוניות הן אופציה מצוינת לשומרי כשרות. יש שפע של מסעדות הודיות, תאילנדיות ויפניות עם אפשרויות טבעוניות.' },
]

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'כשר בדובאי - מסעדות כשרות ומידע',
  description: 'מדריך מלא לאוכל כשר בדובאי. מסעדות כשרות, סופרמרקטים עם מוצרים כשרים, שמירת שבת, וטיפים לשומרי כשרות.',
  author: { '@type': 'Organization', name: 'Yalla Dubai' },
  publisher: { '@type': 'Organization', name: 'Yalla Dubai', url: 'https://yalla-dubai.co.il' },
  mainEntityOfPage: 'https://yalla-dubai.co.il/kosher',
  inLanguage: 'he',
  datePublished: '2025-01-01',
  dateModified: '2026-03-01',
}
---

<Layout
  title="כשר בדובאי - מסעדות כשרות ומידע"
  description="מדריך מלא לאוכל כשר בדובאי. מסעדות כשרות, סופרמרקטים עם מוצרים כשרים, שמירת שבת, טיפים לשומרי כשרות, ואפשרויות אוכל חלאל."
  canonical="https://yalla-dubai.co.il/kosher"
>
  <SchemaOrg schema={articleSchema} />

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-amber-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">כשר <span class="text-amber-400">בדובאי</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">כל מה שצריך לדעת על אוכל כשר בדובאי: מסעדות, סופרמרקטים, שמירת שבת ועוד. דובאי הפכה ליעד ידידותי ליהודים ושומרי כשרות.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/20 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-amber-400 mb-4">כשרות בדובאי — המצב בשטח</h2>
      <p class="text-white/70 leading-relaxed mb-4">מאז הסכמי אברהם ב-2020, דובאי הפכה ליעד פופולרי לתיירים ישראלים ויהודים מכל העולם. התשתית הכשרה גדלה משמעותית — יש כיום מסעדות כשרות, סופרמרקטים עם מוצרים כשרים, ואפילו קהילה יהודית פעילה.</p>
      <p class="text-white/70 leading-relaxed mb-4">חשוב לדעת: רוב המזון בדובאי הוא חלאל, מה שאומר שחלק ניכר מהבשר מותר לאכילה מבחינת השחיטה (תלוי ברמת ההקפדה שלכם). מוצרים חלביים, דגים, ירקות ופירות — כמובן מותרים בכל מקום.</p>
      <p class="text-white/50 text-sm">מומלץ להתייעץ עם רב לגבי רמת הכשרות הנדרשת לכם. ההמלצות כאן מיועדות כמידע כללי.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">מסעדות <span class="text-amber-400">כשרות</span></h2>
    <p class="text-white/60 text-center mb-10 max-w-2xl mx-auto">מבחר מסעדות כשרות בדובאי — מאוכל ישראלי ועד סטייקים יוקרתיים</p>
    <div class="grid md:grid-cols-2 gap-6">
      {kosherRestaurants.map((r) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 rounded-2xl p-6 hover:border-amber-500/30 transition-all">
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-xl font-bold text-white">{r.name}</h3>
            <span class="text-xs font-medium px-3 py-1 rounded-full bg-amber-500/20 text-amber-400 border border-amber-500/30">{r.type}</span>
          </div>
          <div class="flex items-center gap-4 text-sm text-white/50 mb-3">
            <span class="flex items-center gap-1">📍 {r.area}</span>
            <span>{r.cuisine}</span>
            <span>{r.priceRange}</span>
          </div>
          <p class="text-white/70 text-sm leading-relaxed mb-3">{r.description}</p>
          <div class="flex items-center gap-1.5 text-amber-400 text-sm">
            <svg class="w-4 h-4 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span>{r.highlight}</span>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/restaurants" class="inline-flex items-center gap-2 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-[#0D0D0D] px-8 py-3 rounded-xl font-bold transition-all">🍽️ כל המסעדות בדובאי</a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">סופרמרקטים <span class="text-amber-400">עם מוצרים כשרים</span></h2>
    <p class="text-white/60 text-center mb-10">איפה למצוא מוצרים כשרים בדובאי</p>
    <div class="space-y-4">
      {supermarkets.map((m) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🛒</span>
            <h3 class="text-xl font-bold text-white">{m.name}</h3>
          </div>
          <p class="text-white/70 text-sm leading-relaxed mb-2">{m.description}</p>
          <p class="text-amber-400/70 text-sm flex items-center gap-1.5">📍 {m.locations}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">שמירת שבת <span class="text-amber-400">בדובאי</span></h2>
    <p class="text-white/60 text-center mb-10">מידע לשומרי שבת — תפילות, סעודות ולוגיסטיקה</p>
    <div class="grid md:grid-cols-2 gap-4">
      {shabbatInfo.map((info) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 rounded-2xl p-6">
          <h3 class="text-lg font-bold text-amber-400 mb-3">{info.title}</h3>
          <p class="text-white/70 text-sm leading-relaxed">{info.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-8 text-center">טיפים <span class="text-amber-400">לשומרי כשרות</span></h2>
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 rounded-2xl p-6 md:p-8">
      <ul class="space-y-4">
        {kosherTips.map((tip) => (
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <div>
              <p class="text-white font-bold mb-1">{tip.title}</p>
              <p class="text-white/60 text-sm">{tip.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-gradient-to-b from-[#0D0D0D] to-[#1A1208] py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-6">צריכים עזרה <span class="text-amber-400">עם כשרות בדובאי?</span></h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto">צרו איתנו קשר בווטסאפ ונעזור לכם למצוא אפשרויות כשרות מתאימות</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מחפש מידע על כשרות בדובאי')}`} target="_blank" rel="noopener noreferrer" dir="rtl" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all">📱 שלחו הודעה בווטסאפ</a>
        <a href="/restaurants" class="inline-flex items-center gap-2 bg-gradient-to-r from-amber-500 to-amber-600 text-[#0D0D0D] px-8 py-4 rounded-xl font-bold text-lg transition-all">🍽️ כל המסעדות</a>
      </div>
    </div>
  </section>
</Layout>
