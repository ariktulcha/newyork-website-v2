---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'
import { site, waUrl } from '../../../config/site'

const { data } = await supabaseAdmin.from('hotels').select('*').eq('destination_id', DESTINATION_ID).eq('published', true)
const LUXURY_BRANDS = ['Four Seasons', 'Mandarin', 'Waldorf', 'Raffles', 'One&Only', 'Kempinski', 'Park Hyatt', 'Bulgari', 'St. Regis', 'Ritz-Carlton', 'Plaza', 'Peninsula']
const items = (data || []).filter(h => h.star_rating >= 5 || LUXURY_BRANDS.some(b => (h.name_he || '').includes(b) || (h.name_en || '').includes(b)))

const pageTitle = `מלונות יוקרה ב${site.destinationName} | ${site.brand}`
const pageDescription = `מלונות יוקרה בניו יורק עם סוויטות מפוארות, ספא עולמיים ושירות אישי מעולה. Four Seasons, Mandarin Oriental, St. Regis, Peninsula, Bulgari וברירות יוקרתיות נוספות.`

const itemListSchema = { '@context': 'https://schema.org', '@type': 'ItemList', name: `מלונות יוקרה ב${site.destinationName}`, description: pageDescription, numberOfItems: items.length, itemListElement: items.map((item, index) => ({ '@type': 'ListItem', position: index + 1, name: item.name_he, url: new URL(`/hotels/${item.slug}`, `https://${site.domain}`).toString() })) }
const breadcrumbItems = [{ label: 'דף הבית', href: '/' }, { label: 'מלונות', href: '/hotels' }, { label: 'מלונות יוקרה' }]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />
    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/hotels/5-stars/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">5 כוכבים</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-amber-500 text-black whitespace-nowrap">יוקרה</span>
      <a href="/hotels/boutique/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">בוטיק</a>
      <a href="/hotels/manhattan/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">מנהטן</a>
      <a href="/hotels/brooklyn/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">ברוקלין</a>
    </nav>
    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות יוקרה ב{site.destinationName}</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">{site.destinationName} מגדירה מחדש את מושג היוקרה. The Plaza, St. Regis, Mandarin Oriental ועוד - סוויטות עם נוף לסנטרל פארק, ספא ברמה עולמית ושירות מושלם.</p>
    </header>
    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (<HotelCard name_he={item.name_he} name_en={item.name_en} slug={item.slug} image={item.image} area={item.area} star_rating={item.star_rating} price_range={item.price_range} />))}
      </div>
    ) : (<div class="text-center py-16"><p class="text-white/40 text-lg">לא נמצאו מלונות יוקרה כרגע. חזרו בקרוב!</p></div>)}

    <section class="mt-16 bg-[#1A1208] border border-amber-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-amber-400 mb-6">שאלות נפוצות - מלונות יוקרה ב{site.destinationName}</h2>
      <div class="space-y-4">
        <details class="group border-b border-amber-500/10 pb-4"><summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה מלון היוקרה הכי טוב ב{site.destinationName}?</summary><p class="mt-2 text-white/60 leading-relaxed">The Plaza, St. Regis, Mandarin Oriental Central Park, ו-Ritz-Carlton הם מלונות היוקרה המובילים ב{site.destinationName}. כל אחד מציע חוויה שונה - The Plaza הוא קלאסי, Mandarin Oriental מודרני עם נוף מהמם.</p></details>
        <details class="group border-b border-amber-500/10 pb-4"><summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">כמה עולה לילה במלון יוקרה ב{site.destinationName}?</summary><p class="mt-2 text-white/60 leading-relaxed">מלון יוקרה ב{site.destinationName} עולה מ-$500 ללילה ויכול להגיע ל-$3,000+ לסוויטה. בעונת שיא (דצמבר, סתיו) המחירים גבוהים יותר. הזמנה מוקדמת חוסכת משמעותית.</p></details>
        <details class="group border-b border-amber-500/10 pb-4"><summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה כולל מלון יוקרה ב{site.destinationName}?</summary><p class="mt-2 text-white/60 leading-relaxed">מלון יוקרה ב{site.destinationName} כולל: ספא, מסעדות שף, חדר כושר, קונסיירז' 24/7, שירות חדרים, וויוז פנורמיים למנהטן. חלק מהמלונות מציעים גם ליימוזינה ושירותי באטלר.</p></details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים עזרה בבחירת מלון יוקרה ב{site.destinationName}?</p>
      <a href={waUrl(`היי, אנחנו מחפשים מלון יוקרה ב${site.destinationName}`)} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors">דברו איתנו בווטסאפ</a>
    </div>
  </main>
</Layout>
