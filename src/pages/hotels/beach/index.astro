---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('hotels')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

// Beach hotels = JBR, Jumeirah, Palm, or "beach" in name/area
const BEACH_KEYWORDS = ["ביץ'", 'beach', 'חוף', 'פאלם', 'palm', 'ג׳ומיירה', 'jumeirah', 'jbr', 'ים', 'מרינה', 'marina']
const items = (data || []).filter(h =>
  BEACH_KEYWORDS.some(kw =>
    (h.name_he || '').toLowerCase().includes(kw.toLowerCase()) ||
    (h.name_en || '').toLowerCase().includes(kw.toLowerCase()) ||
    (h.area || '').toLowerCase().includes(kw.toLowerCase())
  )
)

const pageTitle = 'מלונות חוף בדובאי | Yalla Dubai'
const pageDescription = 'מלונות חוף מובילים בדובאי עם גישה ישירה לים. חופים פרטיים, בריכות אינסוף ונוף מדהים לים הערבי.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מלונות חוף בדובאי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/hotels/${item.slug}`, 'https://yalla-dubai.co.il').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מלונות', href: '/hotels' },
  { label: 'מלונות חוף' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <!-- Category pills -->
    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/hotels/5-stars/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">⭐ 5 כוכבים</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-amber-500 text-black whitespace-nowrap">🏖️ חוף</span>
      <a href="/hotels/family/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">👨‍👩‍👧 משפחתי</a>
      <a href="/hotels/luxury/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">💎 יוקרה</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות חוף בדובאי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        דובאי מציעה מלונות חוף מהיפים בעולם, עם חופים פרטיים, מים צלולים
        ונוף מרהיב לים הערבי. הנה המלונות המומלצים שלנו על קו החוף.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <HotelCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            star_rating={item.star_rating}
            price_range={item.price_range}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מלונות חוף כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-amber-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-amber-400 mb-6">שאלות נפוצות — מלונות חוף בדובאי</h2>
      <div class="space-y-4">
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">באילו אזורים בדובאי יש מלונות חוף?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בדובאי נמצאים בעיקר בפאלם ג'ומיירה, JBR, חוף ג'ומיירה, מרינה דובאי. כל אזורי המלונות חוף בדובאי הללו הם פופולריים מאד.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">האם כל מלונות חוף בדובאי כוללים חוף פרטי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רוב מלונות חוף 5 כוכבים בדובאי כוללים חוף פרטי. מלונות חוף בדובאי בדרגה נמוכה יותר קרובים לחופים ציבוריים.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה העונה האידאלית למלון חוף בדובאי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בדובאי נעימים ביותר בנובמבר-אפריל כשהמזג אוויר אידאלי. בקיץ מלונות חוף בדובאי זולים יותר אבל חם עז.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה המחירים למלון חוף בדובאי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון חוף בדובאי עולה בין 300-3,000 דירהם בעונה רגילה. מלונות חוף בדובאי יקרים יותר בחורף וחזקה בקיץ.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">איזה בריכות יש במלונות חוף בדובאי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בדובאי בדרך כלל כוללים בריכות אינסוף, בריכות שחייה מחוממות. מלון חוף בדובאי עשוי להיות בבריכה או בים.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה משקקות מוצעות במלונות חוף בדובאי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בדובאי מציעים: ספא, מסעדות, ברים על הים. כל מלון חוף בדובאי חייב להציע נוחות היוקרה.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">צריך להזמין מלון חוף בדובאי מראש?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, מומלץ להזמין מלון חוף בדובאי מראש בעיקר בחורף. מלונות חוף בדובאי פופולריים מתמלאים במהירות.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה המזג אוויר בדובאי לחוף?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בדובאי אידאליים בחורף (20-25 מעלות). בקיץ בדובאי (40+ מעלות), מלונות חוף בדובאי עדיין יפים אבל חמים מאד.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">איזה מלונות חוף בדובאי הטובים ביותר?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף מובילים בדובאי כוללים את אטלנטיס, פאלם ג'ומיירה, פור סיזנס. מלונות חוף בדובאי אלה מיוחדים בחוף פרטי.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה פעילויות מימיות בחופי מלונות בדובאי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בדובאי מציעים: גלישה, צלילה, ג'ט סקי, קנו וסקי מימי. כל מלון חוף בדובאי מציע מערכות פעילויות מימיות שונות.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים עזרה בבחירת מלון חוף בדובאי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מחפש מלון חוף בדובאי 🏖️')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
