---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'
import { site, waUrl } from '../../../config/site'

const { data } = await supabaseAdmin
  .from('hotels')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(h => {
  const meta = h.metadata || {}
  return h.star_rating === 5 || meta.star_rating === 5 || meta.stars === 5
})

const pageTitle = `מלונות 5 כוכבים ב${site.destinationName} | ${site.brand}`
const pageDescription = `מלונות 5 כוכבים בניו יורק עם שירות פאר, וספא עולמיים וחדרים יוקרתיים. The Plaza, Ritz-Carlton, Mandarin Oriental ובחירות נוספות עבור חוויה בלתי נשכחת.`

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `מלונות 5 כוכבים ב${site.destinationName}`,
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/hotels/${item.slug}`, `https://${site.domain}`).toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מלונות', href: '/hotels' },
  { label: '5 כוכבים' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-amber-500 text-black whitespace-nowrap">5 כוכבים</span>
      <a href="/hotels/luxury/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">יוקרה</a>
      <a href="/hotels/boutique/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">בוטיק</a>
      <a href="/hotels/manhattan/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">מנהטן</a>
      <a href="/hotels/brooklyn/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">ברוקלין</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות 5 כוכבים ב{site.destinationName}</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        {site.destinationName} מציעה מלונות 5 כוכבים מהטובים בעולם. The Plaza, Ritz-Carlton, St. Regis, Mandarin Oriental ועוד - חוויית אירוח ברמה הגבוהה ביותר.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <HotelCard name_he={item.name_he} name_en={item.name_en} slug={item.slug} image={item.image} area={item.area} star_rating={item.star_rating} price_range={item.price_range} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16"><p class="text-white/40 text-lg">לא נמצאו מלונות 5 כוכבים כרגע. חזרו בקרוב!</p></div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-amber-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-amber-400 mb-6">שאלות נפוצות - מלונות 5 כוכבים ב{site.destinationName}</h2>
      <div class="space-y-4">
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">כמה עולה לילה במלון 5 כוכבים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות 5 כוכבים ב{site.destinationName} מתחילים מ-$400 ללילה בעונה נמוכה ויכולים להגיע ל-$1,500+ לסוויטה בעונת השיא (דצמבר, קיץ). הזמנה מוקדמת חוסכת כסף משמעותי.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה האזור הכי טוב ב{site.destinationName} למלון 5 כוכבים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">Midtown (ליד סנטרל פארק) ו-Upper East Side הם האזורים הפופולריים ביותר למלונות 5 כוכבים ב{site.destinationName}. Tribeca ו-SoHo מציעים מלונות בוטיק יוקרתיים עם אווירה שכונתית.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה מלון 5 הכוכבים הכי טוב ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">The Plaza, St. Regis, Mandarin Oriental, Ritz-Carlton Central Park, ו-Four Seasons הם מהמלונות המובילים ב{site.destinationName}. כל אחד מציע חוויה שונה - בחרו לפי מיקום והעדפות.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">צריכים עזרה בבחירת מלון 5 כוכבים ב{site.destinationName}?</p>
      <a href={waUrl(`היי, אנחנו מחפשים מלון 5 כוכבים ב${site.destinationName}`)} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors">דברו איתנו בווטסאפ</a>
    </div>
  </main>
</Layout>
