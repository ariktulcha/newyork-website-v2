---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import FAQSection from '../components/FAQSection.astro'
import { site, waUrl } from '../config/site'

const faqItems = [
  {
    q: 'האם ישראלים צריכים ויזה לארצות הברית?',
    a: 'כן. ישראלים עדיין צריכים ויזה תיירית B1/B2 לארה"ב. הוצאת ויזה כוללת מילוי טופס DS-160 אונליין, תשלום אגרה של $185, וראיון בשגרירות האמריקאית בתל אביב. הויזה בדרך כלל ניתנת ל-10 שנים. מומלץ להתחיל את התהליך לפחות 3 חודשים לפני הטיסה. בדקו באתר השגרירות לעדכונים.',
  },
  {
    q: 'כמה ימים מומלץ לטיול בניו יורק?',
    a: 'המינימום המומלץ הוא 3-4 ימים כדי לראות את עיקרי האטרקציות. 5-7 ימים מאפשרים לכם להכיר את העיר לעומק - לצאת מעבר למנהטן, לחוות ברוקלין, לאכול בשכונות השונות ולהנות בלי ללחוץ. מעל שבוע תוכלו לחקור שכונות כמו Harlem, קווינס ואפילו לעשות יום ב-Woodbury Common.',
  },
  {
    q: 'איך עובד המטרו בניו יורק?',
    a: 'מערכת המטרו של ניו יורק פועלת 24/7. נסיעה בודדת עולה $2.90. כרטיס OMNY / MetroCard שבועי עולה $34 - שווה מאוד אם אתם 3+ ימים (ללא הגבלת נסיעות). ילדים עד 112 ס"מ רוכבים חינם. אפשר לשלם עם Apple Pay / כרטיס אשראי contactless. הקווים מסומנים באותיות ומספרים - השתמשו באפליקציית Google Maps לניווט.',
  },
  {
    q: 'האם ניו יורק בטוחה לתיירים ישראלים?',
    a: 'כן! ניו יורק היא אחת הערים הבטוחות ביותר בארה"ב. כמו בכל עיר גדולה - שמרו על ערנות, אל תשאירו דברי ערך ללא השגחה, והימנעו מרחובות חשוכים ושוממים בלילה. המטרו בטוח גם בלילה ברוב הקווים. יש נוכחות משטרתית ברוב האזורים התיירותיים.',
  },
  {
    q: 'כמה כסף צריך ליום בניו יורק?',
    a: 'בתקציב חסכוני: $100-150 ליום (אוכל רחוב, מעבורת חינם, פעילויות חינמיות). בתקציב בינוני: $200-300 ליום (מסעדות טובות, כניסה לאטרקציות, ברודווי). בתקציב גבוה: $400+ ליום (מסעדות יוקרה, מלונות מרכזיים, חוויות VIP). אוכל הוא ההוצאה הגדולה - אפשר לחסוך הרבה עם אוכל רחוב מעולה.',
  },
  {
    q: 'מה השכונות הכי טובות למלון בניו יורק?',
    a: 'Midtown - הכי נוח, ליד הכל, אבל יקר ורועש. Upper West Side - שכונתי ונעים, ליד סנטרל פארק. Lower East Side / East Village - צעיר, מגניב, מסעדות. Brooklyn (Williamsburg/DUMBO) - היפסטרי ומגניב, מחירים טובים יותר. הימנעו מ-Times Square - תיירותי מדי ויקר.',
  },
  {
    q: 'מה העונה הכי טובה לטיול בניו יורק?',
    a: 'כל עונה טובה! אביב (אפריל-מאי) וסתיו (ספטמבר-נובמבר) הם האידיאליים - מזג אוויר נעים ופחות עמוס. קיץ (יוני-אוגוסט) חם ולח אבל יש אירועים ופסטיבלים. חורף (דצמבר-פברואר) קר אבל קסום - שלג בסנטרל פארק, חנוכיות ברוקפלר, והנחות בחנויות.',
  },
  {
    q: 'איך מזמינים כרטיסים לברודווי בניו יורק?',
    a: 'הדרך הזולה ביותר: עמדות TKTS בטיימס סקוור (הנחות של 20-50% על הצגות של אותו היום). אפליקציות: TodayTix ו-Lottery של הצגות ספציפיות. מראש: Telecharge ו-Ticketmaster. מחירי כרטיסים נעים בין $50-250. הצגות פופולריות כמו Hamilton ו-Wicked מתמלאות מהר - הזמינו מראש.',
  },
  {
    q: 'איפה אוכלים אוכל כשר בניו יורק?',
    a: 'ניו יורק היא גן עדן לשומרי כשרות! יש מאות מסעדות כשרות בכל הסגנונות. אזורים מרכזיים: Upper West Side, Midtown, Brooklyn (Borough Park, Williamsburg). מ-Sushi ועד סטייק ופלאפל. אפליקציית Kosher GPS תעזור לכם למצוא הכל. גם רשתות כמו Dunkin\' ו-Starbucks מוכרות מוצרים עם הכשר.',
  },
  {
    q: 'כמה עולה טיפ (תשר) בניו יורק?',
    a: 'הטיפ הוא חלק בלתי נפרד מהתרבות. במסעדות: 18-20% מהחשבון (לפני מס). בברים: $1-2 למשקה או 15-20%. מוניות/Uber: 15-20%. מלונות: $2-5 לחדר ללילה. מדריכי סיורים: $10-20 לאדם. הטיפ לא אופציונלי - זהו חלק ממשכורת העובדים.',
  },
  {
    q: 'מה לארוז לטיול לניו יורק?',
    a: 'נעליים נוחות (תהלכו 15-20 אלף צעדים ביום!), שכבות ביגוד (מזגן חזק בפנים + חום בחוץ בקיץ), מטריה קטנה, מתאם חשמל (ישראלי לאמריקאי), וכרטיס אשראי בינלאומי. בחורף: מעיל חם, כפפות וכובע צמר.',
  },
  {
    q: 'האם כדאי לשכור רכב בניו יורק?',
    a: 'ממש לא! חנייה יקרה ($40-80 ליום), פקקים נוראיים, ואגרות כניסה למנהטן. המטרו, אובר והליכה ברגל הם הדרך הטובה ביותר להסתובב. שכרו רכב רק אם מתכננים יציאות מחוץ לעיר (Woodbury Common, Hamptons).',
  },
]

const topics = ['ויזה לארה"ב', 'כמה ימים', 'מטרו', 'בטיחות', 'תקציב', 'שכונות', 'עונות', 'ברודווי', 'כשרות', 'טיפים', 'אריזה', 'רכב']

const relatedPages = [
  { href: '/plan', title: 'תכנון טיול', desc: 'כלי תכנון חכם' },
  { href: '/attractions', title: 'אטרקציות', desc: `מה לעשות ב${site.destinationName}` },
  { href: '/tours', title: 'סיורים', desc: 'סיורים בעברית' },
  { href: '/restaurants', title: 'מסעדות', desc: 'איפה לאכול' },
  { href: '/hotels', title: 'מלונות', desc: 'היכן לישון' },
  { href: '/contact', title: 'צור קשר', desc: 'נשמח לעזור!' },
]
---

<Layout
  title={`שאלות ותשובות על טיול ל${site.destinationName} | ${site.brand}`}
  description={`כל השאלות והתשובות על טיול ל${site.destinationName}: ויזה לארה"ב, מטרו, בטיחות, תקציב, שכונות, ברודווי, כשרות, טיפים ועוד. המדריך המלא לתייר הישראלי.`}
  canonical={`https://${site.domain}/faq`}
>
  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-amber-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">שאלות <span class="text-amber-400">ותשובות</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">כל מה שרציתם לדעת על טיול ל{site.destinationName} - ויזה, מטרו, כסף, ברודווי, כשרות ועוד. {faqItems.length} שאלות עם תשובות מפורטות.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 -mt-6 relative z-20 mb-8">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/20 rounded-2xl p-4 md:p-6">
      <h2 class="text-white font-bold mb-3">נושאים מכוסים:</h2>
      <div class="flex flex-wrap gap-2">
        {topics.map((topic) => (
          <span class="text-xs bg-amber-500/10 text-amber-400 px-3 py-1 rounded-full border border-amber-500/20">{topic}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <FAQSection items={faqItems} />
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/20 rounded-2xl p-6 md:p-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">עדיין יש שאלות?</h2>
      <p class="text-white/60 mb-6 max-w-md mx-auto">לא מצאתם את התשובה? שלחו לנו הודעה בווטסאפ ונחזור אליכם תוך דקות</p>
      <a href={waUrl(`היי, יש לי שאלה על טיול ל${site.destinationName}`)} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all">שאלו אותנו בווטסאפ</a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">עמודים <span class="text-amber-400">שימושיים</span></h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {relatedPages.map((page) => (
        <a href={page.href} class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 hover:border-amber-500/30 rounded-xl p-4 text-center transition-all">
          <p class="text-white font-bold">{page.title}</p>
          <p class="text-white/50 text-sm">{page.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
