---
import Layout from '../../components/Layout.astro'
import SchemaOrg from '../../components/SchemaOrg.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import TourCard from '../../components/Cards/TourCard.astro'
import TourCalendar from '../../components/TourCalendar.astro'
import BookingForm from '../../components/BookingForm.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import { site, waUrl } from '../../config/site'
import { optimizedImageUrl } from '../../lib/image'

const { data: items } = await supabaseAdmin
  .from('tours')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('name_he')

const tours = items || []

const title = `סיורים בעברית ב${site.destinationName} | ${site.brand}`
const description = `סיורים בעברית ב${site.destinationName} עם מדריכים ישראלים מקומיים. סיורי הכרת העיר, קולינריה, אמנות ותרבות. הזמינו היום וחוו את ${site.destinationName} האמיתית.`
const canonicalUrl = `https://${site.domain}/tours`

const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `סיורים בעברית ב${site.destinationName}`,
  description,
  numberOfItems: tours.length,
  itemListElement: tours.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: t.name_he,
    url: `https://${site.domain}/tours/${t.slug}`,
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'דף הבית', item: `https://${site.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'סיורים' },
  ],
}

const faqItems = [
  {
    q: `כמה עולים סיורים בעברית ב${site.destinationName}?`,
    a: `הסיורים שלנו ב${site.destinationName} מתחילים מ-$59 לאדם. מבצע חבילה: 2 סיורים ביחד ב-$100 בלבד. המחירים כוללים מדריך ישראלי מקצועי.`,
  },
  {
    q: `כמה זמן ארוכים הסיורים ב${site.destinationName}?`,
    a: `רוב הסיורים שלנו ב${site.destinationName} נמשכים 3-4 שעות. הסיורים כוללים הליכה ברגל, עצירות צילום, טעימות, והסברים מעמיקים.`,
  },
  {
    q: `האם הסיורים ב${site.destinationName} מתנהלים בעברית?`,
    a: `כן! כל הסיורים שלנו ב${site.destinationName} מתנהלים בעברית מלאה עם מדריכים ישראלים שגרים ב${site.destinationName} ומכירים כל פינה.`,
  },
  {
    q: `צריך להזמין מראש סיור ב${site.destinationName}?`,
    a: `כן, מומלץ מאוד להזמין מראש לפחות 3-7 ימים. הקבוצות קטנות (עד 15 משתתפים) ונגמרות מהר. שלחו הודעה בוואטסאפ ונחזור תוך דקות.`,
  },
  {
    q: `מה קורה אם יורד גשם ביום הסיור ב${site.destinationName}?`,
    a: `הסיורים מתקיימים בכל מזג אוויר. במקרה של תנאי מזג אוויר קיצוניים נציע לכם תאריך חלופי או החזר מלא.`,
  },
]
---

<Layout title={title} description={description} canonical={canonicalUrl}>
  <SchemaOrg schema={[schemaItemList, breadcrumbSchema]} />

  <!-- Hero Section -->
  <section class="relative py-20 md:py-28 bg-gradient-to-b from-teal-500/10 to-transparent overflow-hidden">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.1) 1px, transparent 0); background-size: 24px 24px;"></div>
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-teal-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">סיורים</span>
      </nav>

      <!-- Social Proof Badge -->
      <div class="inline-flex items-center gap-2 bg-[#1A1208] border border-teal-500/20 rounded-full px-5 py-2 mb-6">
        <span class="w-2 h-2 bg-teal-400 rounded-full animate-pulse"></span>
        <span class="text-sm text-white/70 font-medium">סיורים יומיים עם מדריכים ישראלים מקומיים</span>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
        סיורים בעברית <span class="text-teal-400">ב{site.destinationName}</span>
      </h1>
      <p class="text-lg md:text-xl text-white/60 max-w-3xl mx-auto">
        הצטרפו אלינו לסיורים בעברית ב{site.destinationName} עם מדריכים ישראלים מנוסים.
        חוויות בלתי נשכחות בעיר הגדולה!
      </p>

      <!-- Social Proof Stats -->
      <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm text-white/50">
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <span>4.9 מתוך 5 כוכבים</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span>קבוצות קטנות עד 15</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
          <span>100% בעברית</span>
        </div>
      </div>

      <p class="mt-4 text-teal-400 font-medium">{tours.length} סיורים זמינים</p>
    </div>
  </section>

  <!-- Bundle Deal Banner -->
  {tours.length >= 2 && (
    <section class="bg-gradient-to-r from-teal-500 to-teal-600 py-6">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-8 text-[#0D0D0D]">
          <div class="flex items-center gap-3">
            <span class="text-3xl">🎁</span>
            <span class="text-2xl font-bold">מבצע חבילה!</span>
          </div>
          <div class="text-center md:text-right">
            <p class="text-lg">
              <span class="font-bold">2 סיורים ביחד</span> רק <span class="text-3xl font-bold">$100</span>
              <span class="mr-2 line-through opacity-70">$118</span>
            </p>
            <p class="text-sm flex items-center justify-center md:justify-start gap-2 mt-1">
              חוסכים $18
              <span class="mr-2">|</span>
              2 חוויות שונות לגמרי
            </p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Tours List - Alternating Layout -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    {tours.length > 0 ? (
      <div>
        {tours.map((tour: any, index: number) => {
          const tourPrice = tour.base_price ?? tour.price ?? tour.metadata?.price
          const tourDuration = tour.duration ?? tour.metadata?.duration
          const tourDurationMinutes = tour.duration_minutes ?? tour.metadata?.duration_minutes
          const tourGroupSize = tour.group_size ?? tour.metadata?.group_size ?? tour.group_size_max
          const tourSchedule = tour.schedule ?? tour.metadata?.schedule
          const tourCategory = tour.category ?? tour.metadata?.category
          return (
            <div class={`py-12 ${index > 0 ? 'border-t border-white/5' : ''}`}>
              <div class="grid md:grid-cols-2 gap-8 items-center">
                <!-- Image -->
                <div class={index % 2 === 1 ? 'md:order-2' : ''}>
                  <a href={`/tours/${tour.slug}`}>
                    <div class="relative aspect-video rounded-2xl overflow-hidden group">
                      {tour.image ? (
                        <img
                          src={optimizedImageUrl(tour.image, 600)}
                          alt={tour.name_he}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                          loading={index === 0 ? 'eager' : 'lazy'}
                          width="600"
                          height="338"
                        />
                      ) : (
                        <div class="w-full h-full bg-gradient-to-br from-teal-500/20 to-[#0D0D0D]"></div>
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0D]/60 to-transparent"></div>
                    </div>
                  </a>
                </div>

                <!-- Content -->
                <div class={index % 2 === 1 ? 'md:order-1' : ''}>
                  {tourCategory && (
                    <span class="text-teal-400 text-sm font-medium">{tourCategory}</span>
                  )}
                  <h2 class="text-3xl font-bold text-white mt-2 mb-4">
                    <a href={`/tours/${tour.slug}`} class="hover:text-teal-400 transition-colors">
                      {tour.name_he}
                    </a>
                  </h2>
                  <p class="text-white/60 mb-6 leading-relaxed">
                    {tour.description || tour.excerpt}
                  </p>

                  <!-- Meta Info -->
                  <div class="flex flex-wrap gap-4 mb-6 text-sm">
                    {(tourDuration || tourDurationMinutes) && (
                      <div class="flex items-center gap-2 text-white/50">
                        <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <span>{tourDuration || (tourDurationMinutes >= 60 ? `${Math.floor(tourDurationMinutes / 60)} שעות` : `${tourDurationMinutes} דקות`)}</span>
                      </div>
                    )}
                    {tourGroupSize && (
                      <div class="flex items-center gap-2 text-white/50">
                        <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span>עד {tourGroupSize} משתתפים</span>
                      </div>
                    )}
                    {tourSchedule?.notes && (
                      <div class="flex items-center gap-2 text-white/50">
                        <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        <span>{tourSchedule.notes}</span>
                      </div>
                    )}
                  </div>

                  <!-- Price & CTA -->
                  <div class="flex items-center gap-4">
                    {tourPrice && (
                      <span class="text-3xl font-bold text-teal-400">
                        ${typeof tourPrice === 'number' ? tourPrice : tourPrice}
                      </span>
                    )}
                    <a
                      href={`/tours/${tour.slug}`}
                      class="bg-teal-500 hover:bg-teal-600 text-[#0D0D0D] px-6 py-3 rounded-lg font-bold transition-colors"
                    >
                      פרטים והזמנה
                    </a>
                  </div>
                </div>
              </div>
            </div>
          )
        })}
      </div>
    ) : (
      <div>
        <p class="text-center text-white/40 py-12">לא נמצאו סיורים כרגע. חזרו בקרוב!</p>
      </div>
    )}
  </section>

  <!-- Calendar Section -->
  <section class="bg-gradient-to-br from-teal-900/20 to-teal-800/5 border-y border-teal-500/10 py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white text-center mb-8 flex items-center justify-center gap-3">
        <svg class="w-7 h-7 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        לוח הסיורים שלנו ב{site.destinationName}
      </h2>
      <TourCalendar tours={tours} />
    </div>
  </section>

  <!-- Booking Form Section -->
  <section id="booking-form" class="py-16">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white text-center mb-8">
        הירשמו לסיור ב{site.destinationName}
      </h2>
      <BookingForm tours={tours} />
    </div>
  </section>

  <!-- Why Us Section -->
  <section class="bg-gradient-to-br from-teal-900/10 to-transparent border-y border-teal-500/10 py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white text-center mb-12">
        למה לבחור בסיורים שלנו ב{site.destinationName}?
      </h2>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6 text-center hover:border-teal-500/30 transition-colors">
          <span class="text-4xl mb-4 block">🇮🇱</span>
          <h3 class="text-lg font-bold text-white mb-2">מדריכים ישראלים</h3>
          <p class="text-white/50 text-sm">מדריכים ישראלים שגרים ב{site.destinationName} ומכירים כל פינה ורחוב</p>
        </div>
        <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6 text-center hover:border-teal-500/30 transition-colors">
          <span class="text-4xl mb-4 block">👥</span>
          <h3 class="text-lg font-bold text-white mb-2">קבוצות קטנות</h3>
          <p class="text-white/50 text-sm">עד 15 משתתפים לחוויה אישית ואינטימית</p>
        </div>
        <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6 text-center hover:border-teal-500/30 transition-colors">
          <span class="text-4xl mb-4 block">⭐</span>
          <h3 class="text-lg font-bold text-white mb-2">דירוג גבוה</h3>
          <p class="text-white/50 text-sm">מעל 4.8 כוכבים ממאות משתתפים מרוצים</p>
        </div>
        <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6 text-center hover:border-teal-500/30 transition-colors">
          <span class="text-4xl mb-4 block">💯</span>
          <h3 class="text-lg font-bold text-white mb-2">שביעות רצון מלאה</h3>
          <p class="text-white/50 text-sm">לא נהניתם? נחזיר לכם את הכסף</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 max-w-4xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-white text-center mb-8">שאלות נפוצות על סיורים ב{site.destinationName}</h2>
    <FAQSection items={faqItems} />
  </section>

  <!-- Contact CTA -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">
        יש שאלות? רוצים סיור פרטי ב{site.destinationName}?
      </h2>
      <p class="text-white/50 mb-8">
        צרו איתנו קשר ונשמח לעזור לתכנן את החוויה המושלמת ב{site.destinationName}
      </p>
      <a
        href={waUrl(`היי, אנחנו רוצים לשמוע עוד על הסיורים שלכם ב${site.destinationName}`)}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white px-8 py-4 rounded-xl font-bold transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>דברו איתנו בוואטסאפ</span>
      </a>
    </div>
  </section>
</Layout>
