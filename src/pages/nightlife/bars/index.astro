---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import NightlifeCard from '../../../components/Cards/NightlifeCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'
import { site, waUrl } from '../../../config/site'

const { data } = await supabaseAdmin
  .from('nightlife')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .in('venue_type', ['bar', 'lounge'])

const items = data || []

const pageTitle = `ברים ב${site.destinationName} | ${site.brand}`
const pageDescription = `הברים הטובים ביותר ב${site.destinationName}. מברים אלגנטיים ועד ברים מזדמנים — המדריך המלא לחיי הלילה ב${site.destinationName}.`

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `ברים ב${site.destinationName}`,
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/nightlife/${item.slug}`, `https://${site.domain}`).toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'חיי לילה', href: '/nightlife' },
  { label: 'ברים' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/nightlife/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-amber-500 text-black whitespace-nowrap">ברים</span>
      <a href="/nightlife/clubs/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">מועדונים</a>
      <a href="/nightlife/manhattan/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">מנהטן</a>
      <a href="/nightlife/brooklyn/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">ברוקלין</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">ברים ב{site.destinationName}</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        {site.destinationName} מציעה סצנת ברים מגוונת ומרשימה — מברי speakeasy מוסתרים
        ועד ברי גגות עם נוף לקו הרקיע, ברי קוקטיילים יצירתיים ופאבים אותנטיים.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <NightlifeCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            type={item.type}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו ברים כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-amber-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-amber-400 mb-6">שאלות נפוצות — ברים ב{site.destinationName}</h2>
      <div class="space-y-4">
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה גיל הכניסה לברים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">גיל הכניסה לברים ב{site.destinationName} הוא 21 ומעלה. חובה להציג תעודה מזהה (דרכון לתיירים). כל הברים ב{site.destinationName} בודקים תעודה בכניסה — אין חריגים.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">כמה עולה שתייה בבר ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">בירה ב{site.destinationName} עולה בין $8-14, קוקטייל בין $16-25. יש Happy Hours בברים רבים ב{site.destinationName} עם הנחות של 30-50% בשעות אחר הצהריים, בדרך כלל בין 4-7 בערב.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה קוד הלבוש בברים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רוב הברים ב{site.destinationName} מקבלים לבוש קז'ואל. ברים יוקרתיים וברי מלונות דורשים Smart Casual. ברי speakeasy ורופטופ ב{site.destinationName} מעדיפים לבוש אלגנטי יותר.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה זה Happy Hour בברים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">Happy Hour הוא מבצע קבוע בברים ב{site.destinationName} — בדרך כלל בין 4-7 בערב עם הנחות של 30-50% על משקאות וחטיפים. ברים ב{site.destinationName} רבים מציעים גם $1 oysters ומנות קטנות במחירים מוזלים.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">איזה ברים ב{site.destinationName} טובים לחברים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים ב{site.destinationName} מצוינים לקבוצות חברים: The Dead Rabbit ב-FiDi, Please Don't Tell (PDT) ב-East Village, Employees Only ב-West Village. ברים ב{site.destinationName} עם אווירה חברתית מאפשרים להזמין שולחנות מראש.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה הברים הטובים ביותר ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים מובילים ב{site.destinationName}: The Dead Rabbit, Employees Only, Attaboy, Please Don't Tell (PDT), Dante. ברים אלה ב{site.destinationName} נמנים עם הטובים בעולם, עם קוקטיילים יצירתיים ואווירה ייחודית.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">האם צריך הזמנה לברים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים קז'ואליים ב{site.destinationName} לא דורשים הזמנה. ברי speakeasy ב{site.destinationName} כמו PDT דורשים הזמנה מראש. ברי גגות ומלונות מומלץ להזמין, במיוחד בסוף השבוע.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה ברי speakeasy ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברי speakeasy ב{site.destinationName} הם ברים מוסתרים בסגנון שנות ה-20 — ללא שלט בכניסה. PDT (נכנסים דרך תא טלפון), Attaboy, ו-Bathtub Gin הם מהמפורסמים. ברים ב{site.destinationName} אלה מציעים חוויית שתייה אינטימית וייחודית.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מתי ברים ב{site.destinationName} פתוחים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים ב{site.destinationName} בדרך כלל פתוחים מ-16:00 עד 4:00 בבוקר. ברי brunch פתוחים כבר מ-11:00 בצהריים. ברים ב{site.destinationName} פתוחים כל יום, כולל ימי חול וחגים.</p>
        </details>
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">מה טיפים לברים ב{site.destinationName}?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">טיפים לברים ב{site.destinationName}: תמיד השאירו טיפ של 18-20% (נורמה מחייבת בניו יורק), הביאו דרכון לזיהוי, הגיעו מוקדם בסוף שבוע כדי לקבל מקום. ב{site.destinationName} נהוג לשלם בכרטיס אשראי — רוב הברים לא מקבלים מזומן.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים המלצה לבר ב{site.destinationName}?</p>
      <a
        href={waUrl(`היי, אנחנו מחפשים בר מומלץ ב${site.destinationName}`)}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
