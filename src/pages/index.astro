---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import { supabaseAdmin, DESTINATION_ID } from '../lib/supabase'
import { site, waUrl } from '../config/site'

const { data: attractions } = await supabaseAdmin.from('attractions').select('name_he, slug, image, rating, price, excerpt').eq('destination_id', DESTINATION_ID).eq('published', true).limit(6)
const { data: tours } = await supabaseAdmin.from('tours').select('name, slug, image, base_price, rating, review_count, duration_minutes, short_description, includes').eq('destination_id', DESTINATION_ID).eq('published', true).limit(3)
const { data: hotels } = await supabaseAdmin.from('hotels').select('name_he, slug, image, rating, area').eq('destination_id', DESTINATION_ID).eq('published', true).limit(4)
const { data: areas } = await supabaseAdmin.from('areas').select('name_he, slug, image, excerpt').eq('destination_id', DESTINATION_ID).eq('published', true).limit(6)
const { data: restaurants } = await supabaseAdmin.from('restaurants').select('name_he, slug, image, area, cuisine_types, price_range').eq('destination_id', DESTINATION_ID).eq('published', true).limit(6)
const { data: guides } = await supabaseAdmin.from('guides').select('name_he, slug, image, excerpt').eq('destination_id', DESTINATION_ID).eq('published', true).limit(3)

const featuredAttractions = attractions ?? []
const featuredTours = tours ?? []
const featuredHotels = hotels ?? []
const featuredAreas = areas ?? []
const featuredRestaurants = restaurants ?? []
const featuredGuides = guides ?? []

const categories = [
  { label: 'סיורים', icon: '🎒', href: '/tours', desc: 'סיורים בעברית במנהטן וברוקלין' },
  { label: 'אטרקציות', icon: '🗽', href: '/attractions', desc: 'מרכז הכובד, סנטרל פארק ועוד' },
  { label: 'מלונות', icon: '🏨', href: '/hotels', desc: 'בוטיק, יוקרה ומשפחתי' },
  { label: 'מסעדות', icon: '🍽️', href: '/restaurants', desc: 'פיצה, בייגלים, סטייקים ועוד' },
  { label: 'חיי לילה', icon: '🌙', href: '/nightlife', desc: 'ברים, מועדונים ורופטופ' },
  { label: 'שכונות', icon: '🗺️', href: '/areas', desc: 'מנהטן, ברוקלין, קווינס ועוד' },
]

const testimonials = [
  {
    text: 'הסיור היה מדהים! המדריך ידע לספר על כל פינה במנהטן, גילינו מקומות שלא היינו מגיעים אליהם לבד. ממליצים בחום!',
    name: 'מיכל ואורי',
    city: 'תל אביב',
    tour: 'סיור מנהטן',
    date: 'ינואר 2026',
  },
  {
    text: 'סיור האוכל היה חוויה בלתי נשכחת. יצאנו שבעים ומאושרים. הבייגל ב-Russ & Daughters שינה לנו את החיים. תודה!',
    name: 'דנה כהן',
    city: 'רעננה',
    tour: 'סיור אוכל',
    date: 'דצמבר 2025',
  },
  {
    text: 'ברוקלין פשוט עולם אחר. הגרפיטי, האווירה, האנשים - המדריך הראה לנו את הברוקלין האמיתית. כבר רוצים לחזור!',
    name: 'יוסי לוי',
    city: 'ירושלים',
    tour: 'סיור ברוקלין',
    date: 'פברואר 2026',
  },
]

const homepageFAQ = [
  { q: 'כמה עולה סיור בעברית בניו יורק?', a: 'הסיורים שלנו מתחילים מ-$59 לאדם. סיור האוכל הוא $79 וכולל את כל הטעימות. יש גם מבצע חבילה של מנהטן + ברוקלין ב-$100 במקום $118.' },
  { q: 'איפה נפגשים לסיור בניו יורק?', a: 'לכל סיור יש נקודת מפגש מרכזית ונגישה בתחבורה ציבורית. סיור מנהטן - טיימס סקוור. סיור ברוקלין - תחנת York Street. סיור אוכל - Lower East Side.' },
  { q: 'מה קורה אם יורד גשם בניו יורק?', a: 'הסיור מתקיים בכל מזג אוויר. במקרה של סופה חזקה, ניצור קשר להציע מועד חלופי או החזר מלא.' },
  { q: 'מה מדיניות הביטולים?', a: 'ביטול עד 48 שעות לפני הסיור - החזר מלא. ביטול עד 24 שעות - החזר של 50%. פחות מ-24 שעות - ללא החזר.' },
  { q: 'האם הסיור בניו יורק מתאים לילדים?', a: 'בהחלט! הסיורים מתאימים לכל הגילאים. ילדים עד גיל 5 נכנסים חינם, ילדים מגיל 6 עד 12 מקבלים 50% הנחה.' },
  { q: 'אפשר להזמין סיור פרטי בניו יורק?', a: 'כן! אנחנו מציעים סיורים פרטיים לזוגות, משפחות וקבוצות. המחיר מותאם לגודל הקבוצה. צרו קשר לפרטים.' },
]

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.brand,
  url: `https://${site.domain}`,
  description: site.taglineHe,
  inLanguage: 'he',
}

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.brand,
  url: `https://${site.domain}`,
  description: site.taglineHe,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    availableLanguage: ['Hebrew', 'English'],
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homepageFAQ.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<Layout
  title={`${site.brandHe} - סיורים בעברית ב${site.destinationName} | המדריך המלא 2026`}
  description={`סיורים בעברית ב${site.destinationName} עם מדריכים ישראלים. אטרקציות, מלונות, מסעדות, ברודווי, שכונות ומדריכים מפורטים. להתאהב בעיר דרך עיניים מקומיות.`}
  canonical={`https://${site.domain}`}
>
  <SchemaOrg schema={[websiteSchema, organizationSchema, faqSchema]} />

  <!-- HERO -->
  <section class="relative min-h-[70vh] md:min-h-[85vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-[url('/images/heroes/hero-newyork.webp')] bg-cover bg-center"></div>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-[#0D0D0D]"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <!-- Social proof badge -->
      <div class="inline-flex items-center gap-2 bg-amber-500/15 border border-amber-500/30 rounded-full px-4 py-2 mb-6">
        <span class="text-amber-400 text-sm font-bold">למעלה מ-1,000 מטיילים טיילו איתנו</span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-5xl lg:text-6xl xl:text-7xl font-black text-white mb-4 leading-[1.1]">
        סיורים בעברית ב{site.destinationName}
      </h1>
      <p class="text-2xl md:text-3xl font-bold mb-8 leading-relaxed">
        <span class="text-amber-400">להתאהב בעיר דרך עיניים מקומיות</span>
      </p>

      <div class="flex flex-col items-center gap-4">
        <a
          href="/tours"
          class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-black px-10 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-amber-500/25"
        >
          בחרו סיור והצטרפו אלינו
        </a>
        <a
          href="/plan"
          class="text-amber-400 hover:text-amber-300 transition-colors text-sm font-medium"
        >
          או תכננו לבד עם המדריכים שלנו
        </a>
      </div>
    </div>
  </section>

  <!-- QUICK STATS -->
  <section class="border-y border-amber-500/10 bg-[#1A1208]/50 py-8">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-black text-amber-400">{featuredAttractions.length}+</div>
          <div class="text-white/50 text-sm mt-1">אטרקציות</div>
        </div>
        <div>
          <div class="text-3xl font-black text-amber-400">{featuredHotels.length}+</div>
          <div class="text-white/50 text-sm mt-1">מלונות מומלצים</div>
        </div>
        <div>
          <div class="text-3xl font-black text-amber-400">{featuredTours.length}</div>
          <div class="text-white/50 text-sm mt-1">סיורים בעברית</div>
        </div>
        <div>
          <div class="text-3xl font-black text-amber-400">{featuredAreas.length}+</div>
          <div class="text-white/50 text-sm mt-1">שכונות לגלות</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        מה <span class="text-amber-400">לעשות ב{site.destinationName}</span>
      </h2>
      <p class="text-white/40 max-w-2xl mx-auto">סיורים בעברית, אטרקציות, מסעדות, ברודווי, חיי לילה ועוד</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {categories.map((cat) => (
        <a href={cat.href} class="group relative p-6 rounded-2xl bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 transition-all duration-300 hover:-translate-y-1 text-center">
          <span class="text-4xl mb-3 block">{cat.icon}</span>
          <h3 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors mb-1">{cat.label}</h3>
          <p class="text-white/40 text-xs">{cat.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- TOURS -->
  {featuredTours.length > 0 && (
    <section class="py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-black text-white mb-2">
              סיורים <span class="text-amber-400">בעברית ב{site.destinationName}</span>
            </h2>
            <p class="text-white/40">סיורים מודרכים בעברית עם מדריכים ישראלים שגרים ב{site.destinationName}</p>
          </div>
          <a href="/tours" class="hidden md:inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold text-sm transition-colors">
            כל הסיורים
            <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTours.map((tour: any) => (
            <a href={`/tours/${tour.slug}`} class="group rounded-2xl overflow-hidden bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 transition-all duration-300 hover:-translate-y-1 flex flex-col">
              <div class="relative h-48 overflow-hidden">
                {tour.image ? (
                  <img src={tour.image} alt={tour.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-amber-900/20 via-[#1A1208] to-[#0D0D0D] flex items-center justify-center">
                    <span class="text-6xl opacity-30">🗽</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                {tour.base_price && (
                  <div class="absolute top-3 left-3 bg-amber-500 text-black px-3 py-1 rounded-lg text-sm font-bold">
                    ${tour.base_price}
                  </div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-1">
                <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors mb-2">{tour.name}</h3>
                <div class="flex items-center gap-3 text-sm text-white/50 mb-3">
                  {tour.rating && (
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5 text-amber-400 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      {tour.rating}
                    </span>
                  )}
                  {tour.duration_minutes && <span>{Math.round(tour.duration_minutes / 60)} שעות</span>}
                  {tour.review_count && <span>{tour.review_count} ביקורות</span>}
                </div>
                <p class="text-white/60 text-sm flex-1 line-clamp-2">{tour.short_description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- BUNDLE DEAL -->
  <section class="bg-gradient-to-r from-amber-500 to-amber-600 py-12">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-black mb-4">
        מנהטן + ברוקלין ביחד - $100 במקום <span class="line-through opacity-70">$118</span>
      </h2>
      <div class="flex flex-wrap justify-center gap-6 text-black/80 mb-8">
        <span class="flex items-center gap-1">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          חוסכים $18
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          2 חוויות שונות לגמרי
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          גמישות בתאריכים
        </span>
      </div>
      <a
        href="/tours"
        class="inline-flex items-center justify-center bg-black hover:bg-black/80 text-white px-8 py-4 rounded-xl font-bold text-lg transition-colors"
      >
        הזמינו חבילה משולבת
      </a>
    </div>
  </section>

  <!-- RESTAURANTS -->
  {featuredRestaurants.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-3xl md:text-4xl font-black text-white">
            מסעדות מומלצות <span class="text-amber-400">ב{site.destinationName}</span>
          </h2>
          <p class="text-white/50 mt-2">פיצה, בייגלים, סטייקים, מסעדות איטלקיות ועוד</p>
        </div>
        <a href="/restaurants/" class="hidden md:flex items-center gap-1 text-amber-400 hover:text-amber-300 font-medium text-sm transition-colors">
          כל המסעדות
          <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-8">
        {[
          { href: '/restaurants/italian/', label: 'איטלקי', count: 'פסטות ופיצות' },
          { href: '/restaurants/manhattan/', label: 'מנהטן', count: 'מרכז העיר' },
          { href: '/restaurants/brooklyn/', label: 'ברוקלין', count: 'שכונתי ומגניב' },
          { href: '/culinary-map', label: 'מפה קולינרית', count: 'כל המקומות' },
          { href: '/restaurants/', label: 'הכל', count: 'כל המסעדות' },
        ].map((cat) => (
          <a
            href={cat.href}
            class="group flex flex-col items-center gap-2 bg-white/5 border border-white/10 hover:border-amber-500/50 rounded-xl p-4 transition-all hover:-translate-y-0.5"
          >
            <span class="text-white font-semibold text-sm">{cat.label}</span>
            <span class="text-white/40 text-xs">{cat.count}</span>
          </a>
        ))}
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {featuredRestaurants.map((r: any) => (
          <a
            href={`/restaurants/${r.slug}/`}
            class="group relative rounded-xl overflow-hidden aspect-square bg-gradient-to-br from-amber-900/20 to-[#1A1208]"
          >
            {r.image && (
              <img
                src={r.image}
                alt={r.name_he}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 right-0 left-0 p-3">
              <p class="text-white font-bold text-xs leading-tight">{r.name_he}</p>
              {r.area && <p class="text-amber-400 text-xs">{r.area}</p>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- AREAS -->
  {featuredAreas.length > 0 && (
    <section class="bg-[#1A1208]/30 py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-black text-white mb-2">
              שכונות <span class="text-amber-400">מובילות ב{site.destinationName}</span>
            </h2>
            <p class="text-white/40">כל שכונה ב{site.destinationName} היא עולם בפני עצמו - גלו מה מתאים לכם</p>
          </div>
          <a href="/areas" class="hidden md:inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold text-sm transition-colors">
            כל השכונות
            <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredAreas.map((area: any) => (
            <a href={`/areas/${area.slug}`} class="group relative rounded-2xl overflow-hidden h-52 flex items-end">
              {area.image ? (
                <img src={area.image} alt={area.name_he} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class="absolute inset-0 bg-gradient-to-br from-amber-900/30 to-[#0D0D0D]"></div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
              <div class="relative p-5 w-full">
                <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">{area.name_he}</h3>
                {area.excerpt && <p class="text-white/60 text-sm mt-1 line-clamp-1">{area.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- TESTIMONIALS -->
  <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-4">
        מה אומרים <span class="text-amber-400">המשתתפים</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      {testimonials.map((t) => (
        <div class="bg-[#1A1208] rounded-2xl p-6 border border-amber-500/10">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <p class="text-white/70 mb-4 leading-relaxed">&ldquo;{t.text}&rdquo;</p>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-white font-bold">{t.name}</p>
              <p class="text-white/30 text-sm">{t.city}</p>
            </div>
            <div class="text-left">
              <p class="text-amber-400 text-sm font-medium">{t.tour}</p>
              <p class="text-white/20 text-xs">{t.date}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center">
      <div class="inline-flex flex-wrap justify-center gap-y-1 items-center gap-3 bg-[#1A1208]/50 rounded-2xl sm:rounded-full px-4 sm:px-6 py-3 text-sm">
        <span class="flex items-center gap-1 text-amber-400 font-bold">
          <svg class="w-4 h-4 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          4.9 ממוצע
        </span>
        <span class="text-white/30 hidden sm:inline">|</span>
        <span class="text-white/60">200+ משתתפים מרוצים</span>
        <span class="text-white/30 hidden sm:inline">|</span>
        <span class="text-white/60">אחריות שביעות רצון מלאה</span>
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="bg-[#1A1208]/30 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-4">
          למה <span class="text-amber-400">עם מדריך?</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-[#1A1208] rounded-2xl p-5 md:p-8 border border-amber-500/10">
          <h3 class="text-xl font-bold text-white mb-2">מדריכים ישראלים שגרים ב{site.destinationName}</h3>
          <p class="text-white/60">ישראלים שגרים פה, אוכלים פה, וחיים פה. לא סתם קראנו על זה - אנחנו חיים את זה כל יום.</p>
        </div>
        <div class="bg-[#1A1208] rounded-2xl p-5 md:p-8 border border-amber-500/10">
          <h3 class="text-xl font-bold text-white mb-2">קבוצות קטנות עד 15</h3>
          <p class="text-white/60">לא אוטובוס תיירים. קבוצה אינטימית שבה המדריך מכיר כל אחד, עוצר לשאלות, ומתאים את הקצב אליכם.</p>
        </div>
        <div class="bg-[#1A1208] rounded-2xl p-5 md:p-8 border border-amber-500/10">
          <h3 class="text-xl font-bold text-white mb-2">מעבר למה שכתוב במדריכים</h3>
          <p class="text-white/60">סיפורים, פינות נסתרות, המלצות אישיות שלא תמצאו באף אתר. החלקים הכי טובים של {site.destinationName} הם אלה שמקומיים מגלים לכם.</p>
        </div>
        <div class="bg-[#1A1208] rounded-2xl p-5 md:p-8 border border-amber-500/10">
          <h3 class="text-xl font-bold text-white mb-2">אחריות שביעות רצון מלאה</h3>
          <p class="text-white/60">לא נהניתם? נחזיר לכם את הכסף. בלי שאלות, בלי סיפורים. אנחנו כל כך בטוחים שתאהבו.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-4">
        שאלות <span class="text-amber-400">נפוצות</span>
      </h2>
    </div>
    <div class="space-y-4">
      {homepageFAQ.map((faq) => (
        <details class="group border-b border-amber-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-amber-400 transition-colors">{faq.q}</summary>
          <p class="mt-2 text-white/60 leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="max-w-4xl mx-auto px-4 py-12 md:py-20 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-4">
      סיורים יומיים בשעה 10:00. <span class="text-amber-400">מקומות מוגבלים.</span>
    </h2>
    <p class="text-xl text-white/60 mb-8">
      הצטרפו למאות ישראלים שכבר גילו את {site.destinationName} האמיתית איתנו.
    </p>
    <div class="flex justify-center mb-8">
      <a
        href="/tours"
        class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-black px-10 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-amber-500/25"
      >
        בחרו סיור והזמינו
      </a>
    </div>
    <div class="flex flex-wrap justify-center gap-6 text-white/50 text-sm">
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
        ביטול חינם עד 48 שעות
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
        אחריות שביעות רצון
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
        תשלום מאובטח
      </span>
    </div>
  </section>
</Layout>
