---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import { supabaseAdmin, DESTINATION_ID } from '../lib/supabase'

const { data: attractions } = await supabaseAdmin.from('attractions').select('name_he, slug, image, rating, price').eq('destination_id', DESTINATION_ID).eq('published', true).limit(4)
const { data: tours } = await supabaseAdmin.from('tours').select('name, slug, image, base_price, rating, review_count, duration_minutes, short_description, includes').eq('destination_id', DESTINATION_ID).eq('published', true)

const featuredAttractions = attractions ?? []
const featuredTours = tours ?? []

const categories = [
  { label: 'טיולים וסיורים', icon: '🌴', href: '/tours', count: `${featuredTours.length} חבילות` },
  { label: 'אטרקציות', icon: '🏛️', href: '/attractions', count: `${featuredAttractions.length}+ אטרקציות` },
  { label: 'מלונות', icon: '🏨', href: '/hotels', count: 'מלונות מובילים' },
  { label: 'מסעדות', icon: '🍽️', href: '/restaurants', count: 'מסעדות מומלצות' },
  { label: 'חיי לילה', icon: '🌙', href: '/nightlife', count: 'מקומות לילה' },
  { label: 'חופים', icon: '🏖️', href: '/beaches', count: 'חופים יפים' },
]

const testimonials = [
  {
    text: 'הגענו לבאלי ל-10 ימים עם כל המשפחה — 3 ילדים כולל תינוק. הויזה הוגשה מראש דרכם ועברה חלק. המסלול שקיבלנו היה מדויק לגיל הילדים, וקאנגו הייתה חוויה שהילדים לא יפסיקו לדבר עליה.',
    name: 'תמר ואביב פרידמן',
    city: 'כפר סבא',
    tour: 'טיול משפחתי 10 ימים',
    date: 'פברואר 2026',
  },
  {
    text: 'הגענו לבאלי ל-7 ימים ולא ידענו מאיפה להתחיל. פנינו לוואטסאפ, קיבלנו מסלול מותאם תוך שעה. הסיור לנוסה פניידה שהמליצו עליו היה הייט-לייט של הטיול.',
    name: 'נדב כ.',
    city: 'חיפה',
    tour: 'תכנון טיול 7 ימים',
    date: 'ינואר 2026',
  },
  {
    text: 'הוויזה הגיעה ב-24 שעות, המדריך באובוד היה פנומנלי, והריטריט היוגה שמצאנו דרכם שינה לנו את החיים. יאללה באלי = שירות ברמה שלא מצאתי בשום מקום.',
    name: 'רותם ש.',
    city: 'תל אביב',
    tour: 'ויזה + ריטריט אובוד',
    date: 'מרץ 2026',
  },
]

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Yalla Bali - יאללה באלי',
  url: 'https://yalla-bali.co.il',
  description: 'המדריך המלא לבאלי בעברית — ויזה, אטרקציות, מלונות ומסעדות',
  inLanguage: 'he',
}

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Yalla Bali',
  url: 'https://yalla-bali.co.il',
  description: 'המדריך הישראלי לבאלי',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    availableLanguage: ['Hebrew', 'English'],
  },
}
---

<Layout
  title="יאללה באלי — המדריך המלא לבאלי בעברית 2026"
  description="המדריך הישראלי לבאלי. ויזה לבאלי, חופי קאנגו, מקדשים באובוד, מלוני יוקרה וחיי לילה. הכל בעברית, עם מחירים וטיפים מקומיים."
  canonical="https://yalla-bali.co.il"
  heroImage="/images/heroes/hero-bali.webp"
>
  <SchemaOrg schema={[websiteSchema, organizationSchema]} />

  <!-- HERO -->
  <section class="relative min-h-[75vh] md:min-h-[85vh] flex items-center justify-center overflow-hidden">
    <!-- Background photo -->
    <picture>
      <source srcset="/images/heroes/hero-bali.webp" type="image/webp" />
      <img
        src="/images/heroes/hero-bali.webp"
        alt="באלי — שדות אורז ירוקים ומקדשים עתיקים"
        class="absolute inset-0 w-full h-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1080"
      />
    </picture>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-[#0D0D0D]"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, rgba(13,148,136,0.3) 1px, transparent 1px); background-size: 20px 20px;"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white mb-6 leading-[1.1]">
        גלה את באלי
      </h1>

      <p class="text-xl md:text-2xl text-teal-400 font-bold mb-6">
        ג׳ונגל, חופים, מקדשים וויזה — הכל בעברית
      </p>

      <p class="text-lg text-white/60 mb-10 max-w-2xl mx-auto">
        המדריך הישראלי המלא לבאלי. ויזה מהירה, מסלולים מומלצים, מלונות וחוויות — כל מה שצריך לטיול מושלם
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/visa" class="inline-flex flex-col items-center justify-center gap-1 bg-gradient-to-r from-teal-500 to-teal-600 hover:from-teal-400 hover:to-teal-500 text-white px-10 py-4 rounded-xl font-bold transition-all shadow-lg shadow-teal-500/25">
          <span class="text-sm font-normal opacity-80">ישראלים חייבים ויזה לבאלי — מגישים עבורכם</span>
          <span class="text-lg font-black">הגישו ויזה עכשיו — 185 ₪</span>
        </a>
        <a href="/plan" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-xl font-bold transition-all border border-white/20">
          <span>🗓️</span>
          <span>תכנן את הטיול</span>
        </a>
      </div>
    </div>
  </section>

  <!-- VISA CTA BANNER -->
  <section class="bg-teal-900/40 border-y border-teal-500/30 py-6">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-white font-bold text-lg">
        🛂 <span class="text-teal-400">ויזה לבאלי לישראלים</span> — הגשה מהירה, אישור ב-24 שעות, 185 ₪ בלבד.
        <a href="/visa" class="underline text-teal-300 hover:text-teal-200 mr-2">לפרטים ←</a>
      </p>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        מה <span class="text-teal-400">לעשות בבאלי</span>
      </h2>
      <p class="text-white/40 max-w-2xl mx-auto">גלו את כל מה שהאי הקסום הזה יכול להציע</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {categories.map((cat) => (
        <a href={cat.href} class="group relative p-6 rounded-2xl bg-[#0A1A18] border border-teal-500/10 hover:border-teal-500/30 transition-all duration-300 card-lift text-center">
          <span class="text-4xl mb-3 block">{cat.icon}</span>
          <h3 class="text-lg font-bold text-white group-hover:text-teal-400 transition-colors mb-1">{cat.label}</h3>
          <p class="text-white/40 text-xs">{cat.count}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- TOURS -->
  {featuredTours.length > 0 && (
    <section class="bg-gradient-to-b from-[#0D0D0D] to-[#0A1A18] py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
            חבילות <span class="text-teal-400">טיולים בבאלי</span>
          </h2>
          <p class="text-white/40 max-w-2xl mx-auto">גלישה, ג׳ונגל, מקדשים ועוד — בחרו את החוויה שלכם</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTours.map((tour: any) => (
            <div class="rounded-2xl overflow-hidden bg-[#0A1A18] border border-teal-500/10 hover:border-teal-500/30 transition-all duration-300 card-lift flex flex-col">
              <div class="relative h-48 overflow-hidden">
                {tour.image ? (
                  <img src={tour.image} alt={tour.name} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-teal-900/40 via-[#0A1A18] to-[#0D0D0D] flex items-center justify-center">
                    <span class="text-6xl opacity-30">🌴</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              </div>

              <div class="p-6 flex flex-col flex-1">
                <h3 class="text-xl font-bold text-white mb-2">{tour.name}</h3>
                <div class="flex items-center gap-3 text-sm text-white/50 mb-3">
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 text-teal-400 fill-teal-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {tour.rating}
                  </span>
                  {tour.duration_minutes && <span>{Math.round(tour.duration_minutes / 60)} שעות</span>}
                  {tour.review_count && <span>{tour.review_count} ביקורות</span>}
                </div>
                <p class="text-white/60 text-sm mb-4 flex-1 line-clamp-2">{tour.short_description}</p>
                {tour.includes?.[0] && (
                  <p class="text-teal-400/70 text-xs mb-4 flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    {tour.includes[0]}
                  </p>
                )}
                <div class="flex items-center justify-between mt-auto">
                  <div>
                    <span class="text-white/40 text-xs">החל מ-</span>
                    <span class="text-teal-400 font-bold text-xl mr-1">₪{tour.base_price}</span>
                  </div>
                  <a href={`/tours/${tour.slug}`} class="bg-gradient-to-r from-teal-500 to-teal-600 text-white px-5 py-2.5 rounded-xl font-bold text-sm transition-all hover:shadow-lg hover:shadow-teal-500/25">
                    לפרטים
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- WHY US -->
  <section class="max-w-5xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        למה <span class="text-teal-400">יאללה באלי?</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="text-center p-8 rounded-2xl bg-[#0A1A18] border border-teal-500/10">
        <span class="text-4xl mb-4 block">🛂</span>
        <h3 class="text-xl font-bold text-white mb-2">ויזה מהירה ופשוטה</h3>
        <p class="text-white/50 text-sm">מגישים עבורכם ויזה לבאלי — אישור ב-24 שעות, 185 ₪ בלבד</p>
      </div>
      <div class="text-center p-8 rounded-2xl bg-[#0A1A18] border border-teal-500/10">
        <span class="text-4xl mb-4 block">⭐</span>
        <h3 class="text-xl font-bold text-white mb-2">4.9 דירוג ממוצע</h3>
        <p class="text-white/50 text-sm">מ-500+ ישראלים שכבר טסו לבאלי</p>
      </div>
      <div class="text-center p-8 rounded-2xl bg-[#0A1A18] border border-teal-500/10">
        <span class="text-4xl mb-4 block">🗺️</span>
        <h3 class="text-xl font-bold text-white mb-2">מסלולים מקצועיים</h3>
        <p class="text-white/50 text-sm">מסלולים מותאמים לישראלים — לפי ימים, תקציב וסגנון</p>
      </div>
    </div>
  </section>

  <!-- FEATURED ATTRACTIONS -->
  {featuredAttractions.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
          אטרקציות <span class="text-teal-400">מובילות בבאלי</span>
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredAttractions.map((attraction: any) => (
          <a href={`/attractions/${attraction.slug}`} class="group rounded-2xl overflow-hidden bg-[#0A1A18] border border-teal-500/10 hover:border-teal-500/30 transition-all duration-300 card-lift">
            <div class="relative h-40 bg-gradient-to-br from-teal-900/30 via-[#0A1A18] to-[#0D0D0D] overflow-hidden">
              {attraction.image ? (
                <img src={attraction.image} alt={attraction.name_he} class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-5xl opacity-30">🌴</span>
                </div>
              )}
            </div>
            <div class="p-4">
              <h3 class="text-base font-bold text-white group-hover:text-teal-400 transition-colors mb-2">{attraction.name_he}</h3>
              <div class="flex items-center justify-between text-sm">
                {attraction.rating && (
                  <span class="flex items-center gap-1 text-teal-400">
                    <svg class="w-3.5 h-3.5 fill-teal-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {attraction.rating}
                  </span>
                )}
                <span class="text-white/40 text-xs">{attraction.price}</span>
              </div>
              <span class="text-teal-400/70 text-xs mt-2 block">קראו עוד &larr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- TESTIMONIALS -->
  <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        מה <span class="text-teal-400">אומרים עלינו</span>
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-[#0A1A18] rounded-2xl p-6 border border-teal-500/10">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-teal-400 fill-teal-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <p class="text-white/70 mb-4 leading-relaxed">&ldquo;{t.text}&rdquo;</p>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-white font-bold">{t.name}</p>
              <p class="text-white/30 text-sm">{t.city}</p>
            </div>
            <div class="text-left">
              <p class="text-teal-400 text-sm font-medium">{t.tour}</p>
              <p class="text-white/20 text-xs">{t.date}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-gradient-to-b from-[#0A1A18] to-[#0D0D0D] py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-black text-white mb-6">מוכנים לגלות את באלי?</h2>
      <p class="text-white/50 text-lg mb-10 max-w-xl mx-auto">ג׳ונגל, חופים, מקדשים ושקיעות — באלי מחכה לכם</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/visa" class="inline-flex items-center justify-center bg-gradient-to-r from-teal-500 to-teal-600 text-white px-10 py-4 rounded-xl font-bold text-lg transition-all hover:shadow-lg hover:shadow-teal-500/25">
          🛂 הגישו ויזה — 185 ₪
        </a>
        <a href="/plan" class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all border border-white/20">
          🗓️ תכנן את הטיול
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-6 mt-10 text-white/40 text-sm">
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          ויזה ב-24 שעות
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          תשלום מאובטח
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          מדריכים מקומיים
        </span>
      </div>
    </div>
  </section>
</Layout>
