      </p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מעוניין בטרקטרון או RZR בדובאי. איזו חבילה אתם מומלצים? 🏍️')}`}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-white text-green-600 px-8 py-4 rounded-full font-bold text-lg hover:bg-white/90 transition-all"
      >
        📱 שלחו הודעה בווטסאפ
      </a>
    </div>
  </section>

  <!-- Related Pages -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl md:text-3xl font-black text-white mb-6 text-center">טיולים <span class="text-amber-400">נוספים</span></h2>
    <div class="grid md:grid-cols-2 gap-6">
      <a
        href="/desert-safari"
        class="bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 rounded-xl p-6 transition-all group"
      >
        <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors mb-2">🏜️ ספארי במדבר</h3>
        <p class="text-white/60">ספארי בג׳יפ משותף או פרטי עם ארוחה, גמלים וסקי חולות</p>
      </a>
      <a
        href="/tours"
        class="bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 rounded-xl p-6 transition-all group"
