---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import FAQSection from '../components/FAQSection.astro'

const title = 'טרקטרון ו-RZR בדובאי | נהיגה עצמאית בדיונות | Yalla Dubai'
const description = 'טרקטרון ו-RZR בדובאי — הרפתקת שטח בדיונות. חבילות לזוגות ו-4 אנשים, בוקר ושקיעה. נהיגה עצמאית במדבר. הזמינו בווטסאפ.'

const packages = [
  {
    section: 'בוקר',
    items: [
      {
        name: 'ספארי בוקר + טרקטרון',
        duration: '4.5 שעות',
        price: 300,
        seats: '1 אדם',
        includes: ['נסיעה עצמאית בטרקטרון', 'חצי שעה נהיגה', 'גמלים וסקי חולות', 'איסוף והחזרה מהמלון'],
        featured: false,
        whatsappText: 'היי, אני מעוניין בספארי בוקר + טרקטרון בדובאי (300 AED)',
      },
      {
        name: 'ספארי בוקר + RZR (זוג)',
        duration: '4.5 שעות',
        price: 780,
        seats: '2 אנשים',
        includes: ['נסיעה עצמאית ב-RZR', 'חצי שעה נהיגה', 'גמלים וסקי חולות', 'איסוף והחזרה מהמלון'],
        featured: true,
        whatsappText: 'היי, אני מעוניין בספארי בוקר + RZR (זוג) בדובאי (780 AED)',
      },
    ],
  },
  {
    section: 'שקיעה (כולל ארוחה והופעות)',
    items: [
      {
        name: 'ספארי שקיעה + טרקטרון',
        duration: '6 שעות',
        price: 330,
        seats: '1 אדם',
        includes: ['נסיעה עצמאית בטרקטרון', 'חצי שעה נהיגה', 'ארוחה ערב', 'הופעות (رقص شرقي וריקוד)', 'איסוף והחזרה'],
        featured: false,
        whatsappText: 'היי, אני מעוניין בספארי שקיעה + טרקטרון בדובאי (330 AED)',
      },
      {
        name: 'ספארי שקיעה + RZR (זוג)',
        duration: '6 שעות',
        price: 790,
        seats: '2 אנשים',
        includes: ['נסיעה עצמאית ב-RZR', 'חצי שעה נהיגה', 'ארוחה ערב', 'הופעות (رقص شرقي וריקוד)', 'איסוף והחזרה'],
        featured: true,
        whatsappText: 'היי, אני מעוניין בספארי שקיעה + RZR (זוג) בדובאי (790 AED)',
      },
      {
        name: 'ספארי שקיעה + RZR (4 מושבים)',
        duration: '6 שעות',
        price: 1290,
        seats: '4 אנשים',
        includes: ['נסיעה עצמאית ב-RZR', 'חצי שעה נהיגה', 'ארוחה ערב', 'הופעות (رقص شرقي וריקوד)', 'איסוף והחזרה'],
        featured: false,
        whatsappText: 'היי, אני מעוניין בספארי שקיעה + RZR (4 מושבים) בדובאי (1290 AED)',
      },
    ],
  },
  {
    section: 'נהיגה עצמאית בלבד (ללא ארוחה)',
    items: [
      {
        name: 'RZR שעה (זוג)',
        duration: '3.5 שעות',
        price: 1100,
        seats: '2 אנשים',
        includes: ['שעה נהיגה עצמאית', 'גמלים וסקי חולות', 'ללא ארוחה או הופעות', 'איסוף והחזרה מהמלון'],
        featured: false,
        whatsappText: 'היי, אני מעוניין ב-RZR שעה (זוג) בדובאי (1100 AED)',
      },
      {
        name: 'RZR שעה (4 מושבים)',
        duration: '3.5 שעות',
        price: 1250,
        seats: '4 אנשים',
        includes: ['שעה נהיגה עצמאית', 'גמלים וסקי חולות', 'ללא ארוחה או הופעות', 'איסוף והחזרה מהמלון'],
        featured: false,
        whatsappText: 'היי, אני מעוניין ב-RZR שעה (4 מושבים) בדובאי (1250 AED)',
      },
      {
        name: 'Maverick X3 שעה (זוג)',
        duration: '3.5 שעות',
        price: 1350,
        seats: '2 אנשים',
        includes: ['שעה נהיגה עצמאית ברכב מהיר', 'גמלים וסקי חולות', 'ללא ארוחה או הופעות', 'איסוף והחזרה מהמלון'],
        featured: true,
        whatsappText: 'היי, אני מעוניין ב-Maverick X3 שעה בדובאי (1350 AED)',
      },
    ],
  },
]

const faqItems = [
  { q: 'כמה עולה טרקטרון בדובאי?', a: 'טרקטרון (ATV) בדובאי עולה החל מ-300 AED לאדם בספארי בוקר עם חצי שעה נהיגה. בשקיעה עם ארוחה הוא עולה 330 AED לאדם. כל החבילות כוללות איסוף והחזרה מהמלון שלכם.' },
  { q: 'מה ההבדל בין RZR לטרקטרון בדובאי?', a: 'RZR הוא רכב גדול יותר ומהיר יותר מטרקטרון, עם קושי לנהיגה גדול יותר. ב-RZR יכולים לשבת 2-4 אנשים (תלוי במודל), בעוד בטרקטרון רוכב אחד בלבד. RZR אתגר יותר וממלא פחות וקט יחסית, לכן הוא יקר יותר — החל מ-780 AED לזוג בבוקר.' },
  { q: 'האם צריך ניסיון לנסוע ב-RZR או טרקטרון בדובאי?', a: 'לא צריך ניסיון קודם! אתם תקבלו הדרכה בטיחותית מהנהג שלכם לפני שתוצאו לדיונות. הנהגים שלנו מנוסים בהנחיית תיירים חדשים. עם זאת, צריך לדבר קצת אנגלית או עברית כדי להבין את ההוראות בטיחות.' },
  { q: 'מה כלול בחבילת הטרקטרון/RZR בדובאי?', a: 'הכל כלול: נסיעה בג׳יפ לנקודת ההתחלה, הדרכה בטיחות וציוד, ניסיון של חצי שעה עד שעה בטרקטרון או RZR, רכיבה על גמלים, סקי חולות, ובחבילות שקיעה גם ארוחה ערב וביה״ס תרבות (رقص شرقي). כל זה כולל איסוף והחזרה מהמלון שלכם.' },
  { q: 'האם יכול לנסוע יותר מאדם אחד ב-RZR בדובאי?', a: 'כן! ב-RZR "זוג" יכולים לשבת 2 אנשים (הנהג + נוסע אחד). ב-RZR "4 מושבים" יכולים 4 אנשים. Maverick X3 הוא רכב קטן יותר עם 2 מושבים בלבד. בטרקטרון רוכב אחד בלבד.' },
  { q: 'כמה זמן לוקח נהיגה בטרקטרון או RZR בדובאי?', a: 'הנהיגה עצמאית בטרקטרון או RZR לוקחת בין חצי שעה עד שעה, תלוי בחבילה שבחרתם. חבילות הבוקר עם טרקטרון/RZR לוקחות בסך הכל 4-4.5 שעות (כולל איסוף, הדרכה, גמלים וסקי). חבילות השקיעה לוקחות 6 שעות כולל ארוחה.' },
  { q: 'מה גיל מינימום לנהיגה בטרקטרון או RZR בדובאי?', a: 'גיל מינימום: 18 שנים. צריך דרכון בתוקף לנהיגה. אם אתם מתחת ל-18, אתם יכולים לשבת כנוסע בחבילות ה-RZR "זוג" או "4 מושבים", אבל לא לנהוג.' },
  { q: 'האם טרקטרון ו-RZR בטוח בדובאי?', a: 'בהחלט בטוח! כל רכבי הטרקטרון וה-RZR בנבדקים בקביעות, כל הנהגים מנוסים, וכל אדם מקבל ציוד בטיחות (קסדה וכפפות). יש למדריכים רדיו תקשורת והדרכה שלפניים. דיוני דובאי בטוחים וממלא מקום עבור פעילות זו.' },
]

const stats = [
  { icon: '🏍️', label: 'נהיגה עצמאית' },
  { icon: '🏜️', label: 'בדיונות אמיתיות' },
  { icon: '🏨', label: 'כולל איסוף מהמלון' },
  { icon: '🛂', label: 'דרכון נדרש לנהגים' },
]

const included = [
  'ציוד בטיחות מלא (קסדה וכפפות)',
  'הדרכה בטיחות וטכניקת נהיגה',
  'נסיעה עצמאית בטרקטרון או RZR',
  'רכיבה על גמלים',
  'סקי חולות בדיונות',
  'איסוף והחזרה מהמלון',
  'צלום (צלם יקח לכם תמונות)',
]

const requirements = [
  { req: 'דרכון בתוקף', desc: 'דרכון ישראלי או בינלאומי בתוקף — חובה לנהגים' },
  { req: 'גיל מינימום 18', desc: 'גיל מינימום לנהיגה: 18. נוסעים יכולים להיות צעירים יותר' },
  { req: 'כושר גופני', desc: 'צריך להיות בעמדה בסדר כדי לנהוג. לא מומלץ לנשים בהריון או אנשים עם בעיות גב' },
  { req: 'ביגוד נכון', desc: 'נעליים סגורות (לא סנדלים), כתפיים מכוסות, מכנסיים ארוכים מומלצים' },
]

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'טרקטרון ו-RZR בדובאי — נהיגה עצמאית',
  description,
  url: 'https://yalla-dubai.co.il/quad-rzr-dubai',
  image: '/images/heroes/hero-dubai-dunes.webp',
  brand: {
    '@type': 'Organization',
    name: 'Yalla Dubai',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '120',
  },
  offers: packages.flatMap((section) =>
    section.items.map((item) => ({
      '@type': 'Offer',
      name: item.name,
      price: item.price,
      priceCurrency: 'AED',
      duration: 'PT' + (item.duration.includes('שעות') ? item.duration.split(' ')[0] + 'H' : item.duration.split(' ')[0] + 'H'),
      availability: 'https://schema.org/InStock',
      url: 'https://yalla-dubai.co.il/quad-rzr-dubai',
    }))
  ),
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'דף הבית', item: 'https://yalla-dubai.co.il/' },
    { '@type': 'ListItem', position: 2, name: 'טיולים', item: 'https://yalla-dubai.co.il/tours' },
    { '@type': 'ListItem', position: 3, name: 'טרקטרון ו-RZR' },
  ],
}
---

<Layout
  title={title}
  description={description}
  canonical="https://yalla-dubai.co.il/quad-rzr-dubai"
  ogImage="/images/heroes/hero-dubai-dunes.webp"
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero Section -->
  <section
    class="relative min-h-[60vh] bg-cover bg-center flex items-center justify-center overflow-hidden"
    style="background-image: linear-gradient(135deg, rgba(13, 13, 13, 0.7), rgba(26, 18, 8, 0.8)), url('/images/heroes/hero-dubai-dunes.webp');"
  >
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-br from-amber-900/30 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-amber-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <a href="/tours" class="hover:text-amber-400 transition-colors">טיולים</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">טרקטרון ו-RZR</span>
      </nav>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white mb-6 leading-tight">
        טרקטרון ו-RZR <span class="text-amber-400">בדובאי</span>
      </h1>

      <p class="text-xl md:text-2xl text-white/80 mb-8 max-w-2xl mx-auto leading-relaxed">
        נהיגה עצמאית על דיונות אמיתיות — טרקטרון, RZR ו-Maverick X3 לכל רמת ניסיון
      </p>

      <div class="flex flex-wrap gap-4 justify-center mb-8">
        <a
          href="#packages"
          class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-[#0D0D0D] px-8 py-4 rounded-full font-bold text-lg transition-all"
        >
          📦 ראו את החבילות
        </a>
        <a
          href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מעוניין בטרקטרון או RZR בדובאי 🏍️')}`}
          target="_blank"
          rel="noopener noreferrer"
          dir="rtl"
          class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white px-8 py-4 rounded-full font-bold text-lg transition-all"
        >
          📱 הזמינו דרך וואטסאפ
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="max-w-6xl mx-auto px-4 -mt-8 relative z-20 mb-12">
    <div class="bg-gradient-to-r from-amber-500/20 to-amber-500/10 backdrop-blur border border-amber-500/30 rounded-2xl p-6 md:p-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl mb-2">{stat.icon}</div>
            <p class="text-white font-bold text-sm md:text-base">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-6">מה זה טרקטרון ו-RZR?</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6">
        <h3 class="text-xl font-bold text-amber-400 mb-3">🏍️ טרקטרון (ATV)</h3>
        <p class="text-white/70">
          רכב קטן על 4 גלגלים, נהג בודד, קל וזריז. אידיאלי למתחילים — קל לשלוט ומהנה בדיונות.
        </p>
      </div>
      <div class="bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6">
        <h3 class="text-xl font-bold text-amber-400 mb-3">🚙 RZR (Side-by-Side)</h3>
        <p class="text-white/70">
          רכב גדול יותר עם הגה ומתלים טובים, יכול 2-4 אנשים. אתגר יותר מטרקטרון, מהיר ועוצמתי.
        </p>
      </div>
      <div class="bg-[#1A1208] border border-amber-500/20 rounded-2xl p-6">
        <h3 class="text-xl font-bold text-amber-400 mb-3">⚡ Maverick X3</h3>
        <p class="text-white/70">
          רכב קטנטן וקל בדיונות, מהיר מאוד וזריז. לנהגים עם קצת ניסיון — הנהיגה הכי מרגשת!
        </p>
      </div>
    </div>
  </section>

  <!-- Packages Section -->
  <section id="packages" class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-4xl md:text-5xl font-black text-white mb-12 text-center">חבילות <span class="text-amber-400">טרקטרון ו-RZR</span></h2>

    {packages.map((section) => (
      <div class="mb-16">
        <h3 class="text-2xl md:text-3xl font-black text-white mb-8">{section.section}</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {section.items.map((pkg) => (
            <div
              class={`relative rounded-2xl border transition-all overflow-hidden ${
                pkg.featured
                  ? 'bg-gradient-to-br from-amber-500/30 to-amber-600/10 border-amber-500/40 md:scale-105'
                  : 'bg-[#1A1208] border-amber-500/10 hover:border-amber-500/30'
              }`}
            >
              {pkg.featured && (
                <div class="absolute -top-2 -right-2 bg-amber-500 text-[#0D0D0D] px-4 py-1 rounded-full text-xs font-black">
                  🏆 הפופולרית ביותר
                </div>
              )}

              <div class="p-6">
                <h4 class="text-lg md:text-xl font-bold text-white mb-2">{pkg.name}</h4>

                <div class="flex items-baseline gap-2 mb-4">
                  <span class="text-4xl font-black text-amber-400">{pkg.price}</span>
                  <span class="text-white/60">AED</span>
                </div>

                <div class="flex gap-3 mb-4 text-sm">
                  <div class="flex-1">
                    <p class="text-white/40 text-xs mb-1">משך הזמן</p>
                    <p class="text-white font-semibold">{pkg.duration}</p>
                  </div>
                  <div class="flex-1">
                    <p class="text-white/40 text-xs mb-1">מושבים</p>
                    <p class="text-white font-semibold">{pkg.seats}</p>
                  </div>
                </div>

                <div class="border-t border-white/10 pt-4 mb-4">
                  <p class="text-xs text-white/40 mb-3 font-semibold">כלול בחבילה:</p>
                  <ul class="space-y-2">
                    {pkg.includes.map((item) => (
                      <li class="flex gap-2 text-sm text-white/70">
                        <span class="text-amber-400 flex-none">✓</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <a
                  href={`https://wa.me/972528211665?text=${encodeURIComponent(pkg.whatsappText)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  dir="rtl"
                  class={`block w-full py-3 rounded-lg font-bold text-center transition-all ${
                    pkg.featured
                      ? 'bg-amber-500 text-[#0D0D0D] hover:bg-amber-600'
                      : 'bg-white/10 text-white hover:bg-white/20'
                  }`}
                >
                  הזמינו דרך וואטסאפ
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- Included Section -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-6">מה כלול בכל חבילה?</h2>
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/20 rounded-2xl p-8">
      <ul class="grid md:grid-cols-2 gap-4">
        {included.map((item) => (
          <li class="flex gap-3 items-start">
            <span class="text-amber-400 text-xl flex-none">✓</span>
            <span class="text-white/80">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Requirements Section -->
  <section class="max-w-4xl mx-auto px-4 py-12">
