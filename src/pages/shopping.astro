---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'

const title = 'קניות בבאלי — שווקים, בוטיקים ומה לקנות | Yalla Bali'
const description = 'מדריך קניות בבאלי: שוק אומנות סוקוואטי, מרכז אובוד, שוק Seminyak, בוטיקים בקאנגו ועוד. מה לקנות, איפה לקנות ואיך לא להיפגע.'

const shoppingSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: 'https://images.unsplash.com/photo-1555400038-63f5ba517a47?w=800&q=80&fit=crop',
  url: new URL('/shopping', Astro.site).toString(),
  author: { '@type': 'Organization', name: 'Yalla Bali' },
  publisher: { '@type': 'Organization', name: 'Yalla Bali' },
}

const markets = [
  {
    image: 'https://images.unsplash.com/photo-1555400038-63f5ba517a47?w=800&q=80&fit=crop',
    name: 'Sukawati Art Market',
    nameHe: 'שוק האמנות סוקוואטי — מרכז ה-wholesale של באלי',
    area: 'Sukawati, Gianyar',
    description: 'שוק האמנות הגדול ביותר בבאלי. כאן קונים הסיטונאים שמוכרים אחר כך בשאר השווקים — כלומר המחירים כאן הכי נמוכים שתמצאו. שתי קומות של פסלים, ציורים, טקסטיל, תכשיטים, חוצלות ומוצרי עץ. הסוד: בואו בבוקר מוקדם (לפני 9:00) וחגרו חגורת מיקוח.',
    bestFor: 'כל מי שרוצה הכי הרבה תמורת הכסף',
    tips: 'מחיר פתיחה של המוכרים גבוה פי 3-5 מהמחיר הסביר. מיקוח אגרסיבי נחשב לגיטימי ומצופה.',
    openHours: '08:00-18:00 יומי',
    area_tag: 'דרום-מרכז',
    icon: '🎨',
  },
  {
    image: 'https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=800&q=80&fit=crop',
    name: 'Ubud Art Market',
    nameHe: 'שוק האמנות של אובוד — ממש מול ארמון המלך',
    area: 'Ubud Center',
    description: 'שוק האמנות של אובוד ממוקם ממש מול ארמון המלך (Ubud Palace) — מיקום שלא ניתן לפספס. הוא קטן יותר מסוקוואטי אבל נוח יותר לגישה ומרוכז יותר. תמצאו פה קרמיקה מקומית, תכשיטי כסף, בגדים בהדפסי באטיק, ואביזרי יוגה.',
    bestFor: 'תיירים שנמצאים ממילא באובוד',
    tips: 'בשעות אחר הצהריים הדוכנים ריקים יותר ומוכרים לעיתים מוכנים להוריד מחיר כדי לסגור עסקה.',
    openHours: '08:00-17:00 יומי',
    area_tag: 'אובוד',
    icon: '🏛️',
  },
  {
    image: 'https://images.unsplash.com/photo-1537365587684-f490102e1225?w=800&q=80&fit=crop',
    name: 'Seminyak Village',
    nameHe: 'Seminyak Village — קניון בוטיק',
    area: 'Seminyak',
    description: 'לא שוק — בוטיק מול מאורגן עם מותגים בינלאומיים ומקומיים. Seminyak Village הוא המקום לקניות נוחות ומאורגנות עם A/C, קפה ואווירה נעימה. תמצאו מותגי סרפ, בגדי ים, תכשיטים עיצוביים ומסעדות טובות.',
    bestFor: 'קניות נוחות בלי להתמקח',
    tips: 'חנויות כגון Biasa ו-Magali Pascal מוכרות עיצוב באלינזי איכותי שאי אפשר למצוא בשום מקום אחר.',
    openHours: '10:00-22:00 יומי',
    area_tag: 'סמינייק',
    icon: '🛍️',
  },
  {
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80&fit=crop',
    name: 'Canggu Boutiques',
    nameHe: 'בוטיקים קאנגו — ה-vibe של הסרפרים',
    area: 'Canggu / Berawa',
    description: 'קאנגו היא לא שוק — היא רחוב של בוטיקים עצמאיים. לאורך Jalan Batu Bolong ו-Echo Beach תמצאו חנויות קטנות עם עיצוב מקורי: בגדי סרף, בגדי יום-יום קז׳ואלים, תכשיטי כסף, נרות ורהיטי ראטן. אווירת הנוודים הדיגיטליים מורגשת גם בקניות.',
    bestFor: 'ה-cool vibes, בגדים יומיומיים ועיצוב לבית',
    tips: 'The Bali Craft מוכרת מוצרי בית קראפטיים שמתאימים מצוין כמתנות.',
    openHours: '09:00-21:00 (רוב החנויות)',
    area_tag: 'קאנגו',
    icon: '🏄',
  },
  {
    image: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=800&q=80&fit=crop',
    name: 'Kuta Beach Walk Mall',
    nameHe: 'Beachwalk Mall קוטה — הקניון הגדול',
    area: 'Kuta',
    description: 'Beachwalk הוא הקניון הגדול והמרכזי ביותר בבאלי לתיירים. ממוקם ממש ליד חוף קוטה עם גישה נוחה. תמצאו Zara, H&M, Mango, מותגים ספורטיביים, קינמת ומסעדות. אידיאלי לקניות בוקר כשהחוף עדיין שקט.',
    bestFor: 'מותגים בינלאומיים, קניות עם A/C',
    tips: 'החנויות פתוחות עד 22:00 — כדאי לקנות אחרי שובע מן החוף.',
    openHours: '10:00-22:00 יומי',
    area_tag: 'קוטה',
    icon: '🏬',
  },
  {
    image: 'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=800&q=80&fit=crop',
    name: 'Silver Jewelry Celuk',
    nameHe: 'כפר הכסף Celuk — תכשיטים ישירות מהאומן',
    area: 'Celuk, Gianyar',
    description: 'Celuk הוא כפר שכל תושביו הם צורפים — ממילא המקום הכי טוב לקנות תכשיטי כסף אמיתיים. בסטנדרט 925 (Sterling Silver) ובעיצובים מסורתיים באלינזיים שאי אפשר למצוא בשום מקום אחר. אפשר לראות את האומנים עובדים ולהזמין בהתאמה אישית.',
    bestFor: 'תכשיטי כסף אותנטיים, מתנות',
    tips: 'אל תקנו "כסף" בשווקים רגילים — רובו מגיע ממקומות לא מבוקרים. Celuk הוא הכתובת הנכונה.',
    openHours: '09:00-17:00 יומי',
    area_tag: 'ג\'יאניאר',
    icon: '💎',
  },
]

const whatToBuy = [
  { emoji: '👗', item: 'בגדי באטיק', desc: 'בד צבוע ביד בסגנון מסורתי — שמלות, חולצות, מטפחות' },
  { emoji: '🪵', item: 'פסלי עץ', desc: 'גנש, דמויות הינדיות, פסלי גן — עץ טיק ועץ פיקוס' },
  { emoji: '💍', item: 'תכשיטי כסף', desc: 'מ-Celuk — 925 sterling, עיצובים מסורתיים ומודרניים' },
  { emoji: '🧘', item: 'ציוד יוגה', desc: 'מחצלות, בגדי יוגה, קריסטלים, שמן קוקוס אורגני' },
  { emoji: '🎨', item: 'ציורים', desc: 'סצינות אורז, אלי, ריקודים — ציור יד על בד' },
  { emoji: '🌿', item: 'תמרוקים טבעיים', desc: 'שמן קוקוס, שמן ג\'ינג\'ר, בר-מוצרי טיפוח אורגניים' },
  { emoji: '☕', item: 'קפה לואק', desc: 'הקפה הכי יקר בעולם — בדקו אמינות לפני הקנייה' },
  { emoji: '🏺', item: 'קרמיקה ועבודות יד', desc: 'כוסות, צלחות ואביזרי עיצוב מאולמות האמנים' },
]
---

<Layout title={title} description={description} schema={shoppingSchema}>
  <!-- Hero -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-teal-900/30 to-transparent pointer-events-none" />
    <div class="mx-auto max-w-7xl px-4 sm:px-6 text-center">
      <p class="text-teal-400 font-semibold tracking-widest uppercase text-sm mb-3">קניות בבאלי</p>
      <h1 class="text-4xl md:text-5xl font-black text-white mb-4">
        שווקים, בוטיקים <span class="text-teal-400">ומה לקנות</span>
      </h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        מהשוק הסיטונאי בסוקוואטי ועד בוטיקי הסרפרים בקאנגו — המדריך המלא לקניות בבאלי
      </p>
    </div>
  </section>

  <!-- What to buy -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-16">
    <h2 class="text-2xl font-black text-white mb-6">🛒 מה כדאי לקנות בבאלי?</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {whatToBuy.map(item => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-4 hover:border-teal-500/30 transition-colors">
          <div class="text-3xl mb-2">{item.emoji}</div>
          <div class="font-bold text-white text-sm mb-1">{item.item}</div>
          <div class="text-white/50 text-xs leading-relaxed">{item.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Markets & Malls -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20">
    <h2 class="text-2xl font-black text-white mb-8">📍 שווקים ומרכזי קניות</h2>
    <div class="space-y-8">
      {markets.map((market, i) => (
        <div class={`flex flex-col md:flex-row gap-6 bg-white/[0.03] border border-white/10 rounded-2xl overflow-hidden hover:border-teal-500/20 transition-colors ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="md:w-2/5 h-56 md:h-auto overflow-hidden">
            <img
              src={market.image}
              alt={market.nameHe}
              class="w-full h-full object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
          <div class="flex-1 p-6 flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">{market.icon}</span>
              <span class="text-xs font-bold uppercase tracking-wider text-teal-400 bg-teal-500/10 px-2 py-0.5 rounded-full">{market.area_tag}</span>
            </div>
            <h3 class="text-xl font-black text-white mb-1">{market.nameHe}</h3>
            <p class="text-white/40 text-sm mb-3">{market.area} · {market.openHours}</p>
            <p class="text-white/70 text-sm leading-relaxed mb-4">{market.description}</p>
            <div class="flex flex-col gap-1.5">
              <div class="text-xs text-white/50">🎯 <span class="text-white/70">{market.bestFor}</span></div>
              <div class="text-xs text-teal-400">💡 {market.tips}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Tips section -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20">
    <div class="bg-teal-500/10 border border-teal-500/20 rounded-2xl p-8">
      <h2 class="text-xl font-black text-white mb-6">💡 טיפים לקניות חכמות בבאלי</h2>
      <div class="grid md:grid-cols-2 gap-4 text-sm text-white/70 leading-relaxed">
        <div class="space-y-3">
          <p>⚖️ <strong class="text-white">מיקוח זה חובה</strong> — בשווקים מסורתיים, מחיר הפתיחה גבוה פי 3-5. המיקוח הוא חלק מהתרבות, לא חוסר נימוס.</p>
          <p>💵 <strong class="text-white">מזומן שולט</strong> — שווקים מסורתיים עובדים עם מזומן בלבד. קחו רופיות לפני שיוצאים.</p>
          <p>🌡️ <strong class="text-white">בוקר מוקדם</strong> — מוכרים בשווקים מרוצים יותר ומאפשרים הנחות גדולות יותר בשעות הפתיחה.</p>
        </div>
        <div class="space-y-3">
          <p>🔍 <strong class="text-white">בדקו כסף אמיתי</strong> — תכשיטי כסף: חפשו חותמת 925 ו-Sterling. בלי חותמת = לא כסף אמיתי.</p>
          <p>☕ <strong class="text-white">קפה לואק</strong> — וודאו שהוא "ethical" (חופשי, לא כלוא) לפני הקנייה. מחיר הוגן: 50,000-80,000 IDR לכוס.</p>
          <p>🧳 <strong class="text-white">שקלו תוספת משקל</strong> — פסלי עץ ורהיטי ראטן כבדים. בדקו מחיר משלוח לישראל לפני שאתם קונים הרבה.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20 text-center">
    <div class="bg-gradient-to-r from-teal-900/40 to-teal-800/20 border border-teal-500/20 rounded-2xl p-10">
      <h2 class="text-2xl font-black text-white mb-3">צריכים עזרה עם הטיול?</h2>
      <p class="text-white/60 mb-6">מסלולים, ויזה, הזמנות — הכל בווטסאפ</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אנחנו מתכננים טיול לבאלי ורוצים עזרה עם הקניות והמסלול')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-teal-500 hover:bg-teal-400 text-black font-bold px-8 py-3 rounded-xl transition-colors"
      >
        💬 שלחו הודעה בווטסאפ
      </a>
    </div>
  </section>
</Layout>
