---
import Layout from '../../components/Layout.astro'
import RestaurantCard from '../../components/Cards/RestaurantCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import { optimizedImageUrl } from '../../lib/image'

const { data: categoryRows } = await supabaseAdmin
  .from('category_pages')
  .select('slug, title, subtitle, description, hero_image_url, source_category_field, source_category_value, sort_order')
  .eq('destination_id', DESTINATION_ID)
  .eq('source_table', 'restaurants')
  .eq('published', true)
  .order('sort_order', { ascending: true })

const categories = categoryRows ?? []

async function countForCategory(cat: typeof categories[number]): Promise<number> {
  const base = supabaseAdmin
    .from('restaurants')
    .select('slug', { count: 'exact', head: true })
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)
  if (cat.source_category_field === 'area') {
    const values = cat.source_category_value.split('|').map(v => v.trim()).filter(Boolean)
    const orClause = values.map(v => `area.ilike.%${v}%`).join(',')
    const { count } = await base.or(orClause)
    return count ?? 0
  }
  const { count } = await base.eq(cat.source_category_field, cat.source_category_value)
  return count ?? 0
}

const withCounts = await Promise.all(
  categories.map(async c => ({ ...c, count: await countForCategory(c) }))
)

const areaCategories = withCounts.filter(c => c.source_category_field === 'area')
const cuisineCategories = withCounts.filter(c => c.source_category_field !== 'area')

const { data: allRestaurants } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('name_he')

const restaurants = allRestaurants ?? []

const title = 'מסעדות בניו יורק — עמודי קטגוריה לפי איזור וסגנון | WeNewYorker'
const description = `${restaurants.length} מסעדות בניו יורק בעברית — לפי בורו (מנהטן, ברוקלין, קווינס, ברונקס, סטייטן איילנד) ולפי סגנון אוכל (איטלקי, פיצה, אסיאתי, כשר, סטייקים ועוד).`

const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מסעדות בניו יורק',
  description,
  numberOfItems: restaurants.length,
  itemListElement: restaurants.map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: r.name_he,
    url: new URL(`/restaurants/${r.slug}`, Astro.site).toString(),
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'דף הבית', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'מסעדות' },
  ],
}
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="relative py-16 px-4 bg-gradient-to-b from-teal-500/10 to-transparent">
    <div class="max-w-6xl mx-auto text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-teal-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">מסעדות</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black mb-4">מסעדות בניו יורק</h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto">
        {restaurants.length} מסעדות מומלצות לישראלים בניו יורק — לפי בורו (מנהטן, ברוקלין, קווינס, ברונקס, סטייטן איילנד) ולפי סגנון אוכל. כל עמוד עם המלצות, כתובות, מחירים ושעות פתיחה.
      </p>
    </div>
  </section>

  <!-- By Area -->
  {areaCategories.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-12">
      <header class="mb-6">
        <h2 class="text-2xl md:text-3xl font-black text-white border-r-4 border-teal-500 pr-4">
          מסעדות בניו יורק לפי איזור
        </h2>
        <p class="text-white/50 mt-2 pr-5 text-sm">בחרו את הבורו שבו אתם שוהים — כל איזור בניו יורק מציע סצנת מסעדות שונה.</p>
      </header>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {areaCategories.map(cat => (
          <a
            href={`/restaurants/${cat.slug}/`}
            class="group relative block overflow-hidden rounded-2xl border border-teal-500/10 hover:border-teal-500/40 bg-[#1A1208] transition-all card-lift aspect-[16/10]"
          >
            {cat.hero_image_url ? (
              <img
                src={optimizedImageUrl(cat.hero_image_url, 600)}
                alt={cat.title}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            ) : (
              <div class="absolute inset-0 bg-gradient-to-br from-teal-500/20 to-teal-900/40"></div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="relative h-full flex flex-col justify-end p-5">
              <h3 class="text-xl md:text-2xl font-black text-white group-hover:text-teal-400 transition-colors">
                {cat.title}
              </h3>
              {cat.subtitle && (
                <p class="text-white/70 text-sm mt-1 line-clamp-2">{cat.subtitle}</p>
              )}
              <div class="mt-3 flex items-center gap-2 text-teal-400 text-sm font-bold">
                <span>{cat.count} מסעדות</span>
                <span>←</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- By Cuisine -->
  {cuisineCategories.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-12 border-t border-white/5">
      <header class="mb-6">
        <h2 class="text-2xl md:text-3xl font-black text-white border-r-4 border-teal-500 pr-4">
          מסעדות בניו יורק לפי סגנון אוכל
        </h2>
        <p class="text-white/50 mt-2 pr-5 text-sm">מאיטלקי אותנטי עד פיצה ניו־יורקית וסטייקים קלאסיים — בחרו את הסגנון שאתם בקטע שלו.</p>
      </header>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {cuisineCategories.map(cat => (
          <a
            href={`/restaurants/${cat.slug}/`}
            class="group relative block overflow-hidden rounded-xl border border-teal-500/10 hover:border-teal-500/40 bg-[#1A1208] transition-all card-lift aspect-square"
          >
            {cat.hero_image_url ? (
              <img
                src={optimizedImageUrl(cat.hero_image_url, 400)}
                alt={cat.title}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover opacity-60 transition-transform duration-500 group-hover:scale-105 group-hover:opacity-80"
              />
            ) : (
              <div class="absolute inset-0 bg-gradient-to-br from-teal-500/10 to-teal-900/20"></div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>
            <div class="relative h-full flex flex-col justify-end p-4">
              <h3 class="text-base md:text-lg font-black text-white group-hover:text-teal-400 transition-colors line-clamp-2">
                {cat.title}
              </h3>
              <div class="mt-1.5 text-teal-400 text-xs font-bold">
                {cat.count} מסעדות ←
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Full archive list (no filters) -->
  <section class="max-w-6xl mx-auto px-4 py-12 border-t border-white/5 pb-20">
    <header class="mb-6">
      <h2 class="text-2xl md:text-3xl font-black text-white border-r-4 border-teal-500 pr-4">
        כל המסעדות ({restaurants.length})
      </h2>
      <p class="text-white/50 mt-2 pr-5 text-sm">לא רוצים לבחור לפי קטגוריה? הנה הרשימה המלאה בסדר אלפביתי.</p>
    </header>
    {restaurants.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {restaurants.map(r => (
          <RestaurantCard
            name_he={r.name_he}
            name_en={r.name_en}
            slug={r.slug}
            image={r.image}
            area={r.area}
            cuisine_types={r.cuisine_types}
            price_range={r.price_range}
            rating={r.rating}
          />
        ))}
      </div>
    ) : (
      <p class="text-center text-white/40 py-12">לא נמצאו מסעדות כרגע.</p>
    )}
  </section>
</Layout>
