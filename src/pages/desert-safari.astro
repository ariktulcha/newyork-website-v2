---

<Layout
  title="טיול ג׳יפים בדובאי — ספארי במדבר | האטרקציה הכי מבוקשת"
  description="טיול ג׳יפים במדבר דובאי — נסיעה מטורפת על דיונות, רכיבה על גמלים, שקיעה עוצרת נשימה וארוחת BBQ. החל מ-160 AED. הזמינו עכשיו בווטסאפ!"
  canonical="https://yalla-dubai.co.il/desert-safari"
>
  <SchemaOrg schema={[productSchema, touristTripSchema, faqSchema]} />

  <!-- HERO -->
  <section class="relative min-h-[75vh] md:min-h-[85vh] flex items-center justify-center overflow-hidden">
    <img
      src="/images/heroes/hero-dubai-dunes.webp"
      alt="טיול ג׳יפים על דיונות במדבר דובאי"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0D] via-[#0D0D0D]/60 to-[#0D0D0D]/30"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-[#1A1208]/80 backdrop-blur-sm border border-amber-500/20 rounded-full px-5 py-2.5 mb-8">
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <span class="text-amber-400 font-bold text-sm">4.9/5</span>
        <span class="text-white/50 text-sm">(1,000+ תיירים ישראלים)</span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white mb-6 leading-[1.1]">
        טיול ג׳יפים במדבר דובאי
      </h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 max-w-2xl mx-auto leading-relaxed">
        בכזה ספארי מדברי עוד לא הייתם — נסיעה מטורפת על דיונות הזהב, שקיעה עוצרת נשימה, ארוחת ערב מתחת לכוכבים. הטיול שהישראלים הכי אוהבים בדובאי.
      </p>
      <div class="text-3xl md:text-4xl font-black text-amber-400 mb-8">החל מ-<span class="text-amber-300">160 AED</span> <span class="text-white/40 text-lg font-normal">לאדם</span></div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a dir="rtl" href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מתעניין בספארי במדבר דובאי — טיול ג׳יפים')}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white px-10 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-green-500/25 hover:shadow-xl hover:-translate-y-0.5">
          הזמינו בווטסאפ
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href="#packages" class="inline-flex items-center justify-center gap-2 border border-amber-500/30 hover:border-amber-500/60 text-amber-400 px-8 py-4 rounded-xl font-bold text-lg transition-all hover:bg-amber-500/5">
          ראו את החבילות
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
    </div>
  </section>

  <!-- SOCIAL PROOF BAR -->
  <section class="bg-[#1A1208]/50 border-y border-amber-500/10 py-8">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-2xl md:text-3xl font-black text-amber-400 mb-1">1,000+</div>
          <div class="text-white/60 text-xs md:text-sm">תיירים ישראלים</div>
        </div>
        <div>
          <div class="text-2xl md:text-3xl font-black text-amber-400 mb-1 flex items-center justify-center gap-1">
            4.9/5
            <svg class="w-5 h-5 fill-amber-400 text-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <div class="text-white/60 text-xs md:text-sm">דירוג ממוצע</div>
        </div>
        <div>
          <div class="text-2xl md:text-3xl font-black text-amber-400 mb-1">365</div>
          <div class="text-white/60 text-xs md:text-sm">ימים בשנה</div>
        </div>
        <div>
          <div class="text-2xl md:text-3xl font-black text-amber-400 mb-1">6</div>
          <div class="text-white/60 text-xs md:text-sm">אנשים מקסימום בג׳יפ</div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IS DESERT SAFARI — SEO CONTENT -->
  <section class="max-w-4xl mx-auto px-4 py-16 md:py-24">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-8 text-center">מה זה בכלל <span class="text-amber-400">ספארי במדבר דובאי</span>?</h2>
    <div class="prose prose-invert max-w-none text-white/80 leading-relaxed space-y-6 text-lg">
      <p>
        טיול ג׳יפים במדבר דובאי (Desert Safari) הוא <strong class="text-white">האטרקציה הכי פופולרית</strong> בקרב תיירים ישראלים בדובאי — ומסיבה טובה. מדובר בחוויה מדברית שלמה שמשלבת אדרנלין, נופים מטורפים, ואוכל מעולה, הכל בטיול אחד של כמה שעות.
      </p>
      <p>
        אז איך זה עובד? נהג מקצועי מגיע לאסוף אתכם מהלובי של המלון עם <strong class="text-white">טויוטה לנד קרוזר</strong> נקייה וסופר איכותית. נוסעים כחצי שעה עד לאזור הדיונות של מדבר דובאי. שם, הנהג מוריד אוויר מהגלגלים — וככה הג׳יפ "גולש" על החול.
      </p>
      <p>
        ואז חברים, מתחיל הכיף האמיתי! הנהג לוקח אתכם על <strong class="text-white">נסיעה מטורפת על דיונות</strong> (Dune Bashing) — כחצי שעה של עליות וירידות תלולות, פניות חדות, והרגשה כמו רכבת הרים על חול. עד 6 אנשים בג׳יפ, וההרגשה היא שאתם בסרט הרפתקאות.
      </p>
      <p>
        אחרי הנסיעה יש עצירה על דיונה גבוהה — בדיוק בזמן השקיעה. <strong class="text-white">השקיעה במדבר דובאי</strong> היא משהו שצריך לראות כדי להאמין. השמיים נצבעים בכתום, אדום וזהב, ואתם עומדים על דיונת חול ענקית עם מדבר אינסופי מסביב. הרגע הזה שווה את כל הטיול.
      </p>
      <p>
        בהמשך — רכיבה על גמלים, סנדבורדינג (גלישה על חול), ובחבילות הערב גם ארוחת BBQ מפנקת במאהל בדואי מפואר עם מופע ריקוד בטן חי.
      </p>
    </div>
  </section>

  <!-- PHOTO GALLERY -->
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-8 text-center">תמונות <span class="text-amber-400">מהספארי במדבר</span></h2>
    <PhotoGallery
      mainImage="/images/attractions/desert-safari-jeep-dubai.webp"
      galleryUrls={galleryImages}
      name="ספארי במדבר דובאי — טיול ג׳יפים"
    />
  </section>

  <!-- PACKAGES -->
  <section id="packages" class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-4">חבילות <span class="text-amber-400">ספארי למדבר</span></h2>
      <p class="text-white/60 max-w-2xl mx-auto">ארבע קטגוריות של חבילות — כל סוג של מטייל יימצא משהו לעצמו</p>
    </div>

    {packageCategories.map((category) => (
      <div class="mb-16">
        <h3 class="text-2xl md:text-3xl font-black text-white mb-8">{category.categoryTitle}</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {category.packages.map((pkg) => (
            <div class={`relative bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] rounded-2xl border transition-all duration-300 hover:-translate-y-1 ${pkg.featured ? 'border-[#F59E0B]/40 shadow-lg shadow-[#F59E0B]/10 ring-1 ring-[#F59E0B]/20' : 'border-amber-500/10 hover:border-amber-500/30'}`}>
              <div class="absolute -top-3 right-6">
                <span class={`inline-block ${pkg.badgeColor} text-xs font-bold px-4 py-1.5 rounded-full shadow-md`}>{pkg.badge}</span>
              </div>
              <div class="p-6 md:p-8">
                <div class="mb-6">
                  <h4 class="text-2xl font-black text-white mb-1">{pkg.name}</h4>
                  <p class="text-white/40 text-sm">{pkg.nameEn}</p>
                </div>
                <div class="flex items-end gap-2 mb-2">
                  <span class="text-4xl font-black text-amber-400">{pkg.price}</span>
                  <span class="text-white/40 text-sm mb-1">AED</span>
                </div>
                <div class="flex items-center gap-1.5 text-white/50 text-sm mb-8">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  {pkg.duration}
                </div>
                <div class="space-y-3 mb-8">
                  <p class="text-white/60 text-xs font-bold uppercase tracking-wider">כולל:</p>
                  {pkg.includes.map((item) => (
                    <div class="flex items-start gap-2">
                      <svg class="w-5 h-5 text-amber-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      <span class="text-white/80 text-sm">{item}</span>
                    </div>
                  ))}
                </div>
                <a dir="rtl" href={`https://wa.me/972528211665?text=${encodeURIComponent(pkg.whatsappText)}`} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full py-4 rounded-xl font-bold text-lg transition-all hover:-translate-y-0.5 bg-[#25D366] hover:bg-[#1ebe5d] text-white shadow-lg shadow-green-500/20">
                  הזמינו בווטסאפ
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}

    <!-- Trust note under packages -->
    <div class="mt-8 text-center">
      <p class="text-white/40 text-sm">ללא עמלות הזמנה נסתרות. המחיר כולל הכל — איסוף, ביטוח, ציוד וכיבוד.</p>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="bg-[#1A1208]/30 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">מה <span class="text-amber-400">כלול בספארי</span></h2>
        <p class="text-white/60 max-w-xl mx-auto">כל מה שצריך לחוויה מושלמת — בלי תוספות ובלי הפתעות</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {includedItems.map((item) => (
          <div class="flex flex-col items-center text-center p-5 rounded-2xl bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-amber-500/10 hover:border-amber-500/20 transition-colors">
            <span class="text-3xl mb-3">{item.icon}</span>
            <span class="text-white/80 text-sm font-medium">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ITINERARY -->
  <section class="max-w-3xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">לוח <span class="text-amber-400">זמנים</span> — ספארי ערב</h2>
      <p class="text-white/60 max-w-xl mx-auto">כך נראה ספארי ערב + BBQ טיפוסי. ספארי בוקר יוצא ב-08:00 וחוזר עד 12:00.</p>
    </div>
    <div class="relative">
      <div class="absolute top-0 bottom-0 right-[39px] md:right-[47px] w-px bg-amber-500/20"></div>
      <div class="space-y-8">
        {itinerary.map((step, i) => (
          <div class="flex gap-4 md:gap-6 relative">
            <div class="shrink-0 w-[80px] md:w-[96px] text-left">
              <span class="inline-block bg-[#1A1208] border border-amber-500/20 rounded-lg px-3 py-1.5 text-amber-400 font-bold text-sm md:text-base">{step.time}</span>
            </div>
            <div class="absolute right-[35px] md:right-[43px] top-2.5 w-[9px] h-[9px] rounded-full bg-amber-400 ring-4 ring-[#0D0D0D]"></div>
            <div class="flex-1 pb-2">
              <h3 class="text-lg md:text-xl font-bold text-white mb-1">{step.title}</h3>
              <p class="text-white/60 text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- KOSHER SECTION -->
  <section class="bg-[#1A1208]/30 py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] rounded-2xl border border-amber-500/20 p-8 md:p-10">
        <h2 class="text-2xl md:text-3xl font-black text-white mb-6">ספארי במדבר <span class="text-amber-400">עם אוכל כשר</span></h2>
        <div class="text-white/80 leading-relaxed space-y-4">
          <p>
            אנחנו יודעים שהרבה מטיילים ישראלים שומרים כשרות — ויש לנו פתרון! ניתן להזמין את הספארי עם ארוחה כשרה שמגיעה ישירות למאהל.
          </p>
          <p>האפשרויות שלכם:</p>
          <ul class="space-y-2 mr-4">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span><strong class="text-white">ארוחה בשרית כשרה</strong> — מוכנה מראש ומגיעה אטומה</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span><strong class="text-white">דג על הגריל</strong> — אפשרות קלה יותר לשומרי מסורת</span>
            </li>
          </ul>
          <p class="text-white/60 text-sm">
            פשוט ציינו בהודעת הוואטסאפ שאתם צריכים אוכל כשר ונדאג להכל.
          </p>
        </div>
        <a
          dir="rtl"
          href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מעוניין בספארי במדבר עם אוכל כשר')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white px-8 py-3 rounded-xl font-bold transition-all hover:-translate-y-0.5 mt-6"
        >
