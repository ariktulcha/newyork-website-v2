const faqItems = [
  { q: 'מה כולל טיול ג׳יפים במדבר דובאי?', a: 'הטיול כולל איסוף והחזרה מהמלון, נסיעת ג׳יפים על דיונות (Dune Bashing) ברכב טויוטה לנד קרוזר, רכיבה על גמלים, סנדבורדינג, וצפייה בשקיעה מהמדבר. בחבילות השקיעה כלולה גם ארוחת BBQ מפנקת במאהל בדואי ומופע ריקוד בטן חי.' },
  { q: 'כמה עולה ספארי במדבר דובאי?', a: 'ספארי בוקר משותף מתחיל מ-160 AED לאדם (4 שעות), ספארי שקיעה + BBQ ב-180 AED לאדם (6 שעות), ספארי עם נהיגה עצמית בטרקטרון או RZR החל מ-300 AED (בוקר) או 330 AED (שקיעה). לאפשרויות פרטיות ומכוניות מיוחדות — המחירים גבוהים יותר. המחיר כולל איסוף, ביטוח וציוד.' },
  { q: 'האם הספארי בטוח לילדים?', a: 'כן, הספארי בטוח לילדים מגיל 3 ומעלה. הנהגים מקצועיים ומנוסים, והרכבים מצוידים בחגורות בטיחות. ניתן לבקש נסיעה רגועה יותר למשפחות עם ילדים קטנים. רכיבה על גמלים מתאימה לכל הגילים.' },
  { q: 'האם אפשר להזמין ספארי במדבר עם אוכל כשר?', a: 'כן! אנחנו יודעים לתת פתרון גם לשומרי כשרות ומסורת. ניתן להזמין ארוחות בשריות כשרות או ארוחה הכוללת דג על הגריל. עדכנו אותנו מראש בווטסאפ ונדאג לכם לפתרון.' },
  { q: 'כמה אנשים יושבים בג׳יפ?', a: 'עד 6 אנשים בג׳יפ. אם אתם רוצים ג׳יפ פרטי רק לקבוצה שלכם — ניתן להזמין את חבילת הספארי הפרטי, או פשוט לציין את זה בהזמנה ונדאג לכם לג׳יפ פרטי.' },
  { q: 'האם אני יכול לנהוג בג׳יפ בעצמי?', a: 'הנסיעה על הדיונות דורשת מיומנות ספציפית ולכן מתבצעת ע״י נהג מקצועי בלבד. אם אתם רוצים חוויית נהיגה עצמית — יש לנו חבילות טרקטרון (ATV) או RZR (באגי) שבהם אתם נוהגים בעצמכם!' },
  { q: 'מה כדאי ללבוש לספארי במדבר?', a: 'מומלץ ללבוש בגדים נוחים וקלים, נעליים סגורות (או סנדלים יציבים), ולהביא משקפי שמש וכובע. בערב יכול להיות קריר במדבר, אז כדאי לקחת שכבה נוספת. לפרטים נוספים — קראו את המדריך שלנו "מה ללבוש לספארי במדבר".' },
  { q: 'כמה זמן לפני צריך להזמין?', a: 'מומלץ להזמין לפחות 24-48 שעות מראש, אך ניתן לנסות גם הזמנה ביום עצמו בכפוף לזמינות. בעונות שיא (נובמבר-מרץ) כדאי להזמין מוקדם יותר. פשוט שלחו הודעה בווטסאפ וניתן לכם תשובה תוך דקות.' },
