---
import Layout from '../components/Layout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { site, waUrl } from '../config/site'
import { ITINERARIES, STYLE_META } from '../data/trip-itineraries'

const pageTitle = `תכנון טיול לניו יורק — מחולל לוז אישי | ${site.brand}`
const pageDescription = 'בנו את הטיול המושלם שלכם לניו יורק ב-3 קליקים: בחרו משך שהייה (3/5/7 ימים) וסגנון, וקבלו לוז יומי מפורט עם טיפים מהמקומיים.'

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'מחולל תכנון טיול לניו יורק',
  description: pageDescription,
  author: { '@type': 'Organization', name: site.brand },
  publisher: { '@type': 'Organization', name: site.brand, logo: { '@type': 'ImageObject', url: `https://${site.domain}/favicon.svg` } },
  datePublished: '2026-01-01',
  dateModified: new Date().toISOString().slice(0, 10),
  mainEntityOfPage: `https://${site.domain}/trip-planner`,
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'כמה ימים כדאי להקדיש לניו יורק?', acceptedAnswer: { '@type': 'Answer', text: 'המינימום המומלץ הוא 5 ימים כדי לכסות את האטרקציות המרכזיות ללא לחץ. 3 ימים מתאים לסוף שבוע ארוך אם כבר ביקרתם, ו-7 ימים מאפשרים להוסיף גם ברוקלין, Queens ויום יציאה ל-Woodbury Outlets.' } },
    { '@type': 'Question', name: 'כמה עולה טיול של 7 ימים לניו יורק?', acceptedAnswer: { '@type': 'Answer', text: '5,000–8,000$ לזוג כולל טיסה, מלון, אוכל ואטרקציות. התקציב תלוי עיקרית במלון (מ-$200 ל-$800 ללילה) ובסוג הפעילויות.' } },
    { '@type': 'Question', name: 'איך בונים לוז לניו יורק?', acceptedAnswer: { '@type': 'Answer', text: 'חלקו את העיר לאזורים — יום למנהטן מרכז, יום לסנטרל פארק, יום לברוקלין, יום ל-Downtown. אל תנסו לכסות הכל ביום אחד.' } },
    { '@type': 'Question', name: 'איזה סגנון טיול הכי מתאים?', acceptedAnswer: { '@type': 'Answer', text: 'פעם ראשונה — בחרו "קלאסי" (כל האטרקציות המרכזיות). אוהבי אוכל — "פודי". משפחות עם ילדים קטנים — "משפחות". תקציב מוגבל — "חסכוני".' } },
  ],
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'תכנון טיול' },
]
---

<Layout
  title={pageTitle}
  description={pageDescription}
  heroImage="/images/heroes/hero-newyork.webp"
  schema={[articleSchema, faqSchema]}
>
  <main class="mx-auto max-w-5xl px-4 py-10 sm:py-16">
    <Breadcrumb items={breadcrumbItems} />

    <!-- Hero -->
    <header class="mb-10 text-center">
      <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-teal-500/20 bg-teal-500/5 px-3 py-1 text-xs font-semibold text-teal-400">
        ✨ מחולל לוז אישי
      </div>
      <h1 class="mb-4 text-3xl font-bold text-white md:text-5xl">תכנון טיול לניו יורק ב-3 קליקים</h1>
      <p class="mx-auto max-w-2xl leading-relaxed text-white/60">
        בחרו משך שהייה, סגנון טיול, וקבלו לוז יומי מפורט עם כל המקומות החייבים — כולל טיפים מהמקומיים וקישורים לסיורים שלנו בעברית.
      </p>
    </header>

    <!-- Widget -->
    <div id="planner" class="rounded-3xl border border-white/5 bg-[#1A1208] p-6 md:p-10">
      <!-- Step 1: Duration -->
      <section data-step="duration" class="planner-step">
        <h2 class="mb-2 text-center text-2xl font-bold text-white">כמה ימים אתם בניו יורק?</h2>
        <p class="mb-8 text-center text-white/50">בחרו את משך הטיול המתוכנן</p>
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-4 sm:grid-cols-3">
          <button data-duration="3" class="group rounded-2xl border border-white/10 bg-[#0D0D0D] p-6 text-center transition-all hover:-translate-y-1 hover:border-teal-500/50 hover:shadow-lg hover:shadow-teal-500/10">
            <div class="mb-2 text-4xl font-black text-teal-400">3</div>
            <div class="font-medium text-white">ימים</div>
            <div class="mt-1 text-sm text-white/40">סוף שבוע ארוך</div>
          </button>
          <button data-duration="5" class="group rounded-2xl border border-white/10 bg-[#0D0D0D] p-6 text-center transition-all hover:-translate-y-1 hover:border-teal-500/50 hover:shadow-lg hover:shadow-teal-500/10">
            <div class="mb-2 text-4xl font-black text-teal-400">5</div>
            <div class="font-medium text-white">ימים</div>
            <div class="mt-1 text-sm text-white/40">הכי פופולרי</div>
          </button>
          <button data-duration="7" class="group rounded-2xl border border-white/10 bg-[#0D0D0D] p-6 text-center transition-all hover:-translate-y-1 hover:border-teal-500/50 hover:shadow-lg hover:shadow-teal-500/10">
            <div class="mb-2 text-4xl font-black text-teal-400">7</div>
            <div class="font-medium text-white">ימים</div>
            <div class="mt-1 text-sm text-white/40">שבוע מלא</div>
          </button>
        </div>
      </section>

      <!-- Step 2: Style -->
      <section data-step="style" class="planner-step hidden">
        <div class="mb-2 flex items-center justify-center gap-2">
          <button data-back="duration" class="text-white/40 transition-colors hover:text-white" aria-label="חזור">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
          <h2 class="text-center text-2xl font-bold text-white">מה הסגנון שלכם?</h2>
        </div>
        <p class="mb-8 text-center text-white/50"><span data-duration-label>5</span> ימים בניו יורק — איזה סוג טיול מדבר אליכם?</p>
        <div class="mx-auto grid max-w-3xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {(Object.keys(STYLE_META) as (keyof typeof STYLE_META)[]).map(s => (
            <button data-style={s} class="group flex items-center gap-4 rounded-2xl border border-white/10 bg-[#0D0D0D] p-5 text-right transition-all hover:-translate-y-0.5 hover:border-teal-500/50 hover:shadow-lg hover:shadow-teal-500/10">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-teal-500/10 text-2xl transition-colors group-hover:bg-teal-500/20">
                {STYLE_META[s].emoji}
              </div>
              <div>
                <div class="font-bold text-white">{STYLE_META[s].label}</div>
                <div class="text-sm text-white/40">{STYLE_META[s].desc}</div>
              </div>
            </button>
          ))}
        </div>
      </section>

      <!-- Step 3: Result -->
      <section data-step="result" class="planner-step hidden">
        <div class="mb-6 flex items-center justify-between">
          <button data-back="style" class="flex items-center gap-1 text-sm text-white/50 transition-colors hover:text-white">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            חזרה
          </button>
          <div class="flex items-center gap-2">
            <span class="rounded-full bg-teal-500/20 px-3 py-1 text-sm font-medium text-teal-400"><span data-result-duration>5</span> ימים</span>
            <span class="rounded-full bg-teal-500/20 px-3 py-1 text-sm font-medium text-teal-400"><span data-result-style>קלאסי</span></span>
          </div>
          <button data-reset class="text-sm font-medium text-white/50 transition-colors hover:text-teal-400">התחילו מחדש</button>
        </div>

        <h2 class="mb-2 text-center text-2xl font-bold text-white">
          הלוז שלכם ל-<span data-result-duration>5</span> ימים בניו יורק
        </h2>
        <p class="mb-8 text-center text-white/50">לחצו על כל יום לפרטים המלאים</p>

        <div id="days-list" class="space-y-3"></div>

        <!-- CTA Footer -->
        <div class="mt-10 rounded-2xl border border-teal-500/20 bg-gradient-to-br from-teal-500/10 to-teal-600/5 p-6 text-center">
          <h3 class="mb-2 text-xl font-bold text-white">רוצים מדריך ישראלי שיבנה לכם את הטיול?</h3>
          <p class="mb-5 text-sm text-white/60">סיורים בעברית ב-NYC מ-$59 לאדם — ולכל שאלה דברו איתנו בוואטסאפ.</p>
          <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a href="/tours" class="inline-flex items-center gap-2 rounded-xl bg-teal-500 px-6 py-3 text-sm font-bold text-white transition-all hover:bg-teal-400">
              ראו את הסיורים שלנו
            </a>
            <a href={waUrl('היי, אני מתכנן טיול לניו יורק ורוצה עזרה בבניית לוז')} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl bg-[#25D366] px-6 py-3 text-sm font-bold text-white transition-all hover:bg-[#1ebe5d]">
              דברו איתנו בוואטסאפ
            </a>
          </div>
        </div>
      </section>
    </div>

    <!-- FAQ -->
    <section class="mt-16 rounded-2xl border border-teal-500/10 bg-[#1A1208] p-6 md:p-8">
      <h2 class="mb-6 text-2xl font-bold text-teal-400">שאלות נפוצות — תכנון טיול לניו יורק</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer font-medium text-white transition-colors group-open:text-teal-400">כמה ימים כדאי להקדיש לניו יורק?</summary>
          <p class="mt-2 leading-relaxed text-white/60">המינימום המומלץ הוא 5 ימים כדי לכסות את האטרקציות המרכזיות ללא לחץ. 3 ימים מתאים לסוף שבוע ארוך אם כבר ביקרתם, ו-7 ימים מאפשרים להוסיף גם ברוקלין, Queens ויום יציאה ל-Woodbury Outlets.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer font-medium text-white transition-colors group-open:text-teal-400">כמה עולה טיול של 7 ימים לניו יורק?</summary>
          <p class="mt-2 leading-relaxed text-white/60">5,000–8,000$ לזוג כולל טיסה, מלון, אוכל ואטרקציות. התקציב תלוי עיקרית במלון (מ-$200 ל-$800 ללילה) ובסוג הפעילויות. טיול של 5 ימים זוגי בממוצע ~$4,500.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer font-medium text-white transition-colors group-open:text-teal-400">איך בונים לוז לניו יורק?</summary>
          <p class="mt-2 leading-relaxed text-white/60">חלקו את העיר לאזורים — יום למנהטן מרכז, יום לסנטרל פארק ומוזיאונים, יום לברוקלין, יום ל-Downtown. אל תנסו לכסות שני חלקי עיר באותו יום — תבזבזו זמן בסאבוויי.</p>
        </details>
        <details class="group pb-1">
          <summary class="cursor-pointer font-medium text-white transition-colors group-open:text-teal-400">איזה סגנון טיול הכי מתאים?</summary>
          <p class="mt-2 leading-relaxed text-white/60">פעם ראשונה — "קלאסי". אוהבי אוכל — "פודי". משפחות עם ילדים — "משפחות". תקציב מוגבל — "חסכוני". אם יש לכם זמן והעיר מוכרת — נסו "תרבות ואמנות".</p>
        </details>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ itineraries: ITINERARIES, styleLabels: Object.fromEntries(Object.entries(STYLE_META).map(([k, v]) => [k, v.label])) }}>
    document.addEventListener('DOMContentLoaded', function() {
      var state = { duration: null, style: null };
      var steps = {
        duration: document.querySelector('[data-step="duration"]'),
        style: document.querySelector('[data-step="style"]'),
        result: document.querySelector('[data-step="result"]'),
      };

      function show(step) {
        Object.keys(steps).forEach(function(k) {
          steps[k].classList.toggle('hidden', k !== step);
        });
        steps[step].scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Duration buttons
      document.querySelectorAll('[data-duration]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          state.duration = parseInt(btn.getAttribute('data-duration'), 10);
          document.querySelectorAll('[data-duration-label]').forEach(function(el) { el.textContent = state.duration; });
          show('style');
        });
      });

      // Style buttons
      document.querySelectorAll('[data-style]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          state.style = btn.getAttribute('data-style');
          renderResult();
          show('result');
        });
      });

      // Back buttons
      document.querySelectorAll('[data-back]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          show(btn.getAttribute('data-back'));
        });
      });

      // Reset
      var resetBtn = document.querySelector('[data-reset]');
      if (resetBtn) {
        resetBtn.addEventListener('click', function() {
          state = { duration: null, style: null };
          show('duration');
        });
      }

      function renderResult() {
        var key = state.style + '-' + state.duration;
        var plan = itineraries[key];
        document.querySelectorAll('[data-result-duration]').forEach(function(el) { el.textContent = state.duration; });
        var styleEl = document.querySelector('[data-result-style]');
        if (styleEl) styleEl.textContent = styleLabels[state.style];

        var list = document.getElementById('days-list');
        list.innerHTML = '';
        if (!plan) {
          list.innerHTML = '<p class="text-center text-white/40 py-8">לוז בתצורה הזו בהכנה — נסו שילוב אחר או צרו קשר בוואטסאפ.</p>';
          return;
        }

        plan.forEach(function(day, idx) {
          var el = document.createElement('div');
          el.className = 'overflow-hidden rounded-xl border border-white/10 bg-[#0D0D0D]';
          var tourCta = day.tourLink
            ? '<a href="' + day.tourLink.href + '" class="inline-flex items-center gap-1.5 rounded-lg bg-teal-500/20 px-3 py-1.5 text-xs font-bold text-teal-400 hover:bg-teal-500/30 transition">' + day.tourLink.text + ' →</a>'
            : '';
          el.innerHTML =
            '<button class="flex w-full items-center justify-between gap-4 p-5 text-right transition-colors hover:bg-white/5" data-toggle="' + idx + '">' +
              '<div class="flex min-w-0 items-center gap-4">' +
                '<div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-teal-500/10 text-lg font-black text-teal-400">' + day.day + '</div>' +
                '<div class="min-w-0 text-right">' +
                  '<div class="text-xs text-white/40">יום ' + day.day + '</div>' +
                  '<div class="truncate text-base font-bold text-white">' + day.title + '</div>' +
                '</div>' +
              '</div>' +
              '<svg class="h-5 w-5 shrink-0 text-white/30 transition-transform" data-chevron="' + idx + '" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>' +
            '</button>' +
            '<div class="hidden px-5 pb-5" data-details="' + idx + '">' +
              '<div class="space-y-4 border-t border-white/5 pt-4">' +
                '<div><div class="mb-1 flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-teal-400">🌅 בוקר</div><p class="text-sm leading-relaxed text-white/70">' + day.morning + '</p></div>' +
                '<div><div class="mb-1 flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-teal-400">☀️ אחר הצהריים</div><p class="text-sm leading-relaxed text-white/70">' + day.afternoon + '</p></div>' +
                '<div><div class="mb-1 flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-teal-400">🌆 ערב</div><p class="text-sm leading-relaxed text-white/70">' + day.evening + '</p></div>' +
                '<div class="rounded-lg border border-amber-500/20 bg-amber-500/5 p-3"><div class="mb-1 text-xs font-bold text-amber-400">💡 טיפ</div><p class="text-sm leading-relaxed text-white/70">' + day.tip + '</p></div>' +
                (tourCta ? '<div class="pt-2">' + tourCta + '</div>' : '') +
              '</div>' +
            '</div>';
          list.appendChild(el);
        });

        list.querySelectorAll('[data-toggle]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var idx = btn.getAttribute('data-toggle');
            var details = list.querySelector('[data-details="' + idx + '"]');
            var chevron = list.querySelector('[data-chevron="' + idx + '"]');
            details.classList.toggle('hidden');
            chevron.classList.toggle('rotate-180');
          });
        });
      }
    });
  </script>
</Layout>
