---
/**
 * BookingForm.astro
 * Tour booking form with Netlify Forms integration.
 * Client-side validation + success state.
 */
import { site, waUrl } from '../config/site'

interface BookingTour {
  slug: string
  name_he: string
  base_price?: number | null
  price?: number | null
  metadata?: { price?: number | null; [key: string]: unknown }
}

interface Props {
  tours: BookingTour[]
  preSelectedTour?: string
  preSelectedDate?: string
}

const { tours, preSelectedTour, preSelectedDate } = Astro.props

const normalizedTours = tours.map(t => ({
  slug: t.slug,
  name: t.name_he,
  price: t.base_price ?? t.price ?? t.metadata?.price ?? null,
}))

const whatsappFallback = waUrl(`היי, אנחנו רוצים להירשם לסיור בעברית ב${site.destinationName}`)
---

<div id="booking-form-wrapper">
  <!-- Success State (hidden by default) -->
  <div id="booking-success" class="hidden bg-[#1A1208] rounded-2xl p-6 sm:p-8 border border-teal-500/30 text-center">
    <svg class="w-16 h-16 text-teal-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <h3 class="text-2xl font-bold text-white mb-2">הבקשה נשלחה בהצלחה!</h3>
    <p class="text-white/60 mb-4">נחזור אליכם תוך 24 שעות עם אישור ופרטי תשלום.</p>
    <a
      href={whatsappFallback}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-teal-400 hover:text-teal-300 transition-colors text-sm"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      או צרו קשר בוואטסאפ
    </a>
  </div>

  <!-- Form -->
  <div id="booking-form-container" class="bg-[#1A1208] rounded-2xl p-4 sm:p-6 md:p-8 border border-teal-500/20">
    <p class="text-white/60 text-center mb-6">
      מלאו את הפרטים ונחזור אליכם תוך 24 שעות עם אישור ופרטי תשלום.
    </p>

    <form
      id="tour-booking-form"
      name="tour-booking"
      method="POST"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      class="space-y-4"
    >
      <input type="hidden" name="form-name" value="tour-booking" />
      <!-- Honeypot -->
      <div class="hidden" aria-hidden="true">
        <input name="bot-field" tabindex="-1" autocomplete="off" />
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="bf-name" class="block text-sm text-white/50 mb-2">שם מלא *</label>
          <input
            type="text"
            id="bf-name"
            name="name"
            required
            class="w-full bg-[#0D0D0D] border border-teal-500/10 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:border-teal-500 focus:outline-none transition-colors"
            placeholder="הכניסו את שמכם"
          />
        </div>
        <div>
          <label for="bf-email" class="block text-sm text-white/50 mb-2">אימייל *</label>
          <input
            type="email"
            id="bf-email"
            name="email"
            required
            class="w-full bg-[#0D0D0D] border border-teal-500/10 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:border-teal-500 focus:outline-none transition-colors"
            placeholder="your@email.com"
          />
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="bf-whatsapp" class="block text-sm text-white/50 mb-2">וואטסאפ *</label>
          <input
            type="tel"
            id="bf-whatsapp"
            name="whatsapp"
            required
            class="w-full bg-[#0D0D0D] border border-teal-500/10 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:border-teal-500 focus:outline-none transition-colors"
            placeholder="+972-50-1234567"
          />
        </div>
        <div>
          <label for="bf-tour" class="block text-sm text-white/50 mb-2">סיור *</label>
          <select
            id="bf-tour"
            name="tour"
            required
            class="w-full bg-[#0D0D0D] border border-teal-500/10 rounded-lg px-4 py-3 text-white focus:border-teal-500 focus:outline-none transition-colors"
          >
            <option value="">בחרו סיור</option>
            {normalizedTours.map(t => (
              <option value={t.slug} selected={t.slug === preSelectedTour}>
                {t.name}{t.price ? ` - $${t.price}` : ''}
              </option>
            ))}
            <option value="bundle">מבצע חבילה: 2 סיורים - $100</option>
          </select>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="bf-date" class="block text-sm text-white/50 mb-2">תאריך סיור *</label>
          <input
            type="date"
            id="bf-date"
            name="date"
            required
            value={preSelectedDate ?? ''}
            class="w-full bg-[#0D0D0D] border border-teal-500/10 rounded-lg px-4 py-3 text-white focus:border-teal-500 focus:outline-none transition-colors"
          />
        </div>
        <div>
          <label for="bf-participants" class="block text-sm text-white/50 mb-2">מספר משתתפים *</label>
          <select
            id="bf-participants"
            name="participants"
            required
            class="w-full bg-[#0D0D0D] border border-teal-500/10 rounded-lg px-4 py-3 text-white focus:border-teal-500 focus:outline-none transition-colors"
          >
            <option value="">בחרו</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
            <option value="6">6</option>
            <option value="7">7</option>
            <option value="8">8+</option>
          </select>
        </div>
      </div>

      <div class="flex items-start gap-3 pt-2">
        <input
          type="checkbox"
          name="consent"
          id="bf-consent"
          required
          class="w-5 h-5 shrink-0 accent-teal-500 mt-0.5"
        />
        <label for="bf-consent" class="text-sm text-white/50">
          אני מאשר/ת קבלת מידע בנוגע להזמנה זו באימייל ובוואטסאפ
        </label>
      </div>

      <button
        type="submit"
        class="w-full bg-teal-500 hover:bg-teal-600 text-[#0D0D0D] py-4 rounded-xl font-bold text-lg transition-colors flex items-center justify-center gap-2"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
        שלחו בקשת הרשמה
      </button>
    </form>

    <!-- WhatsApp fallback -->
    <div class="mt-4 text-center">
      <p class="text-white/40 text-sm mb-2">מעדיפים לדבר ישירות?</p>
      <a
        href={whatsappFallback}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-[#25D366] hover:text-[#1ebe5d] font-medium text-sm transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        שלחו הודעה בוואטסאפ
      </a>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var form = document.getElementById('tour-booking-form');
  var container = document.getElementById('booking-form-container');
  var success = document.getElementById('booking-success');
  var dateInput = document.getElementById('bf-date');

  // Set min date to today
  if (dateInput) {
    var now = new Date();
    var y = now.getFullYear();
    var m = String(now.getMonth() + 1).padStart(2, '0');
    var d = String(now.getDate()).padStart(2, '0');
    dateInput.setAttribute('min', y + '-' + m + '-' + d);
  }

  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var formData = new FormData(form);

    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(formData).toString(),
    })
    .then(function() {
      container.classList.add('hidden');
      success.classList.remove('hidden');
    })
    .catch(function() {
      // Show success anyway — Netlify will still receive the form in most cases
      container.classList.add('hidden');
      success.classList.remove('hidden');
    });
  });
})();
</script>
