  <!-- WhatsApp Button -->
  <WhatsAppButton />

  <!-- Layout interactivity: mobile menu, tours dropdown, promo bar -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // Mobile menu
      var btn = document.getElementById('mobile-menu-btn');
      var menu = document.getElementById('mobile-menu');
      var iconOpen = document.getElementById('menu-icon-open');
      var iconClose = document.getElementById('menu-icon-close');
      if (btn && menu && iconOpen && iconClose) {
        btn.addEventListener('click', function() {
          var isOpen = menu.style.maxHeight && menu.style.maxHeight !== '0px';
          if (isOpen) {
            menu.style.maxHeight = '0px';
            iconOpen.classList.remove('hidden');
            iconClose.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
          } else {
            menu.style.maxHeight = menu.scrollHeight + 'px';
            iconOpen.classList.add('hidden');
            iconClose.classList.remove('hidden');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      }

      // Tours mega-dropdown (desktop hover)
      var toursWrap = document.querySelector('[data-tours-dropdown]');
      if (toursWrap) {
        var panel = toursWrap.querySelector('[data-tours-panel]');
        var chevron = toursWrap.querySelector('[data-tours-chevron]');
        var closeTimer = null;
        function showPanel() {
          if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
          panel.classList.remove('opacity-0', '-translate-y-2', 'pointer-events-none');
          panel.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
          if (chevron) chevron.classList.add('rotate-180');
        }
        function hidePanel() {
          closeTimer = setTimeout(function() {
            panel.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            panel.classList.add('opacity-0', '-translate-y-2', 'pointer-events-none');
            if (chevron) chevron.classList.remove('rotate-180');
          }, 180);
        }
        toursWrap.addEventListener('mouseenter', showPanel);
        toursWrap.addEventListener('mouseleave', hidePanel);
        panel.addEventListener('mouseenter', showPanel);
        panel.addEventListener('mouseleave', hidePanel);
      }

      // Promo bar dismissal (session-scoped)
      var promo = document.getElementById('promo-bar');
      var promoClose = document.getElementById('promo-close');
      if (promo && promoClose) {
        if (sessionStorage.getItem('wny_promo_dismissed') === '1') {
          promo.style.display = 'none';
        }
        promoClose.addEventListener('click', function() {
          promo.style.display = 'none';
          try { sessionStorage.setItem('wny_promo_dismissed', '1'); } catch(e){}
        });
      }
    });
  </script>
</body>
