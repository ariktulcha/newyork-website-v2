---
/**
 * FloatingTourCTA.astro
 * Scroll-triggered bottom CTA bar for tours.
 * Appears after scrolling 600px, dismissible.
 */
import { site } from '../config/site'
---

<div
  id="floating-tour-cta"
  class="fixed bottom-0 left-0 right-0 z-50 translate-y-full transition-transform duration-500 ease-out"
>
  <div class="bg-[#0D0D0D]/95 backdrop-blur-xl border-t border-teal-500/15" style="padding-bottom: env(safe-area-inset-bottom)">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-3">
      <!-- Info -->
      <div class="flex-1 min-w-0">
        <p class="text-white text-sm font-bold truncate">
          סיורים בעברית ב{site.destinationName}
        </p>
        <p class="text-white/40 text-xs mt-0.5 flex items-center gap-2">
          <span class="hidden sm:inline-flex items-center gap-1">
            <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            4.9/5
          </span>
          <span class="sm:hidden inline-flex items-center gap-1">
            <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            4.9/5
          </span>
          <span class="hidden sm:inline">&middot;</span>
          <span>החל מ-$59 לאדם</span>
          <span class="hidden sm:inline">&middot;</span>
          <span class="hidden sm:inline">מדריכים ישראלים</span>
        </p>
      </div>

      <!-- CTA + Dismiss -->
      <div class="flex items-center gap-2 shrink-0">
        <a
          href="/tours"
          class="group bg-gradient-to-r from-teal-500 to-teal-600 hover:from-teal-400 hover:to-teal-500 text-white px-5 py-2.5 rounded-xl font-bold text-sm transition-all shadow-lg shadow-teal-500/25 flex items-center gap-1.5"
        >
          <span>הזמינו סיור</span>
          <svg class="w-3.5 h-3.5 rotate-180 group-hover:translate-x-[-2px] transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
        <button
          id="floating-cta-dismiss"
          class="text-white/30 hover:text-white p-2.5 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="סגור"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var cta = document.getElementById('floating-tour-cta');
  var dismissBtn = document.getElementById('floating-cta-dismiss');
  if (!cta || !dismissBtn) return;

  var dismissed = false;
  var visible = false;

  function update() {
    if (dismissed) {
      cta.style.display = 'none';
      return;
    }
    var shouldShow = window.scrollY > 600;
    if (shouldShow !== visible) {
      visible = shouldShow;
      if (visible) {
        cta.classList.remove('translate-y-full');
        cta.classList.add('translate-y-0');
      } else {
        cta.classList.remove('translate-y-0');
        cta.classList.add('translate-y-full');
      }
    }
  }

  window.addEventListener('scroll', update, { passive: true });
  dismissBtn.addEventListener('click', function() {
    dismissed = true;
    update();
  });
})();
</script>
