---
import { optimizedImageUrl } from '../../lib/image'
interface Props {
  name_he: string;
  slug: string;
  image?: string;
  price?: number;
  base_price?: number;
  duration_hours?: number;
  duration_minutes?: number;  // legacy compat
  excerpt?: string;
  short_description?: string; // legacy compat
}

const {
  name_he,
  slug,
  image,
  price: _price,
  base_price,
  duration_hours,
  duration_minutes,
  excerpt,
  short_description,
} = Astro.props;

const price = base_price ?? _price;
const desc = excerpt ?? short_description;

// Duration display: prefer hours, fallback to minutes
const durationText = duration_hours
  ? `${duration_hours} שעות`
  : duration_minutes
    ? duration_minutes >= 60
      ? `${Math.floor(duration_minutes / 60)} שעות`
      : `${duration_minutes} דק׳`
    : null;
---

<a href={`/tours/${slug}`} class="group block bg-[#1A1208] border border-teal-500/10 hover:border-teal-500/30 rounded-2xl overflow-hidden transition-all card-lift">
  <div class="aspect-[16/10] overflow-hidden relative">
    {image ? (
      <img
        src={optimizedImageUrl(image, 400)}
        alt={name_he}
        loading="lazy"
        decoding="async"
        width="400"
        height="250"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-teal-500/20 to-teal-900/20 flex items-center justify-center">
        <span class="text-4xl">🗺️</span>
      </div>
    )}
    {price && (
      <span class="absolute top-3 end-3 text-sm px-3 py-1 rounded-full bg-teal-500 text-black font-bold">
        ₪{price}
      </span>
    )}
  </div>
  <div class="p-4 space-y-2">
    <h3 class="text-lg font-bold text-white group-hover:text-teal-400 transition-colors">{name_he}</h3>
    {desc && (
      <p class="text-sm text-white/60 line-clamp-2 leading-relaxed">{desc}</p>
    )}
    {durationText && (
      <div class="flex items-center gap-1 text-sm text-white/60">
        <svg class="w-3.5 h-3.5 text-teal-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {durationText}
      </div>
    )}
  </div>
</a>
