---
import { optimizedImageUrl } from '../../lib/image'
interface Props {
  name_he: string;
  name_en?: string;
  slug: string;
  image?: string;
  area?: string;
  price?: string;
  price_range?: string;
  is_free?: boolean;
  rating?: number;
}

const { name_he, name_en, slug, image, area, price: _price, price_range, is_free, rating } = Astro.props;
const price = is_free ? 'חינם' : (price_range ?? _price);
---

<a href={`/attractions/${slug}`} class="group block bg-[#1A1208] border border-teal-500/10 hover:border-teal-500/30 rounded-2xl overflow-hidden transition-all card-lift">
  <div class="aspect-[16/10] overflow-hidden">
    {image ? (
      <img
        src={optimizedImageUrl(image, 400)}
        alt={name_he}
        loading="lazy"
        decoding="async"
        width="400"
        height="250"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-teal-500/20 to-teal-900/20 flex items-center justify-center">
        <span class="text-4xl">🎡</span>
      </div>
    )}
  </div>
  <div class="p-4 space-y-2">
    <h3 class="text-lg font-bold text-white group-hover:text-teal-400 transition-colors">{name_he}</h3>
    {name_en && <p class="text-sm text-white/40">{name_en}</p>}
    <div class="flex flex-wrap items-center gap-2 text-sm text-white/60">
      {area && (
        <span class="inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5 text-teal-500/60" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          {area}
        </span>
      )}
      {price && (
        <span class="inline-flex items-center gap-1 text-teal-400 font-medium">
          {price === 'free' || price === '0' ? 'חינם' : price}
        </span>
      )}
      {rating && (
        <span class="inline-flex items-center gap-1 text-teal-400">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {rating.toFixed(1)}
        </span>
      )}
    </div>
  </div>
</a>
