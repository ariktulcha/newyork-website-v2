---
import { optimizedImageUrl } from '../../lib/image'
interface Props {
  name_he: string;
  slug: string;
  image?: string;
  excerpt?: string;
  category?: string;
  read_time?: number;
  read_time_min?: number;
  date?: string;
}

const { name_he, slug, image, excerpt, category, read_time, read_time_min, date } = Astro.props;
const readTime = read_time_min ?? read_time;

const formattedDate = date ? new Date(date).toLocaleDateString('he-IL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}) : null;
---

<a href={`/guides/${slug}`} class="group block bg-[#1A1208] border border-teal-500/10 hover:border-teal-500/30 rounded-2xl overflow-hidden transition-all card-lift">
  <div class="aspect-[16/9] overflow-hidden relative">
    {image ? (
      <img
        src={optimizedImageUrl(image, 400)}
        alt={name_he}
        loading="lazy"
        decoding="async"
        width="400"
        height="250"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-teal-500/20 to-teal-900/20 flex items-center justify-center">
        <span class="text-4xl">📖</span>
      </div>
    )}
    {category && (
      <span class="absolute top-3 start-3 text-xs px-2.5 py-1 rounded-full bg-teal-500/90 text-black font-medium">
        {category}
      </span>
    )}
  </div>
  <div class="p-4 space-y-2">
    <h3 class="text-lg font-bold text-white group-hover:text-teal-400 transition-colors leading-snug">{name_he}</h3>
    {excerpt && (
      <p class="text-sm text-white/60 line-clamp-2 leading-relaxed">{excerpt}</p>
    )}
    <div class="flex flex-wrap items-center gap-3 text-xs text-white/40 pt-1">
      {formattedDate && (
        <span>{formattedDate}</span>
      )}
      {readTime && (
        <span class="inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {readTime} דק׳ קריאה
        </span>
      )}
    </div>
  </div>
</a>
