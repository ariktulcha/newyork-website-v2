---
import { optimizedImageUrl } from '../../lib/image'
interface Props {
  name_he: string;
  name_en?: string;
  slug: string;
  image?: string;
  area?: string;
  type?: string;
}

const { name_he, name_en, slug, image, area, type } = Astro.props;
---

<a href={`/nightlife/${slug}`} class="group block bg-[#1A1208] border border-teal-500/10 hover:border-teal-500/30 rounded-2xl overflow-hidden transition-all card-lift">
  <div class="aspect-[16/10] overflow-hidden relative">
    {image ? (
      <img
        src={optimizedImageUrl(image, 400)}
        alt={name_he}
        loading="lazy"
        decoding="async"
        width="400"
        height="250"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-teal-500/20 to-purple-900/20 flex items-center justify-center">
        <span class="text-4xl">🌃</span>
      </div>
    )}
    {type && (
      <span class="absolute top-3 start-3 text-xs px-2.5 py-1 rounded-full bg-teal-500/90 text-black font-medium">
        {type}
      </span>
    )}
  </div>
  <div class="p-4 space-y-2">
    <h3 class="text-lg font-bold text-white group-hover:text-teal-400 transition-colors">{name_he}</h3>
    {name_en && <p class="text-sm text-white/40">{name_en}</p>}
    {area && (
      <div class="flex items-center gap-1 text-sm text-white/60">
        <svg class="w-3.5 h-3.5 text-teal-500/60" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
        {area}
      </div>
    )}
  </div>
</a>
